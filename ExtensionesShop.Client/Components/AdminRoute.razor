@using ExtensionesShop.Client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

@if (!hasChecked)
{
    <div class="loading-container">
        <div class="spinner">✦</div>
        <p>Verificando permisos...</p>
    </div>
}
else if (!isAuthorized)
{
    <div class="unauthorized-container">
        <div class="unauthorized-icon">🔒</div>
        <h2>Acceso Denegado</h2>
        <p>@errorMessage</p>
        <a href="/" class="btn-primary">Volver al Inicio</a>
    </div>
}
else
{
    @ChildContent
}

<style>
    .loading-container,
    .unauthorized-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 40px 20px;
        text-align: center;
        background: #F5F7FA;
    }

    .spinner {
        font-size: 48px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .unauthorized-icon {
        font-size: 80px;
        margin-bottom: 24px;
        opacity: 0.3;
    }

    .unauthorized-container h2 {
        font-size: 32px;
        color: var(--ink);
        margin-bottom: 16px;
    }

    .unauthorized-container p {
        font-size: 16px;
        color: #64748B;
        margin-bottom: 32px;
        max-width: 500px;
    }
</style>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool hasChecked = false;
    private bool isAuthorized = false;
    private string errorMessage = "";

    // Usamos OnAfterRenderAsync porque aquí es 100% seguro leer el LocalStorage y redirigir
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckAccess();
            StateHasChanged(); // Obligamos a Blazor a repintar la pantalla
        }
    }

    private async Task CheckAccess()
    {
        try
        {
            if (!AuthService.IsAuthenticated)
            {
                errorMessage = "Debes iniciar sesión para acceder al panel.";
                hasChecked = true;
                isAuthorized = false;
                Navigation.NavigateTo("/cuenta");
                return;
            }

            if (!AuthService.IsAdmin)
            {
                errorMessage = $"Acceso denegado. Se requiere rol 'Admin'.";
                hasChecked = true;
                isAuthorized = false;
                Navigation.NavigateTo("/"); // Si es un cliente normal, lo mandamos a la tienda
                return;
            }

            // Si pasa los dos if, es Admin real
            isAuthorized = true;
            hasChecked = true;
        }
        catch (Exception ex)
        {
            // Si hay cualquier error leyendo la sesión, por seguridad lo expulsamos
            Console.WriteLine($"Error de seguridad: {ex.Message}");
            Navigation.NavigateTo("/cuenta");
        }
    }
}