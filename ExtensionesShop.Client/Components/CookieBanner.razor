@using System.Text.Json
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject NavigationManager Navigation

@if (ShowBanner)
{
    <div class="cookie-banner">
        <div class="cookie-banner-content">
            <div class="cookie-banner-text">
                <h3 class="cookie-banner-title">Información sobre Cookies</h3>
                <p class="cookie-banner-message">
                    Utilizamos cookies para optimizar tu experiencia de navegación y análisis de uso. 
                    Esto incluye cookies propias y de terceros para personalizar contenido y publicidad.
                    <a href="/cookies" class="cookie-banner-link">Más información</a>
                </p>
            </div>
            <div class="cookie-banner-actions">
                <button class="cookie-btn-reject" @onclick="RejectCookies">
                    Rechazar
                </button>
                <button class="cookie-btn-accept" @onclick="AcceptCookies">
                    Aceptar
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool ShowBanner = false;

    protected override async Task OnInitializedAsync()
    {
        await CheckCookieConsent();
    }

    private async Task CheckCookieConsent()
    {
        try
        {
            // Verificar si existe la clave de consentimiento en localStorage
            var consent = await JS.InvokeAsync<string>("window.localStorage.getItem", "cookieConsent");

            // Si no existe, mostrar el banner
            ShowBanner = string.IsNullOrEmpty(consent);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al verificar consentimiento de cookies: {ex.Message}");
            // Por seguridad, mostrar el banner si hay error
            ShowBanner = true;
        }
    }

    private async Task AcceptCookies()
    {
        try
        {
            // Guardar la aceptación en localStorage
            var consentData = new
            {
                accepted = true,
                timestamp = DateTime.UtcNow.ToString("O")
            };

            var json = JsonSerializer.Serialize(consentData);
            await JS.InvokeVoidAsync("window.localStorage.setItem", "cookieConsent", json);

            // Ocultar el banner sin recargar la página
            ShowBanner = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar consentimiento de cookies: {ex.Message}");
        }
    }

    private async Task RejectCookies()
    {
        try
        {
            // Guardar el rechazo en localStorage
            var consentData = new
            {
                accepted = false,
                timestamp = DateTime.UtcNow.ToString("O")
            };

            var json = JsonSerializer.Serialize(consentData);
            await JS.InvokeVoidAsync("window.localStorage.setItem", "cookieConsent", json);

            // Ocultar el banner sin recargar la página
            ShowBanner = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar rechazo de cookies: {ex.Message}");
        }
    }
}


<style>
    /* ============================================================
       COOKIE BANNER - Componente de Consentimiento LSSI-CE
       ============================================================ */

    .cookie-banner {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 9999;
        background: linear-gradient(135deg, rgba(233, 30, 99, 0.98) 0%, rgba(212, 175, 55, 0.08) 100%), linear-gradient(to bottom, var(--white), var(--off-white));
        backdrop-filter: blur(10px);
        border-top: 2px solid var(--rose-light);
        padding: 24px var(--inner-pad);
        animation: cookieFadeIn 0.6s var(--ease-smooth) forwards;
        box-shadow: var(--shadow-rose);
    }

    @@keyframes cookieFadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .cookie-banner-content {
        max-width: var(--inner-max);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 32px;
        align-items: center;
    }

    .cookie-banner-text {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .cookie-banner-title {
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 600;
        color: var(--white);
        margin: 0;
        letter-spacing: 0.3px;
    }

    .cookie-banner-message {
        font-family: var(--font-body);
        font-size: 14px;
        line-height: 1.5;
        color: rgba(255, 255, 255, 0.95);
        margin: 0;
    }

    .cookie-banner-link {
        color: var(--gold-light);
        font-weight: 600;
        text-decoration: underline;
        transition: all 0.3s var(--ease-smooth);
        display: inline;
        white-space: nowrap;
    }

        .cookie-banner-link:hover {
            color: var(--gold);
            text-shadow: 0 0 8px rgba(240, 201, 104, 0.3);
        }

    .cookie-banner-actions {
        display: flex;
        gap: 12px;
        flex-shrink: 0;
    }

    /* Botones de acciones */
    .cookie-btn-reject,
    .cookie-btn-accept {
        padding: 10px 20px;
        border-radius: 6px;
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s var(--ease-smooth);
        border: none;
        white-space: nowrap;
    }

    .cookie-btn-reject {
        background: rgba(255, 255, 255, 0.2);
        color: var(--white);
        border: 1.5px solid rgba(255, 255, 255, 0.4);
    }

        .cookie-btn-reject:hover {
            background: rgba(255, 255, 255, 0.3);
            border-color: rgba(255, 255, 255, 0.6);
            transform: translateY(-2px);
        }

    .cookie-btn-accept {
        background: linear-gradient(135deg, var(--gold-light), var(--gold));
        color: var(--black-pure);
        box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
    }

        .cookie-btn-accept:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4);
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
        }

        .cookie-btn-accept:active {
            transform: translateY(0);
        }

    /* Responsive para tablets y móviles */
    @@media (max-width: 768px) {
        .cookie-banner {
            padding: 16px var(--inner-pad);
        }

        .cookie-banner-content {
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .cookie-banner-title {
            font-size: 16px;
        }

        .cookie-banner-message {
            font-size: 13px;
        }

        .cookie-banner-actions {
            width: 100%;
            flex-direction: column-reverse;
        }

        .cookie-btn-reject,
        .cookie-btn-accept {
            width: 100%;
            padding: 12px 16px;
        }
    }

    @@media (max-width: 480px) {
        .cookie-banner {
            padding: 12px 12px;
        }

        .cookie-banner-content {
            gap: 12px;
        }

        .cookie-banner-title {
            font-size: 15px;
        }

        .cookie-banner-message {
            font-size: 12px;
            line-height: 1.4;
        }

        .cookie-btn-reject,
        .cookie-btn-accept {
            padding: 10px 12px;
            font-size: 12px;
        }
    }
</style>