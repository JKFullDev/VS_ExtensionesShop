@* Componente reutilizable para páginas informativas *@

<div class="info-page">
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">@Title</span>
            </div>
            <h1 class="page-title">@Title</h1>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <p class="page-subtitle">@Subtitle</p>
            }
        </div>
    </div>

    <div class="info-content">
        <div class="section-inner">
            <div class="content-wrapper">
                @ChildContent
            </div>
        </div>
    </div>
</div>

<style>
    .info-content {
        padding: 40px 0 var(--section-gap);
    }

    .content-wrapper {
        max-width: 800px;
        margin: 0 auto;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 48px;
    }

    .content-wrapper h2 {
        font-family: var(--font-display);
        font-size: 28px;
        font-weight: 400;
        color: var(--ink);
        margin: 48px 0 20px;
    }

    .content-wrapper h2:first-child {
        margin-top: 0;
    }

    .content-wrapper h3 {
        font-size: 20px;
        font-weight: 600;
        color: var(--ink);
        margin: 32px 0 16px;
    }

    .content-wrapper p {
        font-size: 15px;
        line-height: 1.8;
        color: var(--ink-light);
        margin-bottom: 20px;
    }

    .content-wrapper ul, .content-wrapper ol {
        margin: 20px 0 20px 24px;
        font-size: 15px;
        line-height: 1.8;
        color: var(--ink-light);
    }

    .content-wrapper li {
        margin-bottom: 12px;
        padding-left: 8px;
    }

    .content-wrapper strong {
        color: var(--ink);
        font-weight: 600;
    }

    .content-wrapper a {
        color: var(--rose);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color .2s;
    }

    .content-wrapper a:hover {
        border-bottom-color: var(--rose);
    }

    .info-box {
        background: var(--rose-pale);
        border-left: 4px solid var(--rose);
        padding: 24px;
        border-radius: 12px;
        margin: 32px 0;
    }

    .info-box p:last-child {
        margin-bottom: 0;
    }

    @@media (max-width: 479px) {
        .info-content {
            padding: 24px 0 32px;
        }

        .content-wrapper {
            padding: 20px;
            border-radius: 12px;
            margin: 0;
        }

        .content-wrapper h2 {
            font-size: 20px;
            margin: 24px 0 16px;
        }

        .content-wrapper h2:first-child {
            margin-top: 0;
        }

        .content-wrapper h3 {
            font-size: 16px;
            margin: 20px 0 12px;
        }

        .content-wrapper p {
            font-size: 14px;
            line-height: 1.7;
        }

        .content-wrapper ul,
        .content-wrapper ol {
            margin: 16px 0 16px 20px;
            font-size: 14px;
        }

        .info-box {
            padding: 16px;
            margin: 20px 0;
        }
    }

    @@media (min-width: 480px) and (max-width: 1023px) {
        .info-content {
            padding: 32px 0 48px;
        }

        .content-wrapper {
            padding: 32px;
            border-radius: 12px;
        }

        .content-wrapper h2 {
            font-size: 24px;
            margin: 32px 0 16px;
        }

        .content-wrapper h3 {
            font-size: 18px;
            margin: 24px 0 12px;
        }

        .info-box {
            padding: 20px;
            margin: 24px 0;
        }
    }

    @@media (min-width: 1024px) {
        .info-content {
            padding: 40px 0 var(--section-gap);
        }

        .content-wrapper {
            padding: 48px;
        }
    }
</style>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
