@using Microsoft.AspNetCore.Components.Routing
@using ExtensionesShop.Client.Services
@inject CartStateService CartState
@inject NavigationManager Navigation
@inject AuthService AuthService
@implements IDisposable

<header class="site-header @(_scrolled ? "scrolled" : "")">
    <div class="header-top-bar">
        ENVÍO GRATIS EN PEDIDOS SUPERIORES A 120€
    </div>

    <div class="header-main">
        <a href="/" class="brand-logo" aria-label="Extensiones Shop - Inicio">
            <h1 class="logo-text">
                Extensiones <span class="logo-highlight">Shop</span>
            </h1>
        </a>

        <nav class="nav-center hidden-mobile" role="navigation" aria-label="Menú principal">
            <NavLink href="/" Match="NavLinkMatch.All" class="nav-link">Inicio</NavLink>
            <NavLink href="/productos" class="nav-link">Productos</NavLink>
            @* <NavLink href="/como-elegir" class="nav-link">Guía</NavLink> *@
            <NavLink href="/contacto" class="nav-link">Contacto</NavLink>
        </nav>

        <div class="header-actions">
            <div class="search-wrapper hidden-mobile">
                <form @onsubmit="HandleSearch" @onsubmit:preventDefault class="search-form">
                    <div class="search-box">
                        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8" />
                            <path d="m21 21-4.35-4.35" />
                        </svg>
                        <input type="search"
                               placeholder="Buscar..."
                               @bind="_searchQuery"
                               @bind:event="oninput"
                               @onkeydown="@(e => { if (e.Key == "Enter") HandleSearch(); })"
                               class="search-input" />
                    </div>
                </form>
            </div>

            <button class="icon-btn hidden-desktop" @onclick="ToggleMobile" aria-label="Buscar móvil">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.35-4.35" />
                </svg>
            </button>

            <button class="icon-btn" @onclick="@(() => Navigation.NavigateTo("/favoritos"))" aria-label="Lista de deseos">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                </svg>
            </button>

            <button class="icon-btn" @onclick="@(() => Navigation.NavigateTo("/cuenta"))" aria-label="Mi cuenta">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </button>

            <!-- Botón Admin - Solo visible para administradores -->
            @if (AuthService.IsAdmin)
            {
                <button class="icon-btn admin-btn" @onclick="@(() => Navigation.NavigateTo("/admin"))" aria-label="Panel de administración" title="Ir al panel admin">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="3" y1="9" x2="21" y2="9"></line>
                        <line x1="9" y1="21" x2="9" y2="9"></line>
                    </svg>
                </button>
            }

            <button class="icon-btn cart-btn" @onclick="IrAlCarrito" aria-label="Ver carrito">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                </svg>
                @if (CartState.CantidadTotal > 0)
                {
                    <span class="cart-badge">@CartState.CantidadTotal</span>
                }
            </button>

            <button class="hamburger hidden-desktop @(_mobileOpen ? "open" : "")" @onclick="ToggleMobile" aria-label="Abrir menú">
                <span></span><span></span><span></span>
            </button>
        </div>
    </div>

    @* <div class="header-categories hidden-mobile">
        <div class="categories-scroll">
            <a href="/productos?categoria=clip-in" class="cat-link">Clip-In</a>
            <a href="/productos?categoria=tape-in" class="cat-link">Tape-In</a>
            <a href="/productos?categoria=queratina" class="cat-link">Queratina</a>
            <a href="/productos?categoria=micro-ring" class="cat-link">Micro Ring</a>
            <a href="/productos?categoria=ponytail" class="cat-link">Ponytail</a>
            <a href="/productos?categoria=flequillo" class="cat-link">Flequillo</a>
            <a href="/productos?categoria=onduladas" class="cat-link">Onduladas</a>
            <a href="/productos?categoria=lisas" class="cat-link">Lisas</a>
            <a href="/productos?categoria=rizadas" class="cat-link">Rizadas</a>
            <a href="/productos?categoria=colores" class="cat-link">Colores Fantasy</a>
        </div>
    </div> *@

    <div class="mobile-drawer @(_mobileOpen ? "open" : "")">
        <form @onsubmit="HandleSearch" @onsubmit:preventDefault>
            <div class="mobile-search">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.35-4.35" />
                </svg>
                <input type="search" placeholder="Buscar..." @bind="_searchQuery" class="search-input" />
            </div>
        </form>
        <nav class="mobile-nav">
            <a href="/" @onclick="CloseMobile" class="mobile-nav-link">Inicio</a>
            <a href="/productos" @onclick="CloseMobile" class="mobile-nav-link">Productos</a>
            @* <a href="/como-elegir" @onclick="CloseMobile" class="mobile-nav-link">Guía</a> *@
            <a href="/contacto" @onclick="CloseMobile" class="mobile-nav-link">Contacto</a>
            <a href="/favoritos" @onclick="CloseMobile" class="mobile-nav-link">Favoritos</a>
            <a href="/cuenta" @onclick="CloseMobile" class="mobile-nav-link">Mi Cuenta</a>
        </nav>
    </div>
</header>



@code {
    private bool _scrolled = false;
    private bool _mobileOpen = false;
    private string _searchQuery = string.Empty;

    protected override void OnInitialized()
    {
        // Suscribirse a cambios en el estado de autenticación
        AuthService.OnAuthStateChanged += StateHasChanged;
        CartState.OnChange += StateHasChanged;
    }

    private void HandleSearch()
    {
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            Navigation.NavigateTo($"/productos?search={Uri.EscapeDataString(_searchQuery.Trim())}");
            _searchQuery = string.Empty;
            _mobileOpen = false;
        }
    }

    private void ToggleMobile() => _mobileOpen = !_mobileOpen;
    private void CloseMobile() => _mobileOpen = false;
    private void IrAlCarrito() => Navigation.NavigateTo("/carrito");

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= StateHasChanged;
        CartState.OnChange -= StateHasChanged;
    }
}