@page "/pedido-confirmado"
@using ExtensionesShop.Client.Services
@inject NavigationManager Navigation

<PageTitle>Pedido Confirmado - Extensiones Shop</PageTitle>

<div class="pedido-confirmado-page">
    <div class="confirmation-container">
        <!-- Icono de Éxito -->
        <div class="success-icon-wrapper">
            <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
        </div>

        <!-- Título y Mensaje Principal -->
        <div class="confirmation-header">
            <h1>¡Pedido Recibido!</h1>
            <p class="subtitle">Tu pedido ha sido confirmado exitosamente</p>
        </div>

        <!-- Contenido Principal -->
        <div class="confirmation-content">
            <div class="message-box">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 16v-4"/>
                    <path d="M12 8h.01"/>
                </svg>
                <div class="message-text">
                    <h3>Nos pondremos en contacto contigo en las próximas horas</h3>
                    <p>Te enviaremos un correo con los detalles del pago y confirmaremos el envío de tu pedido.</p>
                </div>
            </div>

            <!-- Pasos Siguientes -->
            <div class="next-steps-box">
                <h3>Próximos Pasos</h3>
                <div class="steps-list">
                    <div class="step">
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <h4>Confirmación por Email</h4>
                            <p>Recibirás un correo confirmando tu pedido con todos los detalles</p>
                        </div>
                    </div>

                    <div class="step">
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <h4>Contacto para Pago</h4>
                            <p>Nuestro equipo se comunicará contigo para coordinar el método de pago</p>
                        </div>
                    </div>

                    <div class="step">
                        <div class="step-number">3</div>
                        <div class="step-content">
                            <h4>Envío Rápido</h4>
                            <p>Una vez confirmado el pago, enviaremos tu pedido en 24-48 horas</p>
                        </div>
                    </div>

                    <div class="step">
                        <div class="step-number">4</div>
                        <div class="step-content">
                            <h4>Seguimiento</h4>
                            <p>Recibirás tu número de seguimiento para rastrear tu paquete</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Información de Contacto -->
            <div class="contact-info-box">
                <h3>¿Preguntas?</h3>
                <p>Si tienes alguna duda sobre tu pedido, no dudes en ponerte en contacto con nosotros:</p>
                <div class="contact-methods">
                    <div class="contact-method">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        </svg>
                        <div>
                            <h4>Email</h4>
                            <a href="mailto:hola@extensiones.shop">hola@extensiones.shop</a>
                        </div>
                    </div>

                    <div class="contact-method">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                        </svg>
                        <div>
                            <h4>Teléfono</h4>
                            <a href="tel:+34600000000">+34 600 00 00 00</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Botones de Acción -->
        <div class="action-buttons">
            <a href="/" class="btn-primary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Volver al Inicio
            </a>
            <a href="/productos" class="btn-secondary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1"/>
                    <circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                Seguir Comprando
            </a>
        </div>
    </div>
</div>

<style>
    .pedido-confirmado-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #f5f1f3 0%, #faf8fa 100%);
        padding: 60px 20px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .confirmation-container {
        max-width: 700px;
        width: 100%;
        background: white;
        border-radius: 20px;
        padding: 60px 40px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
        text-align: center;
    }

    .success-icon-wrapper {
        margin-bottom: 32px;
    }

    .success-icon-wrapper svg {
        color: #10B981;
        animation: scaleIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(0.8);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .confirmation-header h1 {
        font-family: var(--font-display, serif);
        font-size: 42px;
        font-weight: 400;
        color: var(--ink);
        margin: 0 0 12px 0;
        line-height: 1.2;
    }

    .confirmation-header .subtitle {
        font-size: 18px;
        color: var(--muted);
        margin: 0;
    }

    .confirmation-content {
        text-align: left;
        margin-top: 40px;
    }

    /* Message Box */
    .message-box {
        background: linear-gradient(135deg, #FDF0F3 0%, #FCE8F0 100%);
        border: 2px solid #E8607A;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 32px;
        display: flex;
        gap: 16px;
        align-items: flex-start;
    }

    .message-box svg {
        color: #E8607A;
        flex-shrink: 0;
        margin-top: 4px;
    }

    .message-text h3 {
        margin: 0 0 8px 0;
        color: var(--ink);
        font-size: 16px;
        font-weight: 700;
    }

    .message-text p {
        margin: 0;
        color: var(--ink-light);
        font-size: 14px;
        line-height: 1.6;
    }

    /* Next Steps */
    .next-steps-box {
        margin-bottom: 32px;
    }

    .next-steps-box h3 {
        font-family: var(--font-display, serif);
        font-size: 20px;
        font-weight: 400;
        color: var(--ink);
        margin: 0 0 24px 0;
    }

    .steps-list {
        display: grid;
        gap: 16px;
    }

    .step {
        display: grid;
        grid-template-columns: 50px 1fr;
        gap: 16px;
        align-items: start;
        padding: 16px;
        background: var(--off-white);
        border-radius: 12px;
        border-left: 4px solid var(--rose);
    }

    .step-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 50px;
        height: 50px;
        background: var(--rose);
        color: white;
        border-radius: 50%;
        font-weight: 700;
        font-size: 20px;
        flex-shrink: 0;
    }

    .step-content h4 {
        margin: 0 0 4px 0;
        color: var(--ink);
        font-size: 15px;
        font-weight: 700;
    }

    .step-content p {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
    }

    /* Contact Info */
    .contact-info-box {
        background: var(--off-white);
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 32px;
    }

    .contact-info-box h3 {
        font-family: var(--font-display, serif);
        font-size: 18px;
        font-weight: 400;
        color: var(--ink);
        margin: 0 0 8px 0;
    }

    .contact-info-box > p {
        margin: 0 0 20px 0;
        color: var(--ink-light);
        font-size: 14px;
    }

    .contact-methods {
        display: grid;
        gap: 16px;
    }

    .contact-method {
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .contact-method svg {
        color: var(--rose);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .contact-method h4 {
        margin: 0 0 4px 0;
        color: var(--ink);
        font-size: 14px;
        font-weight: 700;
    }

    .contact-method a {
        color: var(--rose);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
    }

    .contact-method a:hover {
        text-decoration: underline;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .action-buttons a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: var(--rose);
        color: white;
    }

    .btn-primary:hover {
        background: #d94a65;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(232, 96, 122, 0.3);
    }

    .btn-secondary {
        background: white;
        color: var(--rose);
        border: 2px solid var(--rose);
    }

    .btn-secondary:hover {
        background: var(--rose-pale);
        transform: translateY(-2px);
    }

    /* Responsive */
    @@media (max-width: 640px) {
        .pedido-confirmado-page {
            padding: 40px 16px;
        }

        .confirmation-container {
            padding: 40px 24px;
        }

        .confirmation-header h1 {
            font-size: 32px;
        }

        .message-box {
            flex-direction: column;
            text-align: center;
        }

        .message-box svg {
            margin: 0 auto;
        }

        .step {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .step-number {
            margin: 0 auto;
        }

        .action-buttons {
            flex-direction: column;
        }

        .action-buttons a {
            width: 100%;
            justify-content: center;
        }
    }
</style>

@code {
    protected override void OnInitialized()
    {
        // Página de confirmación - no requiere lógica especial
    }
}
