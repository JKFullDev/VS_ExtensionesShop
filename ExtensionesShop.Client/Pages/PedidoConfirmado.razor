@page "/pedido-confirmado"
@using ExtensionesShop.Client.Services
@inject NavigationManager Navigation

<PageTitle>Pedido Confirmado - Extensiones Shop</PageTitle>

<div class="pedido-confirmado-page">
    <div class="confirmation-container">
        <!-- Tarjeta Principal de Confirmación -->
        <div class="confirmation-card">
            <!-- Lado Izquierdo: Mensaje de Éxito -->
            <div class="success-section">
                <div class="success-icon">
                    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                </div>
                
                <div class="success-message">
                    <h1>¡Pedido Recibido!</h1>
                    <p class="message">Tu pedido ha sido confirmado exitosamente</p>
                    <p class="submessage">Nos pondremos en contacto contigo en las próximas horas para coordinar los detalles del pago.</p>
                </div>
            </div>

            <!-- Lado Derecho: Resumen Rápido -->
            <div class="summary-section">
                <div class="quick-summary">
                    <h3>Próximos Pasos</h3>
                    <div class="steps-mini">
                        <div class="step-mini">
                            <span class="step-number">1</span>
                            <span class="step-text">Confirmación por Email</span>
                        </div>
                        <div class="step-mini">
                            <span class="step-number">2</span>
                            <span class="step-text">Contacto para Pago</span>
                        </div>
                        <div class="step-mini">
                            <span class="step-number">3</span>
                            <span class="step-text">Envío en 24-48h</span>
                        </div>
                        <div class="step-mini">
                            <span class="step-number">4</span>
                            <span class="step-text">Seguimiento</span>
                        </div>
                    </div>
                </div>

                <div class="contact-box">
                    <h4>¿Preguntas?</h4>
                    <a href="mailto:hola@extensiones.shop" class="contact-link">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        </svg>
                        hola@extensiones.shop
                    </a>
                </div>
            </div>
        </div>

        <!-- Botones de Acción -->
        <div class="action-buttons">
            <a href="/" class="btn-primary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Volver al Inicio
            </a>
            <a href="/productos" class="btn-secondary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1"/>
                    <circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                Seguir Comprando
            </a>
        </div>
    </div>
</div>

<style>
    .pedido-confirmado-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #f5f1f3 0%, #faf8fa 100%);
        padding: 40px 20px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .confirmation-container {
        max-width: 800px;
        width: 100%;
    }

    /* Tarjeta Principal */
    .confirmation-card {
        background: white;
        border-radius: 16px;
        padding: 48px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.06);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        margin-bottom: 32px;
    }

    /* Lado Izquierdo: Éxito */
    .success-section {
        display: flex;
        flex-direction: column;
        gap: 24px;
        align-items: flex-start;
    }

    .success-icon {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .success-icon svg {
        color: #10B981;
        animation: scaleIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(0.8);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .success-message h1 {
        font-family: var(--font-display, 'Segoe UI', serif);
        font-size: 28px;
        font-weight: 400;
        color: var(--ink, #333);
        margin: 0 0 12px 0;
        line-height: 1.3;
    }

    .success-message .message {
        font-size: 15px;
        color: var(--muted, #666);
        margin: 0 0 12px 0;
        font-weight: 500;
    }

    .success-message .submessage {
        font-size: 13px;
        color: var(--ink-light, #888);
        margin: 0;
        line-height: 1.6;
    }

    /* Lado Derecho: Resumen */
    .summary-section {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .quick-summary h3 {
        font-family: var(--font-display, 'Segoe UI', serif);
        font-size: 16px;
        font-weight: 600;
        color: var(--ink, #333);
        margin: 0 0 16px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .steps-mini {
        display: grid;
        gap: 12px;
    }

    .step-mini {
        display: grid;
        grid-template-columns: 32px 1fr;
        gap: 12px;
        align-items: center;
        padding: 12px;
        background: var(--off-white, #f9f9f9);
        border-radius: 8px;
        border-left: 3px solid var(--rose, #E8607A);
    }

    .step-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        background: linear-gradient(135deg, #E8607A 0%, #d94a65 100%);
        color: white;
        border-radius: 50%;
        font-size: 13px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .step-text {
        font-size: 13px;
        color: var(--ink, #333);
        font-weight: 500;
    }

    .contact-box {
        padding: 16px;
        background: linear-gradient(135deg, #FDF0F3 0%, #FCE8F0 100%);
        border: 1px solid #E8D5E0;
        border-radius: 8px;
    }

    .contact-box h4 {
        font-size: 13px;
        font-weight: 600;
        color: var(--ink, #333);
        margin: 0 0 8px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .contact-link {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--rose, #E8607A);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: opacity 0.2s;
    }

    .contact-link:hover {
        opacity: 0.8;
        text-decoration: underline;
    }

    .contact-link svg {
        color: var(--rose, #E8607A);
    }

    /* Botones de Acción */
    .action-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
    }

    .btn-primary, .btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 14px 28px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }

    .btn-primary {
        background: linear-gradient(135deg, #E8607A 0%, #d94a65 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(232, 96, 122, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(232, 96, 122, 0.4);
    }

    .btn-secondary {
        background: white;
        color: var(--ink, #333);
        border: 2px solid var(--border, #ddd);
    }

    .btn-secondary:hover {
        background: var(--off-white, #f9f9f9);
        border-color: var(--rose, #E8607A);
        color: var(--rose, #E8607A);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .confirmation-card {
            grid-template-columns: 1fr;
            gap: 32px;
            padding: 32px 24px;
        }

        .action-buttons {
            flex-direction: column;
            gap: 12px;
        }

        .btn-primary, .btn-secondary {
            width: 100%;
        }
    }
</style>

