@page "/carrito"
@using ExtensionesShop.Shared.Models
@using ExtensionesShop.Client.Services
@inject CartStateService CartState
@inject NavigationManager Navigation

<div class="carrito-page">
    <!-- Header -->
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Carrito de Compras</span>
            </div>
            <h1 class="page-title">Tu Carrito</h1>
            <p class="page-subtitle">Revisa tus productos antes de finalizar la compra</p>
        </div>
    </div>

    <div class="carrito-section">
        <div class="section-inner">
            @if (!CartState.Items.Any())
            {
                <!-- Carrito vacío -->
                <div class="empty-cart">
                    <div class="empty-icon">🛍️</div>
                    <h2>Tu carrito está vacío</h2>
                    <p>Agrega productos increíbles para comenzar tu transformación</p>
                    <a href="/productos" class="btn-primary">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m15 18-6-6 6-6" />
                        </svg>
                        Ir a Productos
                    </a>
                </div>
            }
            else
            {
                <div class="carrito-layout">
                    <!-- Lista de items -->
                    <div class="carrito-items">
                        <div class="items-header">
                            <h2>Productos (@CartState.CantidadTotal items)</h2>
                            <button class="btn-text" @onclick="VaciarCarrito">
                                Vaciar carrito
                            </button>
                        </div>

                        @foreach (var item in CartState.Items)
                        {
                            <div class="cart-item">
                                <!-- Imagen -->
                                <div class="item-image">
                                    <img src="@item.Producto.ImageUrl" alt="@item.Producto.Name" />
                                </div>

                                <!-- Info -->
                                <div class="item-info">
                                    <h3 class="item-name">@item.Producto.Name</h3>
                                    <p class="item-category">@item.Producto.Category?.Name</p>

                                    @if (!string.IsNullOrEmpty(item.Producto.Color) || item.Producto.Centimeters.HasValue)
                                    {
                                        <div class="item-attributes">
                                            @if (!string.IsNullOrEmpty(item.Producto.Color))
                                            {
                                                <span>Color: @item.Producto.Color</span>
                                            }
                                            @if (item.Producto.Centimeters.HasValue)
                                            {
                                                <span>Largo: @item.Producto.Centimeters cm</span>
                                            }
                                        </div>
                                    }
                                </div>

                                <!-- Precio unitario -->
                                <div class="item-price">
                                    <span class="price-label">Precio</span>
                                    <span class="price-value">$@item.Producto.Price.ToString("N2")</span>
                                </div>

                                <!-- Cantidad -->
                                <div class="item-quantity">
                                    <span class="quantity-label">Cantidad</span>
                                    <div class="quantity-controls">
                                        <button class="qty-btn"
                                                @onclick="() => CartState.DecrementarCantidad(item.Producto.Id)"
                                                aria-label="Disminuir cantidad">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <line x1="5" y1="12" x2="19" y2="12" />
                                            </svg>
                                        </button>
                                        <input type="number"
                                               class="qty-input"
                                               value="@item.Cantidad"
                                               min="1"
                                               @onchange="(e) => ActualizarCantidad(item.Producto.Id, e)" />
                                        <button class="qty-btn"
                                                @onclick="() => CartState.IncrementarCantidad(item.Producto.Id)"
                                                aria-label="Aumentar cantidad">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <line x1="12" y1="5" x2="12" y2="19" />
                                                <line x1="5" y1="12" x2="19" y2="12" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>

                                <!-- Subtotal -->
                                <div class="item-subtotal">
                                    <span class="subtotal-label">Subtotal</span>
                                    <span class="subtotal-value">$@item.Subtotal.ToString("N2")</span>
                                </div>

                                <!-- Eliminar -->
                                <button class="item-remove"
                                        @onclick="() => CartState.EliminarProducto(item.Producto.Id)"
                                        aria-label="Eliminar producto">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>

                    <!-- Resumen -->
                    <div class="carrito-summary">
                        <h3 class="summary-title">Resumen del Pedido</h3>

                        <div class="summary-row">
                            <span>Subtotal (@CartState.CantidadTotal items)</span>
                            <span>$@CartState.Total.ToString("N2")</span>
                        </div>

                        <div class="summary-row">
                            <span>Envío</span>
                            <span class="envio-gratis">GRATIS</span>
                        </div>

                        <div class="summary-divider"></div>

                        <div class="summary-row summary-total">
                            <span>Total</span>
                            <span>$@CartState.Total.ToString("N2")</span>
                        </div>

                        <button class="btn-primary btn-checkout" @onclick="FinalizarCompra">
                            Finalizar Compra
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="m9 18 6-6-6-6" />
                            </svg>
                        </button>

                        <a href="/productos" class="btn-continue">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="m15 18-6-6 6-6" />
                            </svg>
                            Continuar Comprando
                        </a>

                        <!-- Trust badges -->
                        <div class="trust-section">
                            <div class="trust-item">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                </svg>
                                <span>Compra segura SSL</span>
                            </div>
                            <div class="trust-item">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                    <path d="M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
                                </svg>
                                <span>Envío gratis</span>
                            </div>
                            <div class="trust-item">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                    <polyline points="9 22 9 12 15 12 15 22" />
                                </svg>
                                <span>Devolución 30 días</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* ── Empty Cart ────────────────────────────────────────── */
    .empty-cart {
        text-align: center;
        padding: 0px 20px;
    }

    .empty-icon {
        font-size: 80px;
        margin-bottom: 24px;
        opacity: .3;
    }

    .empty-cart h2 {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 300;
        color: var(--ink);
        margin-bottom: 12px;
    }

    .empty-cart p {
        color: var(--muted);
        margin-bottom: 32px;
    }

    /* ── Carrito Section ───────────────────────────────────── */
    .carrito-section {
        padding: 40px 0 var(--section-gap);
    }

    .carrito-layout {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 40px;
        align-items: start;
    }

    /* ── Items List ────────────────────────────────────────── */
    .carrito-items {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 32px;
    }

    .items-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
    }

        .items-header h2 {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 400;
            color: var(--ink);
        }

    .btn-text {
        font-size: 13px;
        font-weight: 500;
        color: var(--muted);
        transition: color .2s;
    }

        .btn-text:hover {
            color: var(--rose);
        }

    /* ── Cart Item ─────────────────────────────────────────── */
    .cart-item {
        display: grid;
        grid-template-columns: 100px 1fr auto auto auto auto;
        gap: 20px;
        align-items: center;
        padding: 24px 0;
        border-bottom: 1px solid var(--border);
    }

        .cart-item:last-child {
            border-bottom: none;
        }

    .item-image {
        width: 100px;
        height: 120px;
        border-radius: 12px;
        overflow: hidden;
        background: var(--off-white);
    }

        .item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .item-info {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .item-name {
        font-size: 16px;
        font-weight: 500;
        color: var(--ink);
        margin: 0;
    }

    .item-category {
        font-size: 12px;
        color: var(--rose);
        text-transform: uppercase;
        letter-spacing: .1em;
        font-weight: 600;
        margin: 0;
    }

    .item-attributes {
        display: flex;
        gap: 12px;
        font-size: 12px;
        color: var(--muted);
        margin-top: 4px;
    }

    .item-price, .item-quantity, .item-subtotal {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .price-label, .quantity-label, .subtotal-label {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .1em;
    }

    .price-value, .subtotal-value {
        font-size: 16px;
        font-weight: 600;
        color: var(--ink);
    }

    /* Quantity controls */
    .quantity-controls {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--off-white);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 4px;
    }

    .qty-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ink);
        transition: background .2s;
    }

        .qty-btn:hover {
            background: var(--rose-pale);
            color: var(--rose);
        }

    .qty-input {
        width: 50px;
        text-align: center;
        border: none;
        background: transparent;
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
    }

        .qty-input::-webkit-outer-spin-button,
        .qty-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

    .item-remove {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: background .2s, color .2s;
    }

        .item-remove:hover {
            background: #FEE2E2;
            color: #DC2626;
        }

    /* ── Summary ───────────────────────────────────────────── */
    .carrito-summary {
        position: sticky;
        top: 100px;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 32px;
    }

    .summary-title {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 400;
        color: var(--ink);
        margin-bottom: 24px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        font-size: 14px;
        color: var(--ink-light);
    }

    .envio-gratis {
        color: #059669;
        font-weight: 600;
        font-size: 12px;
        letter-spacing: .05em;
    }

    .summary-divider {
        height: 1px;
        background: var(--border);
        margin: 16px 0;
    }

    .summary-total {
        font-size: 18px;
        font-weight: 600;
        color: var(--ink);
        padding: 16px 0;
    }

    .btn-checkout {
        width: 100%;
        justify-content: center;
        margin-bottom: 12px;
    }

    .btn-continue {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 12px;
        font-size: 13px;
        font-weight: 500;
        color: var(--ink-light);
        transition: color .2s;
    }

        .btn-continue:hover {
            color: var(--rose);
        }

    /* Trust section */
    .trust-section {
        margin-top: 32px;
        padding-top: 32px;
        border-top: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .trust-item {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 13px;
        color: var(--ink-light);
    }

        .trust-item svg {
            color: var(--rose);
            flex-shrink: 0;
        }

    /* ── Responsive ────────────────────────────────────────── */
    @@media (max-width: 1024px) {
        .carrito-layout {
            grid-template-columns: 1fr;
        }

        .carrito-summary {
            position: static;
        }

        .cart-item {
            grid-template-columns: 80px 1fr;
            gap: 16px;
        }

        .item-price, .item-quantity, .item-subtotal, .item-remove {
            grid-column: 2;
        }
    }
</style>

@code {
    private async Task ActualizarCantidad(int productoId, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int nuevaCantidad))
        {
            await CartState.ActualizarCantidad(productoId, nuevaCantidad);
        }
    }

    private async Task VaciarCarrito()
    {
        if (CartState.Items.Any())
        {
            await CartState.VaciarCarrito();
        }
    }

    private void FinalizarCompra()
    {
        // Aquí implementarías la lógica de checkout
        Navigation.NavigateTo("/checkout");
    }
}
