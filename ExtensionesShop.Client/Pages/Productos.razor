@code {
    private List<Product> productos = new();
    private bool isLoading = true;

    // ✅ NUEVO: Parámetro de búsqueda desde la URL
    [Parameter]
    [SupplyParameterFromQuery]
    public string? search { get; set; }

    // Filtros
    private List<Category> categoriasDisponibles = new();
    private List<int> categoriasFiltradas = new();
    private List<int> subcategoriasFiltradas = new();
    private List<string> coloresDisponibles = new();
    private List<string> coloresFiltrados = new();
    private List<decimal> longitudesDisponibles = new();
    private List<decimal> longitudesFiltradas = new();

    // Filtros de precio
    private bool precioMenor50 = false;
    private bool precio50a100 = false;
    private bool precioMayor100 = false;

    // ✅ NUEVO: Estados de secciones colapsables
    private bool categoriasColapsadas = false;
    private bool coloresColapsadas = false;
    private bool longitudesColapsadas = false;

    // ✅ NUEVO: Control de sidebar en móvil
    private bool filtersOpen = false;

    // Ordenación
    private string ordenActual = "nombre-asc";

    // ✅ NUEVO: Paginación local en el cliente
    private int paginaActual = 1;
    private int productosPorPagina = 24;

    // Estado de productos añadidos al carrito
    private Dictionary<int, bool> productosAñadidos = new();

    private IEnumerable<Product> productosFiltrados => OrdenarProductos(FiltrarProductos());

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            Console.WriteLine("🔵 Iniciando carga de productos...");
            productos = await ProductService.GetProductsAsync();
            Console.WriteLine($"🟢 Productos cargados: {productos.Count}");

            // Inicializar filtros disponibles
            InicializarFiltros();

            if (productos.Any())
            {
                Console.WriteLine($"✅ Primer producto: {productos.First().Name}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"🔴 Error en OnInitializedAsync: {ex.Message}");
            Console.WriteLine($"🔴 Stack trace: {ex.StackTrace}");
        }
        finally
        {
            isLoading = false;
            Console.WriteLine($"⏹️ Loading finalizado. isLoading={isLoading}, productos.Count={productos.Count}");
        }

        // Suscribirse a cambios de favoritos
        FavoritosService.OnChange += StateHasChanged;
    }

    private void InicializarFiltros()
    {
        // Categorías disponibles (con subcategorías cargadas)
        categoriasDisponibles = productos
            .Where(p => p.Category != null)
            .Select(p => p.Category!)
            .DistinctBy(c => c.Id)
            .ToList();

        // Cargar subcategorías de cada categoría
        foreach (var categoria in categoriasDisponibles)
        {
            if (categoria.Subcategories == null)
            {
                categoria.Subcategories = productos
                    .Where(p => p.CategoryId == categoria.Id && p.Subcategory != null)
                    .Select(p => p.Subcategory!)
                    .DistinctBy(s => s.Id)
                    .ToList();
            }
        }

        // ✅ MEJORADO: Colores disponibles incluyendo variantes
        coloresDisponibles = productos
            .Where(p => EsPeloNatural(p))
            .SelectMany(p => 
                // Combinar color del producto base + colores de las variantes
                new List<string>()
                {
                    p.Color
                }.Concat(p.Variants?.Select(v => v.Color) ?? new List<string>())
                 .Where(c => !string.IsNullOrEmpty(c))
            )
            .Distinct()
            .OrderBy(c => c)
            .ToList();

        // ✅ MEJORADO: Longitudes disponibles incluyendo variantes
        longitudesDisponibles = productos
            .Where(p => EsPeloNatural(p))
            .SelectMany(p => 
                // Combinar longitud del producto base + longitudes de las variantes
                new List<decimal?>()
                {
                    p.Centimeters
                }.Concat(p.Variants?.Select(v => v.Centimeters) ?? new List<decimal?>())
                 .Where(l => l.HasValue)
                 .Select(l => l!.Value)
            )
            .Distinct()
            .OrderBy(l => l)
            .ToList();
    }

    private bool EsPeloNatural(Product producto)
    {
        // Verifica si el producto es de una categoría de pelo
        // Categorías válidas de pelo:
        // - Extensiones de pelo natural
        // - Frontal, topper y Pelucas
        // - Extensiones fibra sintética
        // - Coletas y moños postizos
        // - Pelo Crochet
        var categoriasDeAlo = new[] 
        { 
            "Extensiones de pelo natural",
            "Frontal, topper y Pelucas",
            "Extensiones fibra sintética",
            "Coletas y moños postizos",
            "Pelo Crochet"
        };

        return producto.Category?.Name != null && 
               categoriasDeAlo.Any(cat => producto.Category.Name.Equals(cat, StringComparison.OrdinalIgnoreCase));
    }

    private bool MostrarFiltrosPelo()
    {
        // ✅ MEJORADO: Solo mostrar si se seleccionó categoría de pelo O sin filtros
        var categoriasDeAlo = new[] 
        { 
            "Extensiones de pelo natural",
            "Frontal, topper y Pelucas",
            "Extensiones fibra sintética",
            "Coletas y moños postizos",
            "Pelo Crochet"
        };

        // Si no hay filtros, mostrar todo
        if (!categoriasFiltradas.Any() && !subcategoriasFiltradas.Any())
            return true;

        // Si hay categorías filtradas, verificar si alguna es de pelo
        var categoriasSeleccionadas = categoriasDisponibles
            .Where(c => categoriasFiltradas.Contains(c.Id))
            .ToList();

        return categoriasSeleccionadas.Any(c => 
            categoriasDeAlo.Any(catAlo => c.Name.Equals(catAlo, StringComparison.OrdinalIgnoreCase)));
    }

    private IEnumerable<Product> FiltrarProductos()
    {
        var filtrados = productos.AsEnumerable();

        // ✅ NUEVO: Filtro por término de búsqueda
        if (!string.IsNullOrWhiteSpace(search))
        {
            var searchLower = search.ToLowerInvariant();
            filtrados = filtrados.Where(p => 
                (p.Name?.ToLowerInvariant().Contains(searchLower) ?? false) ||
                (p.Description?.ToLowerInvariant().Contains(searchLower) ?? false) ||
                (p.Color?.ToLowerInvariant().Contains(searchLower) ?? false) ||
                (p.Category?.Name.ToLowerInvariant().Contains(searchLower) ?? false)
            );
        }

        // Filtro por categoría
        if (categoriasFiltradas.Any())
        {
            filtrados = filtrados.Where(p => p.Category != null && categoriasFiltradas.Contains(p.Category.Id));
        }

        // Filtro por subcategoría
        if (subcategoriasFiltradas.Any())
        {
            filtrados = filtrados.Where(p => p.Subcategory != null && subcategoriasFiltradas.Contains(p.Subcategory.Id));
        }

        // ✅ MEJORADO: Filtro por color (busca en producto base Y variantes)
        if (coloresFiltrados.Any())
        {
            filtrados = filtrados.Where(p => 
                // Coincide si el producto base tiene el color
                (!string.IsNullOrEmpty(p.Color) && coloresFiltrados.Contains(p.Color)) ||
                // O si al menos una variante tiene el color
                (p.Variants?.Any(v => !string.IsNullOrEmpty(v.Color) && coloresFiltrados.Contains(v.Color)) ?? false)
            );
        }

        // ✅ MEJORADO: Filtro por longitud (busca en producto base Y variantes)
        if (longitudesFiltradas.Any())
        {
            filtrados = filtrados.Where(p => 
                // Coincide si el producto base tiene la longitud
                (p.Centimeters.HasValue && longitudesFiltradas.Contains(p.Centimeters.Value)) ||
                // O si al menos una variante tiene la longitud
                (p.Variants?.Any(v => v.Centimeters.HasValue && longitudesFiltradas.Contains(v.Centimeters.Value)) ?? false)
            );
        }

        // Filtro por precio
        if (precioMenor50 || precio50a100 || precioMayor100)
        {
            filtrados = filtrados.Where(p =>
                (precioMenor50 && p.Price < 50) ||
                (precio50a100 && p.Price >= 50 && p.Price <= 100) ||
                (precioMayor100 && p.Price > 100)
            );
        }

        return filtrados;
    }

    private IEnumerable<Product> OrdenarProductos(IEnumerable<Product> productos)
    {
        return ordenActual switch
        {
            "nombre-asc" => productos.OrderBy(p => p.Name),
            "nombre-desc" => productos.OrderByDescending(p => p.Name),
            "precio-asc" => productos.OrderBy(p => p.Price),
            "precio-desc" => productos.OrderByDescending(p => p.Price),
            "nuevo" => productos.OrderByDescending(p => p.Id), // Asume que ID mayor = más nuevo
            _ => productos.OrderBy(p => p.Name)
        };
    }

    private void CambiarOrden(ChangeEventArgs e)
    {
        ordenActual = e.Value?.ToString() ?? "nombre-asc";
        paginaActual = 1;  // ✅ Resetear a primera página cuando cambia el orden
    }

    private void ToggleCategoria(int categoriaId)
    {
        if (categoriasFiltradas.Contains(categoriaId))
            categoriasFiltradas.Remove(categoriaId);
        else
            categoriasFiltradas.Add(categoriaId);
        paginaActual = 1;  // ✅ Resetear a primera página
    }

    private void ToggleSubcategoria(int subcategoriaId)
    {
        if (subcategoriasFiltradas.Contains(subcategoriaId))
            subcategoriasFiltradas.Remove(subcategoriaId);
        else
            subcategoriasFiltradas.Add(subcategoriaId);
        paginaActual = 1;  // ✅ Resetear a primera página
    }

    private void ToggleColor(string color)
    {
        if (coloresFiltrados.Contains(color))
            coloresFiltrados.Remove(color);
        else
            coloresFiltrados.Add(color);
        paginaActual = 1;  // ✅ Resetear a primera página
    }

    private void ToggleLongitud(decimal longitud)
    {
        if (longitudesFiltradas.Contains(longitud))
            longitudesFiltradas.Remove(longitud);
        else
            longitudesFiltradas.Add(longitud);
        paginaActual = 1;  // ✅ Resetear a primera página
    }

    private void TogglePrecioMenor50()
    {
        precioMenor50 = !precioMenor50;
        paginaActual = 1;  // ✅ Resetear a primera página
    }

    private void TogglePrecio50a100()
    {
        precio50a100 = !precio50a100;
        paginaActual = 1;  // ✅ Resetear a primera página
    }

    private void TogglePrecioMayor100()
    {
        precioMayor100 = !precioMayor100;
        paginaActual = 1;  // ✅ Resetear a primera página
    }

    private bool HasActiveFilters()
    {
        return categoriasFiltradas.Any() || subcategoriasFiltradas.Any() || 
               coloresFiltrados.Any() || longitudesFiltradas.Any() || 
               precioMenor50 || precio50a100 || precioMayor100;
    }

    private void LimpiarFiltros()
    {
        categoriasFiltradas.Clear();
        subcategoriasFiltradas.Clear();
        coloresFiltrados.Clear();
        longitudesFiltradas.Clear();
        precioMenor50 = false;
        precio50a100 = false;
        precioMayor100 = false;
        paginaActual = 1;  // ✅ Resetear a primera página
    }

    private async Task ToggleFavorito(Product producto)
    {
        if (!AuthService.IsAuthenticated)
        {
            // Redirigir a cuenta para que inicie sesión
            Navigation.NavigateTo("/cuenta");
            return;
        }

        await FavoritosService.ToggleFavoritoAsync(producto);
    }

    private void IrAlDetalle(Product producto)
    {
        Navigation.NavigateTo($"/producto/{producto.Id}");
    }

    private async Task AgregarAlCarrito(Product producto)
    {
        try
        {
            await CartState.AgregarProducto(producto);

            // Establecer estado visual temporal SOLO si fue exitoso
            productosAñadidos[producto.Id] = true;
            StateHasChanged();

            // Resetear después de 2 segundos
            await Task.Delay(2000);
            productosAñadidos[producto.Id] = false;
            StateHasChanged();

            Console.WriteLine($"✅ Producto {producto.Name} añadido al carrito");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error al añadir {producto.Name}: {ex.Message}");
            // El error será manejado por CartStateService (notificación al usuario)
        }
    }

    /// <summary>
    /// ✅ NUEVO: Ir a página anterior
    /// </summary>
    private void PaginaAnterior()
    {
        if (paginaActual > 1)
        {
            paginaActual--;
            StateHasChanged();
        }
    }

    /// <summary>
    /// ✅ NUEVO: Ir a página siguiente
    /// </summary>
    private void PaginaSiguiente()
    {
        var totalPaginas = (int)Math.Ceiling((double)productosFiltrados.Count() / productosPorPagina);
        if (paginaActual < totalPaginas)
        {
            paginaActual++;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        FavoritosService.OnChange -= StateHasChanged;
    }
}