@page "/productos"
@using ExtensionesShop.Shared.Models
@using ExtensionesShop.Client.Services
@using Microsoft.AspNetCore.Components
@inject ProductService ProductService
@inject CartStateService CartState
@inject FavoritosService FavoritosService
@inject AuthService AuthService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Catálogo - Extensiones Shop</PageTitle>

<div class="productos-page">
    <!-- Header -->
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Catálogo</span>
            </div>
            <h1 class="page-title">Nuestro Catálogo</h1>
            <p class="page-subtitle">Descubre extensiones de cabello premium 100% Remy. Calidad profesional garantizada.</p>
        </div>
    </div>

    <!-- Productos Section -->
    <div class="productos-section">
        <div class="section-inner" >
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner">✦</div>
                    <p>Cargando productos...</p>
                </div>
            }
            else if (!productos.Any())
            {
                <div class="empty-state">
                    <p>No se encontraron productos</p>
                </div>
            }
            else
            {
                <div class="productos-layout">
                    <!-- Botón Toggle Filtros Mobile/Tablet -->
                    <button class="filter-toggle-btn @(filtersOpen ? "active" : "")" 
                            @onclick="@(() => filtersOpen = !filtersOpen)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="21" y1="4" x2="14" y2="4"></line>
                            <line x1="10" y1="4" x2="3" y2="4"></line>
                            <line x1="21" y1="12" x2="12" y2="12"></line>
                            <line x1="8" y1="12" x2="3" y2="12"></line>
                            <line x1="21" y1="20" x2="16" y2="20"></line>
                            <line x1="12" y1="20" x2="3" y2="20"></line>
                            <line x1="14" y1="1" x2="14" y2="7"></line>
                            <line x1="8" y1="9" x2="8" y2="15"></line>
                            <line x1="16" y1="17" x2="16" y2="23"></line>
                        </svg>
                        @(filtersOpen ? "Ocultar Filtros" : "Mostrar Filtros")
                    </button>

                    <!-- Backdrop para cerrar filtros en móvil -->
                    @if (filtersOpen)
                    {
                        <div class="filters-backdrop" @onclick="@(() => filtersOpen = false)"></div>
                    }

                    <!-- Sidebar de Filtros -->
                    <aside class="lovable-sidebar @(filtersOpen ? "open" : "")">
                        <div class="sidebar-header">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-primary">
                                    <line x1="21" y1="4" x2="14" y2="4"></line>
                                    <line x1="10" y1="4" x2="3" y2="4"></line>
                                    <line x1="21" y1="12" x2="12" y2="12"></line>
                                    <line x1="8" y1="12" x2="3" y2="12"></line>
                                    <line x1="21" y1="20" x2="16" y2="20"></line>
                                    <line x1="12" y1="20" x2="3" y2="20"></line>
                                    <line x1="14" y1="1" x2="14" y2="7"></line>
                                    <line x1="8" y1="9" x2="8" y2="15"></line>
                                    <line x1="16" y1="17" x2="16" y2="23"></line>
                                </svg>
                                <h2 class="sidebar-title">Filtros</h2>
                            </div>
                            <button class="close-filters-btn" @onclick="@(() => filtersOpen = false)" aria-label="Cerrar filtros">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                </svg>
                            </button>
                        </div>

    @if (categoriasDisponibles.Any())
    {
        <div class="filter-section">
            <button class="filter-title-btn" @onclick="() => categoriasColapsadas = !categoriasColapsadas">
                <span>Categoría</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="collapse-icon @(categoriasColapsadas ? "" : "expanded")">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>
            @if (!categoriasColapsadas)
            {
                <div class="filter-options">
                    @foreach (var cat in categoriasDisponibles)
                    {
                        var productosCat = FiltrarProductos().Where(p => p.Category?.Id == cat.Id).Count();
                        <label class="filter-label">
                            <input type="checkbox"
                                   checked="@categoriasFiltradas.Contains(cat.Id)"
                                   @onchange="() => ToggleCategoria(cat.Id)" />
                            <span class="filter-label-text">@cat.Name</span>
                            <span class="filter-count">@productosCat</span>
                        </label>

                        @if (cat.Subcategories != null && cat.Subcategories.Any())
                        {
                            <div class="filter-options" style="margin-left: 20px; margin-top: 4px; margin-bottom: 8px;">
                                @foreach (var subcat in cat.Subcategories)
                                {
                                    var productosSubcat = FiltrarProductos().Where(p => p.Subcategory?.Id == subcat.Id).Count();
                                    <label class="filter-label" style="font-size: 13px; color: var(--muted);">
                                        <input type="checkbox"
                                               checked="@subcategoriasFiltradas.Contains(subcat.Id)"
                                               @onchange="() => ToggleSubcategoria(subcat.Id)" />
                                        <span class="filter-label-text">@subcat.Name</span>
                                        <span class="filter-count">@productosSubcat</span>
                                    </label>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </div>
    }

    <div class="filter-section">
        <h3 class="filter-title">Precio</h3>
        <div class="filter-options">
            <label class="filter-label">
                <input type="checkbox" checked="@precioMenor50" @onchange="() => TogglePrecioMenor50()" />
                Menos de 50€
            </label>
            <label class="filter-label">
                <input type="checkbox" checked="@precio50a100" @onchange="() => TogglePrecio50a100()" />
                50€ - 100€
            </label>
            <label class="filter-label">
                <input type="checkbox" checked="@precioMayor100" @onchange="() => TogglePrecioMayor100()" />
                Más de 100€
            </label>
        </div>
    </div>

    @if (MostrarFiltrosPelo() && coloresDisponibles.Any())
    {
        <div class="filter-section">
            <button class="filter-title-btn" @onclick="() => coloresColapsadas = !coloresColapsadas">
                <span>Color</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="collapse-icon @(coloresColapsadas ? "" : "expanded")">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>
            @if (!coloresColapsadas)
            {
                <div class="filter-options color-options">
                    @foreach (var color in coloresDisponibles)
                    {
                        var productosColor = FiltrarProductos()
                            .Where(p => 
                                (!string.IsNullOrEmpty(p.Color) && p.Color == color) ||
                                (p.Variants?.Any(v => !string.IsNullOrEmpty(v.Color) && v.Color == color) ?? false)
                            ).Count();
                        <label class="filter-label color-pill">
                            <input type="checkbox"
                                   checked="@coloresFiltrados.Contains(color)"
                                   @onchange="() => ToggleColor(color)" />
                            <span class="pill-text">@color</span>
                            <span class="pill-count">@productosColor</span>
                        </label>
                    }
                </div>
            }
        </div>
    }

    @if (MostrarFiltrosPelo() && longitudesDisponibles.Any())
    {
        <div class="filter-section">
            <button class="filter-title-btn" @onclick="() => longitudesColapsadas = !longitudesColapsadas">
                <span>Longitud (cm)</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="collapse-icon @(longitudesColapsadas ? "" : "expanded")">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>
            @if (!longitudesColapsadas)
            {
                <div class="filter-options">
                    @foreach (var longitud in longitudesDisponibles.OrderBy(l => l))
                    {
                        var productosLong = FiltrarProductos()
                            .Where(p => 
                                (p.Centimeters.HasValue && p.Centimeters.Value == longitud) ||
                                (p.Variants?.Any(v => v.Centimeters.HasValue && v.Centimeters.Value == longitud) ?? false)
                            ).Count();
                        <label class="filter-label">
                            <input type="checkbox"
                                   checked="@longitudesFiltradas.Contains(longitud)"
                                   @onchange="() => ToggleLongitud(longitud)" />
                            <span class="filter-label-text">@longitud cm</span>
                            <span class="filter-count">@productosLong</span>
                        </label>
                    }
                </div>
            }
        </div>
    }

    <div class="sidebar-actions">
        <button class="btn-cta-full">Aplicar Filtros</button>
        
        @if (HasActiveFilters())
        {
            <button class="btn-ghost-full" @onclick="LimpiarFiltros">Limpiar Todo</button>
        }
    </div>
</aside>
                    <!-- Grid de Productos -->
                    <div class="productos-container">
                        <div class="productos-header">
                            <p class="resultados-count">
                                @productosFiltrados.Count() resultado@(productosFiltrados.Count() == 1 ? "" : "s")
                            </p>

                            <!-- Ordenar Por -->
                            <div class="ordenar-section">
                                <label for="ordenar">Ordenar por:</label>
                                <select id="ordenar" class="ordenar-select" @onchange="CambiarOrden">
                                    <option value="nombre-asc">Nombre (A-Z)</option>
                                    <option value="nombre-desc">Nombre (Z-A)</option>
                                    <option value="precio-asc">Precio (Menor a Mayor)</option>
                                    <option value="precio-desc">Precio (Mayor a Menor)</option>
                                    <option value="nuevo">Más Recientes</option>
                                </select>
                            </div>
                        </div>

                        <!-- ✅ NUEVO: Sección de Filtros Activos -->
                        @if (HasActiveFilters())
                        {
                            <div class="filtros-activos">
                                <div class="filtros-activos-container">
                                    <!-- Filtros de Categorías -->
                                    @foreach (var catId in categoriasFiltradas)
                                    {
                                        var categoria = categoriasDisponibles.FirstOrDefault(c => c.Id == catId);
                                        @if (categoria != null)
                                        {
                                            <span class="chip-filtro">
                                                <span class="chip-label">@categoria.Name</span>
                                                <button class="chip-close" @onclick="() => ToggleCategoria(catId)" title="Eliminar filtro">✕</button>
                                            </span>
                                        }
                                    }

                                    <!-- Filtros de Subcategorías -->
                                    @foreach (var subcatId in subcategoriasFiltradas)
                                    {
                                        var subcat = categoriasDisponibles
                                            .SelectMany(c => c.Subcategories ?? new List<Subcategory>())
                                            .FirstOrDefault(s => s.Id == subcatId);
                                        @if (subcat != null)
                                        {
                                            <span class="chip-filtro">
                                                <span class="chip-label">@subcat.Name</span>
                                                <button class="chip-close" @onclick="() => ToggleSubcategoria(subcatId)" title="Eliminar filtro">✕</button>
                                            </span>
                                        }
                                    }

                                    <!-- Filtros de Colores -->
                                    @foreach (var color in coloresFiltrados)
                                    {
                                        <span class="chip-filtro color">
                                            <span class="chip-label">@color</span>
                                            <button class="chip-close" @onclick="() => ToggleColor(color)" title="Eliminar filtro">✕</button>
                                        </span>
                                    }

                                    <!-- Filtros de Longitud -->
                                    @foreach (var longitud in longitudesFiltradas.OrderBy(l => l))
                                    {
                                        <span class="chip-filtro">
                                            <span class="chip-label">@longitud cm</span>
                                            <button class="chip-close" @onclick="() => ToggleLongitud(longitud)" title="Eliminar filtro">✕</button>
                                        </span>
                                    }

                                    <!-- Filtros de Precio -->
                                    @if (precioMenor50)
                                    {
                                        <span class="chip-filtro">
                                            <span class="chip-label">Menos de $50</span>
                                            <button class="chip-close" @onclick="TogglePrecioMenor50" title="Eliminar filtro">✕</button>
                                        </span>
                                    }
                                    @if (precio50a100)
                                    {
                                        <span class="chip-filtro">
                                            <span class="chip-label">$50 - $100</span>
                                            <button class="chip-close" @onclick="TogglePrecio50a100" title="Eliminar filtro">✕</button>
                                        </span>
                                    }
                                    @if (precioMayor100)
                                    {
                                        <span class="chip-filtro">
                                            <span class="chip-label">Más de $100</span>
                                            <button class="chip-close" @onclick="TogglePrecioMayor100" title="Eliminar filtro">✕</button>
                                        </span>
                                    }
                                </div>
                                <button class="btn-limpiar-filtros" @onclick="LimpiarFiltros">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M3 6h18M8 6v12a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V6m-4 0V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                                    </svg>
                                    Limpiar todos
                                </button>
                            </div>
                        }

                        <div class="productos-grid">
                         @foreach (var producto in productosFiltrados.Skip((paginaActual - 1) * productosPorPagina).Take(productosPorPagina))
{
    <div class="lovable-product-card">
        <div class="product-visual">
            <a href="/producto/@producto.Id" class="product-image-link">
                <img src="@producto.ImageUrl" alt="@producto.Name" loading="lazy" class="product-img" />
                <div class="product-overlay"></div>
            </a>



            <div class="quick-actions">
                <button class="btn-icon-round @(FavoritosService.IsFavorito(producto.Id) ? "active" : "")"
                        @onclick="() => ToggleFavorito(producto)"
                        @onclick:stopPropagation="true"
                        title="@(FavoritosService.IsFavorito(producto.Id) ? "Quitar" : "Añadir")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="@(FavoritosService.IsFavorito(producto.Id) ? "currentColor" : "none")" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                </button>
            </div>

            <div class="cart-action">
                @if (producto.Variants != null && producto.Variants.Any())
                {
                    <!-- Producto con variantes: Botón "Ver opciones" -->
                    <button class="btn-cta-hover"
                            @onclick="() => IrAlDetalle(producto)"
                            @onclick:stopPropagation="true">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <text>Ver opciones</text>
                    </button>
                }
                else
                {
                    <!-- Producto simple: Botón "Añadir al carrito" -->
                    <button class="btn-cta-hover"
                            disabled="@(producto.Stock == 0)"
                            @onclick="() => AgregarAlCarrito(producto)"
                            @onclick:stopPropagation="true">
                        @if (productosAñadidos.ContainsKey(producto.Id) && productosAñadidos[producto.Id])
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                            <text>¡Añadido!</text>
                        }
                        else if (producto.Stock >= 0 || producto.Stock <= 0)
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
                                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                <line x1="3" y1="6" x2="21" y2="6" />
                                <path d="M16 10a4 4 0 0 1-8 0" />
                            </svg>
                            <text>Añadir al Carrito</text>
                        }
                    </button>
                }
            </div>
        </div>

        <a href="/producto/@producto.Id" class="product-info-link">
            <h3 class="product-name">@producto.Name</h3>
            
            <div class="product-attributes">
                <span class="attr-text" style="color: var(--rose); font-weight: 600;">@producto.Category?.Name</span>
                @if (producto.Centimeters.HasValue)
                {
                    <span class="attr-dot">•</span>
                    <span class="attr-text">@producto.Centimeters cm</span>
                }
                @if (!string.IsNullOrEmpty(producto.Color))
                {
                    <span class="attr-dot">•</span>
                    <span class="attr-text">@producto.Color</span>
                }
            </div>

            <div class="product-pricing">
                @if (producto.Variants != null && producto.Variants.Any())
                {
                    <span class="price-label">Desde</span>
                }
                <span class="price-current">€@producto.PrecioMinimo.ToString("N2")</span>
            </div>
        </a>
    </div>
}</div>

                        <!-- ✅ NUEVO: Controles de Paginación (DENTRO de productos-container) -->
                        @if (productosFiltrados.Any())
                        {
                            <div class="pagination-controls">
                                <button class="btn-pagination" 
                                        @onclick="() => PaginaAnterior()" 
                                        disabled="@(paginaActual <= 1)">
                                    ← Anterior
                                </button>

                                <div class="pagination-info">
                                    Página @paginaActual de @((int)Math.Ceiling((double)productosFiltrados.Count() / productosPorPagina))
                                    <span class="pagination-results">(@productosFiltrados.Count() productos encontrados)</span>
                                </div>

                                <button class="btn-pagination" 
                                        @onclick="() => PaginaSiguiente()" 
                                        disabled="@(paginaActual >= Math.Ceiling((double)productosFiltrados.Count() / productosPorPagina))">
                                    Siguiente →
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* ── Loading State ──────────────────────────────────────── */
    .loading-state {
        text-align: center;
        padding: 80px 20px;
    }

    .spinner {
        font-size: 48px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .loading-state p {
        margin-top: 20px;
        color: var(--muted);
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: var(--muted);
    }

    /* ── Layout con Filtros ────────────────────────────────── */
    .productos-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 40px;
        align-items: start;
        margin-bottom: 60px;
    }


    /* ── Contenedor de Productos ────────────────────────────── */
    .productos-container {
        min-height: 400px;
    }

    .productos-header {
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
    }

    .resultados-count {
        font-size: 14px;
        color: var(--muted);
    }

    /* ── Filtros Activos (Chips) ────────────────────────────── */
    .filtros-activos {
        margin: 24px 0 32px 0;
        padding: 16px;
        background: var(--off-white);
        border-radius: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .filtros-activos-container {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        flex: 1;
    }

    .chip-filtro {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        color: var(--ink);
        animation: slideIn 0.2s ease-out;
    }

    .chip-filtro.color {
        background: rgba(212, 70, 112, 0.08);
        border-color: rgba(212, 70, 112, 0.2);
        color: var(--rose);
    }

    .chip-label {
        white-space: nowrap;
    }

    .chip-close {
        background: transparent;
        border: none;
        color: inherit;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        transition: background-color 0.2s;
    }

    .chip-close:hover {
        background: rgba(0, 0, 0, 0.08);
    }

    .btn-limpiar-filtros {
        padding: 8px 14px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--muted);
        cursor: pointer;
        font-size: 13px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .btn-limpiar-filtros:hover {
        border-color: var(--rose);
        color: var(--rose);
        background: rgba(232, 96, 122, 0.05);
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: scale(0.9);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* ── Sidebar Mejorado ─────────────────────────────────── */
    .lovable-sidebar {
        position: sticky;
        top: 120px;
        padding: 24px;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 2px solid var(--border);
    }

    .sidebar-title {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
        color: var(--ink);
    }

    .filter-section {
        margin-bottom: 24px;
        border-bottom: 1px solid var(--off-white);
        padding-bottom: 16px;
    }

    .filter-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    /* Botón de Título Colapsable */
    .filter-title-btn {
        background: none;
        border: none;
        width: 100%;
        padding: 0;
        margin-bottom: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 14px;
        font-weight: 600;
