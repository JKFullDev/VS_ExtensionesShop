@page "/restablecer-password"
@using System.ComponentModel.DataAnnotations
@using ExtensionesShop.Client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Restablecer Contraseña - Extensiones Shop</PageTitle>

<div class="restablecer-page">
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Restablecer Contraseña</span>
            </div>
            <h1 class="page-title">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"/>
                    <path d="M9 10V6a3 3 0 116 0v4"/>
                </svg>
                Crear Nueva Contraseña
            </h1>
            <p class="page-subtitle">Introduce tu nueva contraseña</p>
        </div>
    </div>

    <div class="restablecer-content">
        <div class="section-inner">
            <div class="restablecer-card">
                @if (passwordRestablecida)
                {
                    <div class="success-message">
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                            <polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                        <h2>¡Contraseña Actualizada!</h2>
                        <p>Tu contraseña ha sido restablecida exitosamente.</p>
                        <p>Ya puedes iniciar sesión con tu nueva contraseña.</p>
                        <a href="/cuenta" class="btn-primary">Iniciar Sesión</a>
                    </div>
                }
                else if (string.IsNullOrEmpty(token))
                {
                    <div class="error-state">
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <h2>Link Inválido</h2>
                        <p>Este link de recuperación no es válido o ha expirado.</p>
                        <a href="/recuperar-password" class="btn-primary">Solicitar Nuevo Link</a>
                    </div>
                }
                else
                {
                    <EditForm Model="@restablecerForm" OnValidSubmit="EnviarRestablecimiento">
                        <DataAnnotationsValidator />

                        <div class="form-intro">
                            <p>Introduce tu nueva contraseña. Debe tener al menos 8 caracteres.</p>
                        </div>

                        <div class="form-group">
                            <label for="password">Nueva Contraseña</label>
                            <InputText id="password" type="password" @bind-Value="restablecerForm.NewPassword" class="form-control" placeholder="Mínimo 8 caracteres" />
                            <ValidationMessage For="@(() => restablecerForm.NewPassword)" />
                        </div>

                        <div class="form-group">
                            <label for="confirmPassword">Confirmar Contraseña</label>
                            <InputText id="confirmPassword" type="password" @bind-Value="restablecerForm.ConfirmPassword" class="form-control" placeholder="Repite tu contraseña" />
                            <ValidationMessage For="@(() => restablecerForm.ConfirmPassword)" />
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-error">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="12" y1="8" x2="12" y2="12"/>
                                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                                </svg>
                                @errorMessage
                            </div>
                        }

                        <button type="submit" class="btn-primary btn-submit" disabled="@procesando">
                            @if (procesando)
                            {
                                <span class="spinner-sm">✦</span>
                                <text>Actualizando...</text>
                            }
                            else
                            {
                                <text>Restablecer Contraseña</text>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M5 12h14M12 5l7 7-7 7"/>
                                </svg>
                            }
                        </button>
                    </EditForm>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .restablecer-content {
        padding: 40px 0 var(--section-gap);
    }

    .restablecer-content .section-inner {
        max-width: 600px;
    }

    .restablecer-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 48px;
    }

    .form-intro {
        margin-bottom: 32px;
        padding: 20px;
        background: var(--rose-pale);
        border-radius: 12px;
    }

    .form-intro p {
        font-size: 14px;
        color: var(--ink-light);
        margin: 0;
        line-height: 1.6;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid var(--border);
        border-radius: 10px;
        font-size: 14px;
        transition: border-color .2s, box-shadow .2s;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--rose);
        box-shadow: 0 0 0 3px rgba(232, 96, 122, .1);
    }

    .alert {
        padding: 16px;
        border-radius: 12px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 14px;
    }

    .alert-error {
        background: #FEE2E2;
        color: #DC2626;
        border: 1px solid #FECACA;
    }

    .alert svg {
        flex-shrink: 0;
    }

    .btn-submit {
        width: 100%;
        justify-content: center;
    }

    .success-message, .error-state {
        text-align: center;
        padding: 40px 20px;
    }

    .success-message svg {
        color: #10B981;
        margin: 0 auto 24px;
    }

    .error-state svg {
        color: #DC2626;
        margin: 0 auto 24px;
    }

    .success-message h2, .error-state h2 {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 400;
        color: var(--ink);
        margin-bottom: 16px;
    }

    .success-message p, .error-state p {
        color: var(--ink-light);
        margin-bottom: 12px;
        line-height: 1.6;
    }

    .success-message .btn-primary, .error-state .btn-primary {
        margin-top: 24px;
    }

    .spinner-sm {
        display: inline-block;
        animation: spin 1s linear infinite;
    }
</style>

@code {
    private RestablecerFormModel restablecerForm = new();
    private bool procesando = false;
    private bool passwordRestablecida = false;
    private string errorMessage = string.Empty;
    private string? token;

    protected override void OnInitialized()
    {
        // Obtener el token de la URL
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);

        if (uri.Query.Contains("token="))
        {
            var query = uri.Query.Substring(1); // Remover el '?'
            var pairs = query.Split('&');
            foreach (var pair in pairs)
            {
                var parts = pair.Split('=');
                if (parts.Length == 2 && parts[0] == "token")
                {
                    token = Uri.UnescapeDataString(parts[1]);
                    break;
                }
            }
        }
    }

    private async Task EnviarRestablecimiento()
    {
        if (restablecerForm.NewPassword != restablecerForm.ConfirmPassword)
        {
            errorMessage = "Las contraseñas no coinciden";
            return;
        }

        if (string.IsNullOrEmpty(token))
        {
            errorMessage = "Token inválido";
            return;
        }

        procesando = true;
        errorMessage = string.Empty;

        try
        {
            var result = await AuthService.ResetPasswordAsync(token, restablecerForm.NewPassword);

            if (result.Success)
            {
                passwordRestablecida = true;
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Error al restablecer la contraseña. El link puede haber expirado.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error al procesar la solicitud. Por favor, inténtalo de nuevo.";
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            procesando = false;
        }
    }

    public class RestablecerFormModel
    {
        [Required(ErrorMessage = "La contraseña es obligatoria")]
        [MinLength(8, ErrorMessage = "La contraseña debe tener al menos 8 caracteres")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Debes confirmar la contraseña")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
