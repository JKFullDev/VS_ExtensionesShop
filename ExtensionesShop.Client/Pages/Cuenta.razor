@page "/cuenta"

<PageTitle>Mi Cuenta - Extensiones Shop</PageTitle>

<div class="cuenta-page">
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Mi Cuenta</span>
            </div>
            <h1 class="page-title">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                Mi Cuenta
            </h1>
            <p class="page-subtitle">Gestiona tu perfil y pedidos</p>
        </div>
    </div>

    <div class="cuenta-content">
        <div class="section-inner">
            <div class="login-prompt">
                <div class="login-card">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                    <h2>Inicia Sesión</h2>
                    <p>Accede a tu cuenta para ver tus pedidos, favoritos y más</p>
                    
                    <div class="login-actions">
                        <button class="btn-primary btn-google">
                            <svg width="18" height="18" viewBox="0 0 24 24">
                                <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                                <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                            </svg>
                            Continuar con Google
                        </button>

                        <div class="divider">
                            <span>o</span>
                        </div>

                        <button class="btn-ghost btn-email">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                            Continuar con Email
                        </button>
                    </div>

                    <p class="register-link">
                        ¿No tienes cuenta? <a href="/registro" class="link-primary">Regístrate gratis</a>
                    </p>
                </div>

                <div class="benefits-sidebar">
                    <h3>Beneficios de Tener Cuenta</h3>
                    <ul class="benefits-list">
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Seguimiento de pedidos en tiempo real</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Guarda tus productos favoritos</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Checkout más rápido</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Ofertas y descuentos exclusivos</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Historial de compras</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cuenta-content {
        padding: 64px 0 var(--section-gap);
    }

    .login-prompt {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 60px;
        align-items: start;
    }

    .login-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 48px;
        text-align: center;
    }

    .login-card svg {
        color: var(--rose);
        margin-bottom: 24px;
    }

    .login-card h2 {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 400;
        margin-bottom: 12px;
    }

    .login-card > p {
        color: var(--muted);
        margin-bottom: 40px;
    }

    .login-actions {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .btn-google {
        background: white;
        color: var(--ink);
        border: 1px solid var(--border);
        justify-content: center;
    }

    .btn-google:hover {
        background: var(--off-white);
        box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    .btn-email {
        justify-content: center;
    }

    .divider {
        position: relative;
        text-align: center;
        margin: 8px 0;
    }

    .divider::before,
    .divider::after {
        content: '';
        position: absolute;
        top: 50%;
        width: 45%;
        height: 1px;
        background: var(--border);
    }

    .divider::before { left: 0; }
    .divider::after { right: 0; }

    .divider span {
        background: var(--white);
        padding: 0 12px;
        font-size: 13px;
        color: var(--muted);
    }

    .register-link {
        margin-top: 32px;
        font-size: 14px;
        color: var(--ink-light);
    }

    .link-primary {
        color: var(--rose);
        font-weight: 600;
        text-decoration: none;
    }

    .link-primary:hover {
        text-decoration: underline;
    }

    .benefits-sidebar h3 {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 400;
        margin-bottom: 24px;
    }

    .benefits-list {
        list-style: none;
    }

    .benefits-list li {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
    }

    .benefits-list li:last-child {
        border-bottom: none;
    }

    .benefits-list svg {
        color: var(--rose);
        flex-shrink: 0;
        margin-top: 2px;
    }

    @@media (max-width: 968px) {
        .login-prompt {
            grid-template-columns: 1fr;
        }
    }
</style>
