@page "/cuenta"
@using System.ComponentModel.DataAnnotations
@using ExtensionesShop.Client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Mi Cuenta - Extensiones Shop</PageTitle>

<div class="cuenta-page">
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Mi Cuenta</span>
            </div>
            <h1 class="page-title">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                Mi Cuenta
            </h1>
            <p class="page-subtitle">Gestiona tu perfil y pedidos</p>
        </div>
    </div>

    <div class="cuenta-content">
        <div class="section-inner">
            <div class="login-prompt">
                <div class="login-card">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                    <h2>Inicia Sesión</h2>
                    <p>Accede a tu cuenta para ver tus pedidos, favoritos y más</p>
                    
                    <div class="login-actions">
                        <EditForm Model="@loginForm" OnValidSubmit="IniciarSesion">
                            <DataAnnotationsValidator />

                            <div class="form-group">
                                <label for="email">Email</label>
                                <InputText id="email" type="email" @bind-Value="loginForm.Email" class="form-control" placeholder="tu@email.com" />
                                <ValidationMessage For="@(() => loginForm.Email)" />
                            </div>

                            <div class="form-group">
                                <label for="password">Contraseña</label>
                                <InputText id="password" type="password" @bind-Value="loginForm.Password" class="form-control" placeholder="Tu contraseña" />
                                <ValidationMessage For="@(() => loginForm.Password)" />
                            </div>

                            <div class="form-checkbox">
                                <InputCheckbox id="remember" @bind-Value="loginForm.RecordarSesion" />
                                <label for="remember">Recordar sesión</label>
                            </div>

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-error">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/>
                                        <line x1="12" y1="8" x2="12" y2="12"/>
                                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                                    </svg>
                                    @errorMessage
                                </div>
                            }

                            <button type="submit" class="btn-primary btn-login" disabled="@procesando">
                                @if (procesando)
                                {
                                    <span class="spinner-sm">✦</span>
                                    <text>Iniciando sesión...</text>
                                }
                                else
                                {
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                                        <polyline points="10 17 15 12 10 7"/>
                                        <line x1="15" y1="12" x2="3" y2="12"/>
                                    </svg>
                                    <text>Iniciar Sesión</text>
                                }
                            </button>
                        </EditForm>

                        <a href="/recuperar-password" class="forgot-password">¿Olvidaste tu contraseña?</a>
                    </div>

                    <p class="register-link">
                        ¿No tienes cuenta? <a href="/registro" class="link-primary">Regístrate gratis</a>
                    </p>
                </div>

                <div class="benefits-sidebar">
                    <h3>Beneficios de Tener Cuenta</h3>
                    <ul class="benefits-list">
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Seguimiento de pedidos en tiempo real</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Guarda tus productos favoritos</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Checkout más rápido</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Ofertas y descuentos exclusivos</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Historial de compras</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cuenta-content {
        padding: 40px 0 var(--section-gap);
    }

    .login-prompt {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 60px;
        align-items: start;
    }

    .login-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 48px;
        text-align: center;
    }

    .login-card > svg {
        color: var(--rose);
        margin: 0 auto 24px;
    }

    .login-card h2 {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 400;
        margin-bottom: 12px;
    }

    .login-card > p {
        color: var(--muted);
        margin-bottom: 40px;
    }

    .login-actions {
        text-align: left;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 8px;
        text-align: left;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid var(--border);
        border-radius: 10px;
        font-size: 14px;
        transition: border-color .2s, box-shadow .2s;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--rose);
        box-shadow: 0 0 0 3px rgba(232, 96, 122, .1);
    }

    .form-checkbox {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
    }

    .form-checkbox input[type="checkbox"] {
        cursor: pointer;
    }

    .form-checkbox label {
        font-size: 13px;
        color: var(--ink-light);
        cursor: pointer;
    }

    .alert {
        padding: 16px;
        border-radius: 12px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 14px;
    }

    .alert-error {
        background: #FEE2E2;
        color: #DC2626;
        border: 1px solid #FECACA;
    }

    .alert svg {
        flex-shrink: 0;
    }

    .btn-login {
        width: 100%;
        justify-content: center;
        margin-bottom: 16px;
    }

    .forgot-password {
        display: block;
        text-align: center;
        font-size: 13px;
        color: var(--rose);
        text-decoration: none;
        margin-top: 12px;
    }

    .forgot-password:hover {
        text-decoration: underline;
    }

    .register-link {
        margin-top: 32px;
        padding-top: 32px;
        border-top: 1px solid var(--border);
        font-size: 14px;
        color: var(--ink-light);
        text-align: center;
    }

    .link-primary {
        color: var(--rose);
        font-weight: 600;
        text-decoration: none;
    }

    .link-primary:hover {
        text-decoration: underline;
    }

    .benefits-sidebar h3 {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 400;
        margin-bottom: 24px;
    }

    .benefits-list {
        list-style: none;
    }

    .benefits-list li {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
    }

    .benefits-list li:last-child {
        border-bottom: none;
    }

    .benefits-list svg {
        color: var(--rose);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .spinner-sm {
        display: inline-block;
        animation: spin 1s linear infinite;
    }
</style>

<!-- Estilos @keyframes y @media van en CSS global para evitar conflictos -->

@code {
    private LoginFormModel loginForm = new();
    private bool procesando = false;
    private string errorMessage = string.Empty;

    private async Task IniciarSesion()
    {
        procesando = true;
        errorMessage = string.Empty;

        try
        {
            var result = await AuthService.LoginAsync(loginForm.Email, loginForm.Password);

            if (result.Success)
            {
                // Login exitoso, redirigir a inicio
                Navigation.NavigateTo("/");
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Email o contraseña incorrectos";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error al iniciar sesión. Por favor, inténtalo de nuevo.";
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            procesando = false;
        }
    }

    public class LoginFormModel
    {
        [Required(ErrorMessage = "El email es obligatorio")]
        [EmailAddress(ErrorMessage = "El email no es válido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria")]
        public string Password { get; set; } = string.Empty;

        public bool RecordarSesion { get; set; }
    }
}
