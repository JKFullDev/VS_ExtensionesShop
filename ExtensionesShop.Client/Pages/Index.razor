@page "/"

<PageTitle>Extensiones Shop — Tu Cabello, Tu Poder</PageTitle>

<!-- HERO SECTION -->
<section class="hero" aria-label="Sección principal">
    <div class="hero-bg">
        <div class="hero-blob blob-1"></div>
        <div class="hero-blob blob-2"></div>
    </div>

    <div class="hero-inner">
        <div class="hero-content">
            <span class="hero-eyebrow">✦ Nueva Colección 2025</span>
            <h1 class="hero-title">
                Tu Cabello,<br />
                <em>Tu Poder.</em>
            </h1>
            <p class="hero-subtitle">
                Extensiones de cabello natural 100% Remy. Calidad de salón,
                comodidad de casa. Encuentra el tono perfecto para ti.
            </p>
            <div class="hero-actions">
                <a href="/productos" class="btn-primary">
                    Descubrir Colección
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </a>
                <a href="/como-elegir" class="btn-ghost">
                    ¿Cómo elegir la tuya?
                </a>
            </div>

            <!-- Social proof -->
            <div class="hero-proof">
                <div class="proof-avatars" aria-hidden="true">
                    <div class="avatar av-1"></div>
                    <div class="avatar av-2"></div>
                    <div class="avatar av-3"></div>
                    <div class="avatar av-4"></div>
                </div>
                <div class="proof-text">
                    <strong>+12.000 clientas</strong> ya transformaron su look
                    <span class="stars" aria-label="5 estrellas">★★★★★</span>
                </div>
            </div>
        </div>

        <!-- Hero image placeholder -->
        <div class="hero-visual" aria-hidden="true">
            <div class="hero-img-frame">
                <div class="hero-img-placeholder">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                    </svg>
                    <span>Imagen Hero</span>
                </div>
                <div class="hero-badge-float badge-top">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    100% Cabello Natural
                </div>
                <div class="hero-badge-float badge-bottom">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                    Envío en 24h
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-hint" aria-hidden="true">
        <div class="scroll-line"></div>
        <span>Explorar</span>
    </div>
</section>

<!-- FEATURES STRIP -->
<section class="features-strip" aria-label="Ventajas">
    <div class="features-inner">
        <div class="feature-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <div>
                <strong>100% Remy</strong>
                <span>Cabello natural sin procesar</span>
            </div>
        </div>
        <div class="feature-divider" aria-hidden="true"></div>
        <div class="feature-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <div>
                <strong>Envío Express</strong>
                <span>Entrega en 24-48h</span>
            </div>
        </div>
        <div class="feature-divider" aria-hidden="true"></div>
        <div class="feature-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
            </svg>
            <div>
                <strong>30 días</strong>
                <span>Devolución gratuita</span>
            </div>
        </div>
        <div class="feature-divider" aria-hidden="true"></div>
        <div class="feature-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <div>
                <strong>+12.000 clientas</strong>
                <span>Confían en nosotras</span>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORÍAS DESTACADAS (placeholder visual) -->
<section class="categories-section" aria-label="Categorías destacadas">
    <div class="section-inner">
        <div class="section-header">
            <span class="section-eyebrow">Nuestras Familias</span>
            <h2 class="section-title">Encuentra Tu Método</h2>
        </div>

        <div class="categories-grid">
            <a href="/productos?cat=clip-in" class="category-card cat-large">
                <div class="cat-img-placeholder">
                    <span>Clip-In</span>
                </div>
                <div class="cat-overlay">
                    <h3>Clip-In</h3>
                    <p>Sin químicos, sin calor</p>
                    <span class="cat-cta">Ver colección →</span>
                </div>
            </a>

            <div class="categories-right">
                <a href="/productos?cat=tape-in" class="category-card cat-small">
                    <div class="cat-img-placeholder">
                        <span>Tape-In</span>
                    </div>
                    <div class="cat-overlay">
                        <h3>Tape-In</h3>
                        <p>Resultado profesional</p>
                        <span class="cat-cta">Ver colección →</span>
                    </div>
                </a>
                <a href="/productos?cat=keratin" class="category-card cat-small">
                    <div class="cat-img-placeholder">
                        <span>Keratina</span>
                    </div>
                    <div class="cat-overlay">
                        <h3>Keratina</h3>
                        <p>Fusión perfecta</p>
                        <span class="cat-cta">Ver colección →</span>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- CTA BANNER -->
<section class="cta-banner" aria-label="Oferta especial">
    <div class="cta-inner">
        <div class="cta-content">
            <span class="cta-eyebrow">Oferta Limitada</span>
            <h2 class="cta-title">Tu primera compra,<br/><em>-15% de descuento.</em></h2>
            <p class="cta-text">Únete a nuestra comunidad y transforma tu cabello hoy mismo.</p>
            <div class="cta-input-group">
                <input type="email" placeholder="tu@email.com" class="cta-email-input" />
                <button class="btn-primary">Obtener descuento</button>
            </div>
        </div>
    </div>
</section>
