            <span class="hero-banner-eyebrow">Nueva Colección 2026</span>
            <h2 class="hero-banner-title">Tu Cabello, Tu Poder</h2>
            <p class="hero-banner-subtitle">
                Extensiones 100% Remy de la más alta calidad. Transforma tu look con nuestras colecciones exclusivas.
            </p>

            <div class="hero-banner-actions">
                <a href="/productos" class="btn-primary" style="padding: 10px 24px;">Ver Catálogo</a>
                @* <a href="/guia" class="btn-outline-light">Guía de compra</a> *@
                    <div class="social-links">
                        <!-- Instagram -->
