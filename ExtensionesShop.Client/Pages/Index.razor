@page "/"
<PageTitle>Extensiones Shop — Tu Cabello, Tu Poder</PageTitle>

<div class="page-header">
    <a href="/admin">ADMIN</a>
<section class="hero-banner-section" aria-label="Sección principal">
    <div class="hero-banner-wrapper">
        <img src="/images/hero-extensions.jpg" alt="Extensiones de cabello de lujo" class="hero-banner-bg" loading="eager" />

        <div class="hero-banner-overlay"></div>

        <div class="hero-banner-content">
            <span class="hero-banner-eyebrow">Nueva Colección 2026</span>
            <h2 class="hero-banner-title">Tu Cabello, Tu Poder</h2>
            <p class="hero-banner-subtitle">
                Extensiones 100% Remy de la más alta calidad. Transforma tu look con nuestras colecciones exclusivas.
            </p>

            <div class="hero-banner-actions">
                <a href="/productos" class="btn-primary" style="padding: 10px 24px;">Ver Catálogo</a>
                <a href="/guia" class="btn-outline-light">Guía de compra</a>
            </div>
        </div>
    </div>
</section>
</div>
<!-- FEATURES STRIP -->
<section class="features-strip" aria-label="Ventajas">
    <div class="features-inner">
        <div class="feature-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <div>
                <strong>100% Remy</strong>
                <span>Cabello natural sin procesar</span>
            </div>
        </div>
        <div class="feature-divider" aria-hidden="true"></div>
        <div class="feature-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <div>
                <strong>Envío Express</strong>
                <span>Entrega en 24-48h</span>
            </div>
        </div>
        <div class="feature-divider" aria-hidden="true"></div>
        <div class="feature-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
            </svg>
            <div>
                <strong>30 días</strong>
                <span>Devolución gratuita</span>
            </div>
        </div>
        <div class="feature-divider" aria-hidden="true"></div>
        <div class="feature-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <div>
                <strong>+12.000 clientas</strong>
                <span>Confían en nosotras</span>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORÍAS DESTACADAS -->
<div class="page-header">
<section class="categories-section" aria-label="Categorías destacadas">
    <div class="section-inner">
        <div class="section-header">
            <span class="section-eyebrow">Nuestras Familias</span>
            <h2 class="section-title">Explora Nuestras Categorías</h2>
        </div>

        <div class="categories-grid">
            <a href="/productos?categoryId=1" class="category-card cat-large">
                <div class="cat-img-placeholder">
                    <span>Pelo Natural</span>
                </div>
                <div class="cat-overlay">
                    <h3>Extensiones de Pelo Natural</h3>
                    <p>100% Remy de máxima calidad</p>
                    <span class="cat-cta">Ver colección →</span>
                </div>
            </a>

            <div class="categories-right">
                <a href="/productos?categoryId=2" class="category-card cat-small">
                    <div class="cat-img-placeholder">
                        <span>Frontales</span>
                    </div>
                    <div class="cat-overlay">
                        <h3>Frontal, Topper y Pelucas</h3>
                        <p>Soluciones completas</p>
                        <span class="cat-cta">Ver colección →</span>
                    </div>
                </a>
                <a href="/productos?categoryId=4" class="category-card cat-small">
                    <div class="cat-img-placeholder">
                        <span>Coletas</span>
                    </div>
                    <div class="cat-overlay">
                        <h3>Coletas y Moños</h3>
                        <p>Estilo instantáneo</p>
                        <span class="cat-cta">Ver colección →</span>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>
</div>
<!-- CTA BANNER -->
<section class="cta-banner" aria-label="Oferta especial">
    <div class="cta-inner">
        <div class="cta-content">
            <span class="cta-eyebrow">Oferta Limitada</span>
            <h2 class="cta-title">Tu primera compra,<br/><em>-15% de descuento.</em></h2>
            <p class="cta-text">Únete a nuestra comunidad y transforma tu cabello hoy mismo.</p>
            <div class="cta-input-group">
                <input type="email" placeholder="tu@email.com" class="cta-email-input" />
                <button class="btn-primary">Obtener descuento</button>
            </div>
        </div>
    </div>
</section>
