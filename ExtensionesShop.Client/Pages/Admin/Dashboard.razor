@page "/admin"
@layout ExtensionesShop.Client.Layouts.AdminLayout
@using ExtensionesShop.Shared.Models
@inject HttpClient Http


    <!-- Page Header (estilo corporativo) -->
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <a href="/admin" class="breadcrumb-link">Admin</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Dashboard</span>
            </div>
            <h1 class="page-title">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="3" y1="9" x2="21" y2="9"></line>
                    <line x1="9" y1="21" x2="9" y2="9"></line>
                </svg>
                Panel de Control
            </h1>
            <p class="page-subtitle">Gestiona tu tienda desde un solo lugar</p>
        </div>
    </div>

    <div class="dashboard-content">
        <div class="section-inner">
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner">✦</div>
                    <p>Cargando estadísticas...</p>
                </div>
            }
            else
            {
                <!-- Stats Cards -->
                <div class="stats-grid">
                    <div class="stat-card stat-card-rose">
                        <div class="stat-icon-wrapper">
                            <svg class="stat-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                                <line x1="3" y1="6" x2="21" y2="6"></line>
                            </svg>
                        </div>
                        <div class="stat-content">
                            <div class="stat-label">Total Pedidos</div>
                            <div class="stat-value">@stats.TotalPedidos</div>
                            <div class="stat-trend">Últimos 30 días</div>
                        </div>
                    </div>

                    <div class="stat-card stat-card-green">
                        <div class="stat-icon-wrapper">
                            <svg class="stat-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="1" x2="12" y2="23"></line>
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                            </svg>
                        </div>
                        <div class="stat-content">
                            <div class="stat-label">Ingresos Totales</div>
                            <div class="stat-value">$@stats.IngresosTotales.ToString("N2")</div>
                            <div class="stat-trend">Revenue total</div>
                        </div>
                    </div>

                    <div class="stat-card stat-card-blue">
                        <div class="stat-icon-wrapper">
                            <svg class="stat-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="9" cy="21" r="1"></circle>
                                <circle cx="20" cy="21" r="1"></circle>
                                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                            </svg>
                        </div>
                        <div class="stat-content">
                            <div class="stat-label">Total Productos</div>
                            <div class="stat-value">@stats.TotalProductos</div>
                            <div class="stat-trend">En catálogo</div>
                        </div>
                    </div>

                    <div class="stat-card stat-card-orange">
                        <div class="stat-icon-wrapper">
                            <svg class="stat-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                        </div>
                        <div class="stat-content">
                            <div class="stat-label">Total Usuarios</div>
                            <div class="stat-value">@stats.TotalUsuarios</div>
                            <div class="stat-trend">Registrados</div>
                        </div>
                    </div>
                </div>

                <!-- Pedidos Recientes -->
                <div class="data-section">
                    <div class="section-title-wrapper">
                        <h2 class="section-title">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                            </svg>
                            Pedidos Recientes
                        </h2>
                        <a href="/admin/pedidos" class="btn-view-all">
                            Ver Todos
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                        </a>
                    </div>

                    <div class="table-card">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Pedido</th>
                                    <th>Cliente</th>
                                    <th>Total</th>
                                    <th>Estado</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (pedidosRecientes.Any())
                                {
                                    @foreach (var pedido in pedidosRecientes.Take(5))
                                    {
                                        <tr>
                                            <td><span class="pedido-id">#@pedido.Id</span></td>
                                            <td>@pedido.CustomerName</td>
                                            <td><strong class="amount">$@pedido.Total.ToString("N2")</strong></td>
                                            <td>
                                                <span class="status-badge @GetStatusClass(pedido.Status)">
                                                    @GetStatusText(pedido.Status)
                                                </span>
                                            </td>
                                            <td class="date-cell">@pedido.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="empty-state">
                                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                                            </svg>
                                            <p>No hay pedidos recientes</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Productos con Bajo Stock -->
                <div class="data-section">
                    <div class="section-title-wrapper">
                        <h2 class="section-title">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="12" y1="8" x2="12" y2="12"></line>
                                <line x1="12" y1="16" x2="12.01" y2="16"></line>
                            </svg>
                            Productos con Stock Bajo
                        </h2>
                        <a href="/admin/productos" class="btn-view-all">
                            Ver Todos
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                        </a>
                    </div>

                    <div class="table-card">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Producto</th>
                                    <th>Categoría</th>
                                    <th>Stock</th>
                                    <th>Precio</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (productosBajoStock.Any())
                                {
                                    @foreach (var producto in productosBajoStock.Take(5))
                                    {
                                        <tr>
                                            <td><span class="product-id">#@producto.Id</span></td>
                                            <td>@producto.Name</td>
                                            <td>@producto.Category?.Name</td>
                                            <td>
                                                <span class="stock-warning">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <circle cx="12" cy="12" r="10"></circle>
                                                        <line x1="12" y1="8" x2="12" y2="12"></line>
                                                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                                    </svg>
                                                    @producto.Stock unidades
                                                </span>
                                            </td>
                                            <td><strong class="amount">$@producto.Price.ToString("N2")</strong></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="empty-state">
                                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
                                                <line x1="9" y1="9" x2="9.01" y2="9"></line>
                                                <line x1="15" y1="9" x2="15.01" y2="9"></line>
                                            </svg>
                                            <p>✅ Todos los productos tienen stock adecuado</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>

<style>
    /* ================================================================
       DASHBOARD - ESTILO CORPORATIVO
       ================================================================ */

    /* Page Header - Heredado del estilo global */
    .page-header {
        background: linear-gradient(to bottom, var(--rose-pale), var(--white));
        padding: 36px 0 40px;
        text-align: center;
        margin: -32px -32px 32px -32px;
    }

    .dashboard-content {
        padding: 32px 0;
    }

    .loading-state {
        text-align: center;
        padding: 80px 20px;
    }

    .spinner {
        font-size: 48px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* === STATS CARDS === */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 24px;
        margin-bottom: 48px;
    }

    .stat-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 28px;
        display: flex;
        align-items: flex-start;
        gap: 20px;
        transition: all .3s var(--ease);
        position: relative;
        overflow: hidden;
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--rose), var(--rose-light));
        opacity: 0;
        transition: opacity .3s var(--ease);
    }

    .stat-card:hover {
        border-color: var(--rose-light);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }

    .stat-card:hover::before {
        opacity: 1;
    }

    .stat-icon-wrapper {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-card-rose .stat-icon-wrapper {
        background: linear-gradient(135deg, #FFF1F5, #FFE5EC);
    }

    .stat-card-rose .stat-icon {
        color: var(--rose);
    }

    .stat-card-green .stat-icon-wrapper {
        background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
    }

    .stat-card-green .stat-icon {
        color: #4CAF50;
    }

    .stat-card-blue .stat-icon-wrapper {
        background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
    }

    .stat-card-blue .stat-icon {
        color: #2196F3;
    }

    .stat-card-orange .stat-icon-wrapper {
        background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
    }

    .stat-card-orange .stat-icon {
        color: #FF9800;
    }

    .stat-content {
        flex: 1;
        min-width: 0;
    }

    .stat-label {
        font-size: 13px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: 8px;
        font-weight: 500;
    }

    .stat-value {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 600;
        color: var(--ink);
        line-height: 1.1;
        margin-bottom: 4px;
    }

    .stat-trend {
        font-size: 12px;
        color: var(--muted);
    }

    /* === DATA SECTIONS === */
    .data-section {
        margin-bottom: 40px;
    }

    .section-title-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .section-title {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 400;
        color: var(--ink);
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 0;
    }

    .section-title svg {
        color: var(--rose);
    }

    .btn-view-all {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 24px;
        color: var(--ink);
        font-size: 14px;
        font-weight: 500;
        transition: all .3s var(--ease);
    }

    .btn-view-all:hover {
        background: var(--rose);
        border-color: var(--rose);
        color: var(--white);
        transform: translateX(4px);
    }

    .btn-view-all svg {
        transition: transform .3s var(--ease);
    }

    .btn-view-all:hover svg {
        transform: translateX(4px);
    }

    /* === TABLE === */
    .table-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table thead {
        background: var(--off-white);
        border-bottom: 2px solid var(--border);
    }

    .data-table th {
        padding: 16px 20px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .8px;
    }

    .data-table td {
        padding: 20px;
        border-bottom: 1px solid var(--border);
        font-size: 15px;
        color: var(--ink-light);
    }

    .data-table tbody tr:last-child td {
        border-bottom: none;
    }

    .data-table tbody tr {
        transition: background-color .2s var(--ease);
    }

    .data-table tbody tr:hover {
        background: var(--off-white);
    }

    .pedido-id,
    .product-id {
        font-family: var(--font-display);
        font-weight: 600;
        color: var(--rose);
        font-size: 16px;
    }

    .amount {
        font-weight: 600;
        color: var(--ink);
    }

    .date-cell {
        color: var(--muted);
        font-size: 14px;
    }

    /* Status Badges */
    .status-badge {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .3px;
    }

    .status-pending {
        background: #FFF3CD;
        color: #856404;
    }

    .status-confirmed {
        background: #D1ECF1;
        color: #0C5460;
    }

    .status-processing {
        background: #D1ECF1;
        color: #0C5460;
    }

    .status-shipped {
        background: #D4EDDA;
        color: #155724;
    }

    .status-delivered {
        background: #D4EDDA;
        color: #155724;
    }

    .status-cancelled {
        background: #F8D7DA;
        color: #721C24;
    }

    .stock-warning {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #D97706;
        font-weight: 600;
    }

    .stock-warning svg {
        flex-shrink: 0;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px !important;
        color: var(--muted);
    }

    .empty-state svg {
        margin: 0 auto 16px;
        opacity: 0.3;
    }

    .empty-state p {
        font-size: 15px;
    }

    /* === RESPONSIVE === */
    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .page-header {
            margin: -32px -16px 32px -16px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .section-title-wrapper {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }

        .data-table {
            font-size: 13px;
        }

        .data-table th,
        .data-table td {
            padding: 12px;
        }

        .stat-value {
            font-size: 28px;
        }
    }
</style>

@code {
    private bool isLoading = true;
    private DashboardStats stats = new();
    private List<Order> pedidosRecientes = new();
    private List<Product> productosBajoStock = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading = true;
            Console.WriteLine("📊 Dashboard - Iniciando carga de datos...");

            // Cargar pedidos
            Console.WriteLine("📦 Cargando pedidos...");
            var pedidos = await Http.GetFromJsonAsync<List<Order>>("api/orders") ?? new();
            pedidosRecientes = pedidos;
            Console.WriteLine($"✅ Pedidos cargados: {pedidos.Count}");

            // Cargar productos
            Console.WriteLine("🛍️ Cargando productos...");
            var productos = await Http.GetFromJsonAsync<List<Product>>("api/products") ?? new();
            productosBajoStock = productos.Where(p => p.Stock < 10).OrderBy(p => p.Stock).ToList();
            Console.WriteLine($"✅ Productos cargados: {productos.Count}");

            // Cargar usuarios
            Console.WriteLine("👥 Cargando usuarios...");
            var usuarios = await Http.GetFromJsonAsync<List<User>>("api/users") ?? new();
            Console.WriteLine($"✅ Usuarios cargados: {usuarios.Count}");

            // Calcular estadísticas
            stats.TotalPedidos = pedidos.Count;
            stats.IngresosTotales = pedidos.Sum(p => p.Total);
            stats.TotalProductos = productos.Count;
            stats.TotalUsuarios = usuarios.Count;

            Console.WriteLine("📊 Estadísticas calculadas:");
            Console.WriteLine($"   Total Pedidos: {stats.TotalPedidos}");
            Console.WriteLine($"   Ingresos: ${stats.IngresosTotales:N2}");
            Console.WriteLine($"   Productos: {stats.TotalProductos}");
            Console.WriteLine($"   Usuarios: {stats.TotalUsuarios}");
        }
        catch (HttpRequestException httpEx)
        {
            Console.WriteLine($"❌ Error HTTP cargando dashboard: {httpEx.Message}");
            Console.WriteLine($"   StatusCode: {httpEx.StatusCode}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error cargando dashboard: {ex.Message}");
            Console.WriteLine($"   StackTrace: {ex.StackTrace}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetStatusText(int status)
    {
        return status switch
        {
            0 => "Pendiente",
            1 => "Confirmado",
            2 => "En Proceso",
            3 => "Enviado",
            4 => "Entregado",
            5 => "Cancelado",
            _ => "Desconocido"
        };
    }

    private string GetStatusClass(int status)
    {
        return status switch
        {
            0 => "status-pending",
            1 => "status-confirmed",
            2 => "status-processing",
            3 => "status-shipped",
            4 => "status-delivered",
            5 => "status-cancelled",
            _ => "status-pending"
        };
    }

    private class DashboardStats
    {
        public int TotalPedidos { get; set; }
        public decimal IngresosTotales { get; set; }
        public int TotalProductos { get; set; }
        public int TotalUsuarios { get; set; }
    }
}
