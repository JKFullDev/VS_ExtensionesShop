@page "/admin/usuarios"
@layout ExtensionesShop.Client.Layouts.AdminLayout
@using ExtensionesShop.Shared.Models
@inject HttpClient Http
@inject IJSRuntime JS

    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <a href="/admin" class="breadcrumb-link">Admin</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Usuarios</span>
            </div>

            <div class="header-content-flex" style="display: flex; flex-direction:column; gap:20px; justify-content: space-between; align-items: center;">
                <div>
                    <h1 class="page-title">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                        Gestión de Usuarios
                    </h1>
                    <p class="page-subtitle">Controla los accesos y roles de los clientes (@usuarios.Count registrados)</p>
                </div>

                <div class="filtros">
                    <select @onchange="FiltrarPorRol" class="filtro-select">
                        <option value="">Todos los roles</option>
                        <option value="Admin">Solo Admins</option>
                        <option value="User">Solo Usuarios</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="section-inner">

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner">✦</div>
                <p>Cargando usuarios...</p>
            </div>
        }
        else
        {
            <div class="table-card">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Teléfono</th>
                            <th>Ciudad</th>
                            <th>Rol</th>
                            <th>Pedidos</th>
                            <th>Registrado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var usuario in usuariosFiltrados)
                        {
                            <tr>
                                <td><strong>#@usuario.Id</strong></td>
                                <td>@usuario.FirstName @usuario.LastName</td>
                                <td>
                                    <a href="mailto:@usuario.Email">@usuario.Email</a>
                                    @if (usuario.EmailVerified)
                                    {
                                        <span class="badge-verified" title="Email verificado">✓</span>
                                    }
                                </td>
                                <td>@usuario.Phone</td>
                                <td>@usuario.City</td>
                                <td>
                                    <select class="rol-select @(usuario.Role == "Admin" ? "rol-admin" : "")"
                                            value="@usuario.Role"
                                            @onchange="@(e => CambiarRol(usuario, e.Value?.ToString() ?? "User"))">
                                        <option value="User">Usuario</option>
                                        <option value="Admin">Admin</option>
                                    </select>
                                </td>
                                <td>
                                    <span class="pedidos-count">@GetPedidosCount(usuario.Id)</span>
                                </td>
                                <td>@usuario.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <button class="btn-icon" @onclick="() => VerDetalles(usuario)" title="Ver detalles">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                            <circle cx="12" cy="12" r="3"></circle>
                                        </svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Modal de Detalles -->
        @if (usuarioSeleccionado != null)
        {
            <div class="modal-overlay" @onclick="CerrarModal">
                <div class="modal-content" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h3>Detalles de Usuario #@usuarioSeleccionado.Id</h3>
                        <button class="btn-close" @onclick="CerrarModal">✕</button>
                    </div>

                    <div class="modal-body">
                        <div class="user-info-grid">
                            <div class="info-item">
                                <label>Nombre Completo:</label>
                                <p>@usuarioSeleccionado.FirstName @usuarioSeleccionado.LastName</p>
                            </div>

                            <div class="info-item">
                                <label>Email:</label>
                                <p>
                                    @usuarioSeleccionado.Email
                                    @if (usuarioSeleccionado.EmailVerified)
                                    {
                                        <span class="badge-verified">✓ Verificado</span>
                                    }
                                    else
                                    {
                                        <span class="badge-not-verified">✗ Sin verificar</span>
                                    }
                                </p>
                            </div>

                            <div class="info-item">
                                <label>Teléfono:</label>
                                <p>@usuarioSeleccionado.Phone</p>
                            </div>

                            <div class="info-item">
                                <label>Rol:</label>
                                <p>
                                    <span class="role-badge @(usuarioSeleccionado.Role == "Admin" ? "role-admin" : "role-user")">
                                        @usuarioSeleccionado.Role
                                    </span>
                                </p>
                            </div>

                            <div class="info-item full-width">
                                <label>Dirección:</label>
                                <p>@usuarioSeleccionado.Address</p>
                            </div>

                            <div class="info-item">
                                <label>Ciudad:</label>
                                <p>@usuarioSeleccionado.City</p>
                            </div>

                            <div class="info-item">
                                <label>Código Postal:</label>
                                <p>@usuarioSeleccionado.PostalCode</p>
                            </div>

                            <div class="info-item">
                                <label>Registrado:</label>
                                <p>@usuarioSeleccionado.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>

                            <div class="info-item">
                                <label>Total de Pedidos:</label>
                                <p><strong>@GetPedidosCount(usuarioSeleccionado.Id)</strong></p>
                            </div>
                        </div>

                        <div class="pedidos-usuario">
                            <h4>Pedidos Recientes</h4>
                            @{
                                var pedidosUsuario = pedidosTodos.Where(p => p.UserId == usuarioSeleccionado.Id).OrderByDescending(p => p.CreatedAt).Take(5).ToList();
                            }

                            @if (pedidosUsuario.Any())
                            {
                                <ul class="pedidos-list">
                                    @foreach (var pedido in pedidosUsuario)
                                    {
                                        <li>
                                            <span>Pedido #@pedido.Id</span>
                                            <span>$@pedido.Total.ToString("N2")</span>
                                            <span class="status-badge @GetStatusClass(pedido.Status)">
                                                @GetStatusText(pedido.Status)
                                            </span>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="no-data">Sin pedidos</p>
                            }
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn-secondary" @onclick="CerrarModal">Cerrar</button>
                    </div>
                </div>
            </div>
        }
    </div>

<style>
    /* Page Header - Heredado del estilo global */
    .page-header {
        background: linear-gradient(to bottom, var(--rose-pale), var(--white));
        padding: 36px 0 40px;
        text-align: center;
        margin: -32px -32px 32px -32px;
    }

    .usuarios-admin-page {
        max-width: 1600px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .page-header h2 {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
    }

    .filtros {
        display: flex;
        gap: 12px;
    }

    .filtro-select {
        padding: 8px 16px;
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        font-size: 14px;
        background: white;
    }

    .loading-state {
        text-align: center;
        padding: 80px 20px;
    }

    .spinner {
        font-size: 48px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .table-card {
        background: white;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th {
        background: #F8FAFC;
        padding: 12px 16px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        color: #64748B;
        text-transform: uppercase;
        white-space: nowrap;
        border-bottom: 1px solid #E2E8F0;
    }

    .data-table td {
        padding: 16px;
        border-bottom: 1px solid #F1F5F9;
        font-size: 14px;
    }

    .data-table tr:hover {
        background: #F8FAFC;
    }

    .badge-verified {
        display: inline-block;
        background: #D4EDDA;
        color: #155724;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        margin-left: 6px;
    }

    .rol-select {
        padding: 6px 12px;
        border: 1px solid #E2E8F0;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        background: white;
        cursor: pointer;
    }

    .rol-select.rol-admin {
        background: #FFF3F8;
        color: var(--rose);
        border-color: var(--rose);
    }

    .pedidos-count {
        display: inline-block;
        background: #E3F2FD;
        color: #2196F3;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-icon {
        padding: 8px;
        border: none;
        background: #F1F5F9;
        border-radius: 6px;
        cursor: pointer;
        color: var(--ink);
        transition: all .2s;
    }

    .btn-icon:hover {
        background: var(--rose);
        color: white;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 16px;
        max-width: 700px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px;
        border-bottom: 1px solid #E2E8F0;
    }

    .modal-header h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
    }

    .btn-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #94A3B8;
    }

    .modal-body {
        padding: 24px;
    }

    .user-info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 24px;
    }

    .info-item {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .info-item.full-width {
        grid-column: 1 / -1;
    }

    .info-item label {
        font-size: 13px;
        font-weight: 600;
        color: #64748B;
    }

    .info-item p {
        font-size: 14px;
        color: var(--ink);
        margin: 0;
    }

    .badge-not-verified {
        display: inline-block;
        background: #FFF3CD;
        color: #856404;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        margin-left: 6px;
    }

    .role-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
    }

    .role-admin {
        background: #FFF3F8;
        color: var(--rose);
    }

    .role-user {
        background: #E3F2FD;
        color: #2196F3;
    }

    .pedidos-usuario {
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid #E2E8F0;
    }

    .pedidos-usuario h4 {
        margin: 0 0 16px 0;
        font-size: 16px;
        font-weight: 600;
    }

    .pedidos-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .pedidos-list li {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px;
        background: #F8FAFC;
        border-radius: 6px;
        margin-bottom: 8px;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .status-pending { background: #FFF3CD; color: #856404; }
    .status-confirmed { background: #D1ECF1; color: #0C5460; }
    .status-processing { background: #D1ECF1; color: #0C5460; }
    .status-shipped { background: #D4EDDA; color: #155724; }
    .status-delivered { background: #D4EDDA; color: #155724; }
    .status-cancelled { background: #F8D7DA; color: #721C24; }

    .no-data {
        text-align: center;
        color: #94A3B8;
        padding: 20px;
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid #E2E8F0;
        display: flex;
        justify-content: flex-end;
    }
</style>

@code {
    private List<User> usuarios = new();
    private List<User> usuariosFiltrados = new();
    private List<Order> pedidosTodos = new();
    private User? usuarioSeleccionado;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading = true;
            usuarios = await Http.GetFromJsonAsync<List<User>>("api/users") ?? new();
            usuariosFiltrados = usuarios;
            pedidosTodos = await Http.GetFromJsonAsync<List<Order>>("api/orders") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error cargando datos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FiltrarPorRol(ChangeEventArgs e)
    {
        var rol = e.Value?.ToString();
        usuariosFiltrados = string.IsNullOrEmpty(rol)
            ? usuarios
            : usuarios.Where(u => u.Role == rol).ToList();
    }

    private async Task CambiarRol(User usuario, string nuevoRol)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Cambiar el rol de '{usuario.FirstName} {usuario.LastName}' a {nuevoRol}?");
        if (!confirmado)
        {
            StateHasChanged();
            return;
        }

        try
        {
            usuario.Role = nuevoRol;
            await Http.PutAsJsonAsync($"api/users/{usuario.Id}", usuario);
            await JS.InvokeVoidAsync("alert", "✅ Rol actualizado correctamente");
            await CargarDatos();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error cambiando rol: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
    }

    private void VerDetalles(User usuario)
    {
        usuarioSeleccionado = usuario;
    }

    private void CerrarModal()
    {
        usuarioSeleccionado = null;
    }

    private int GetPedidosCount(int userId)
    {
        return pedidosTodos.Count(p => p.UserId == userId);
    }

    private string GetStatusText(int status)
    {
        return status switch
        {
            0 => "Pendiente",
            1 => "Confirmado",
            2 => "En Proceso",
            3 => "Enviado",
            4 => "Entregado",
            5 => "Cancelado",
            _ => "Desconocido"
        };
    }

    private string GetStatusClass(int status)
    {
        return status switch
        {
            0 => "status-pending",
            1 => "status-confirmed",
            2 => "status-processing",
            3 => "status-shipped",
            4 => "status-delivered",
            5 => "status-cancelled",
            _ => "status-pending"
        };
    }
}
