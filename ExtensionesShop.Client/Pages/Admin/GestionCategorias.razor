@page "/admin/categorias"
@layout ExtensionesShop.Client.Layouts.AdminLayout
@using ExtensionesShop.Shared.Models
@inject HttpClient Http
@inject IJSRuntime JS

<AdminRoute>
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <a href="/admin" class="breadcrumb-link">Admin</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Categorías</span>
            </div>

            <div class="header-content-flex" style="display: flex; flex-direction:column; gap:20px; justify-content: space-between; align-items: center;">
                <div>
                    <h1 class="page-title">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                        Estructura de Categorías
                    </h1>
                    <p class="page-subtitle">Organiza los menús y subcategorías de la tienda</p>
                </div>

                <button class="btn-primary" @onclick="() => MostrarModal(null, false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Nueva Categoría
                </button>
            </div>
        </div>
    </div>

    <div class="section-inner">

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner">✦</div>
                <p>Cargando categorías...</p>
            </div>
        }
        else
        {
            <div class="categorias-grid">
                @foreach (var categoria in categorias)
                {
                    <div class="categoria-card">
                        <div class="categoria-header">
                            <h3>@categoria.Name</h3>
                            <div class="action-buttons">
                                <button class="btn-icon" @onclick="() => MostrarModal(categoria, false)" title="Editar">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                    </svg>
                                </button>
                                <button class="btn-icon btn-delete" @onclick="() => EliminarCategoria(categoria)" title="Eliminar">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="subcategorias-section">
                            <div class="subcategorias-header">
                                <strong>Subcategorías (@(categoria.Subcategories?.Count ?? 0))</strong>
                                <button class="btn-add-sub" @onclick="() => MostrarModal(categoria, true)">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="12" y1="5" x2="12" y2="19"></line>
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                    </svg>
                                    Agregar
                                </button>
                            </div>

                            @if (categoria.Subcategories?.Any() == true)
                            {
                                <ul class="subcategorias-list">
                                    @foreach (var sub in categoria.Subcategories)
                                    {
                                        <li class="subcategoria-item">
                                            <span>@sub.Name</span>
                                            <div class="sub-actions">
                                                <button class="btn-icon-sm" @onclick="() => EditarSubcategoria(sub)" title="Editar">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                                    </svg>
                                                </button>
                                                <button class="btn-icon-sm" @onclick="() => EliminarSubcategoria(sub)" title="Eliminar">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <polyline points="3 6 5 6 21 6"></polyline>
                                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                    </svg>
                                                </button>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="no-subcategorias">Sin subcategorías</p>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Modal -->
        @if (mostrarModal)
        {
            <div class="modal-overlay" @onclick="CerrarModal">
                <div class="modal-content" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h3>@(esSubcategoria ? "Nueva Subcategoría" : itemEditando?.Id == 0 ? "Nueva Categoría" : "Editar Categoría")</h3>
                        <button class="btn-close" @onclick="CerrarModal">✕</button>
                    </div>

                    <div class="modal-body">
                        <div class="form-group">
                            <label>Nombre *</label>
                            <input type="text" @bind="nombreInput" class="form-control" placeholder="Nombre..." />
                        </div>

                        @if (esSubcategoria)
                        {
                            <div class="form-group">
                                <label>Categoría Padre</label>
                                <input type="text" value="@categoriaSeleccionada?.Name" class="form-control" disabled />
                            </div>
                        }
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-secondary" @onclick="CerrarModal">Cancelar</button>
                        <button type="button" class="btn-primary" @onclick="GuardarItem" disabled="@guardando">
                            @if (guardando)
                            {
                                <span>Guardando...</span>
                            }
                            else
                            {
                                <span>Guardar</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</AdminRoute>

<style>
    /* Page Header - Heredado del estilo global */
    .page-header {
        background: linear-gradient(to bottom, var(--rose-pale), var(--white));
        padding: 36px 0 40px;
        text-align: center;
        margin: -32px -32px 32px -32px;
    }

    .categorias-admin-page {
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .page-header h2 {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
    }

    .loading-state {
        text-align: center;
        padding: 80px 20px;
    }

    .spinner {
        font-size: 48px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .categorias-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 24px;
    }

    .categoria-card {
        background: white;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        padding: 24px;
    }

    .categoria-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 2px solid var(--rose);
    }

    .categoria-header h3 {
        font-size: 20px;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .btn-icon {
        padding: 8px;
        border: none;
        background: #F1F5F9;
        border-radius: 6px;
        cursor: pointer;
        color: var(--ink);
        transition: all .2s;
    }

    .btn-icon:hover {
        background: var(--rose);
        color: white;
    }

    .btn-delete:hover {
        background: #DC2626;
    }

    .subcategorias-section {
        margin-top: 16px;
    }

    .subcategorias-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .btn-add-sub {
        padding: 6px 12px;
        background: #F1F5F9;
        border: none;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        color: var(--ink);
        transition: all .2s;
    }

    .btn-add-sub:hover {
        background: var(--rose);
        color: white;
    }

    .subcategorias-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .subcategoria-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 12px;
        background: #F8FAFC;
        border-radius: 6px;
        margin-bottom: 6px;
    }

    .sub-actions {
        display: flex;
        gap: 8px;
    }

    .btn-icon-sm {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 14px;
        padding: 4px;
        transition: transform .2s;
    }

    .btn-icon-sm:hover {
        transform: scale(1.2);
    }

    .no-subcategorias {
        text-align: center;
        color: #94A3B8;
        font-size: 14px;
        padding: 20px;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        padding: 0;
        border-radius: 16px;
        max-width: 500px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px;
        border-bottom: 1px solid #E2E8F0;
    }

    .modal-header h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
    }

    .btn-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #94A3B8;
        padding: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-close:hover {
        color: var(--ink);
    }

    .modal-body {
        padding: 24px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        font-size: 14px;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--rose);
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid #E2E8F0;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }
</style>

@code {
    private List<Category> categorias = new();
    private bool isLoading = true;
    private bool mostrarModal = false;
    private bool esSubcategoria = false;
    private bool guardando = false;
    private Category? categoriaSeleccionada;
    private Category itemEditando = new();
    private Subcategory? subEditando;
    private string nombreInput = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading = true;
            categorias = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error cargando categorías: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void MostrarModal(Category? categoria, bool esSubcat)
    {
        esSubcategoria = esSubcat;
        categoriaSeleccionada = categoria;
        nombreInput = "";

        if (!esSubcat)
        {
            itemEditando = categoria ?? new Category();
            nombreInput = itemEditando.Name;
        }

        mostrarModal = true;
    }

    private void EditarSubcategoria(Subcategory sub)
    {
        subEditando = sub;
        nombreInput = sub.Name;
        esSubcategoria = true;
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        nombreInput = "";
        itemEditando = new();
        subEditando = null;
        categoriaSeleccionada = null;
    }

    private async Task GuardarItem()
    {
        if (string.IsNullOrWhiteSpace(nombreInput))
        {
            await JS.InvokeVoidAsync("alert", "❌ El nombre es obligatorio");
            return;
        }

        try
        {
            guardando = true;

            if (esSubcategoria)
            {
                // Guardar subcategoría
                if (subEditando != null)
                {
                    // Editar
                    subEditando.Name = nombreInput;
                    await Http.PutAsJsonAsync($"api/subcategories/{subEditando.Id}", subEditando);
                    await JS.InvokeVoidAsync("alert", "✅ Subcategoría actualizada");
                }
                else
                {
                    // Crear nueva
                    var nuevaSub = new Subcategory
                    {
                        Name = nombreInput,
                        CategoryId = categoriaSeleccionada!.Id
                    };
                    await Http.PostAsJsonAsync("api/subcategories", nuevaSub);
                    await JS.InvokeVoidAsync("alert", "✅ Subcategoría creada");
                }
            }
            else
            {
                // Guardar categoría
                itemEditando.Name = nombreInput;

                if (itemEditando.Id == 0)
                {
                    await Http.PostAsJsonAsync("api/categories", itemEditando);
                    await JS.InvokeVoidAsync("alert", "✅ Categoría creada");
                }
                else
                {
                    await Http.PutAsJsonAsync($"api/categories/{itemEditando.Id}", itemEditando);
                    await JS.InvokeVoidAsync("alert", "✅ Categoría actualizada");
                }
            }

            await CargarDatos();
            CerrarModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error guardando: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task EliminarCategoria(Category categoria)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar la categoría '{categoria.Name}'?\n\nEsto también eliminará todas sus subcategorías y productos asociados.");
        if (!confirmado) return;

        try
        {
            await Http.DeleteAsync($"api/categories/{categoria.Id}");
            await JS.InvokeVoidAsync("alert", "✅ Categoría eliminada");
            await CargarDatos();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
    }

    private async Task EliminarSubcategoria(Subcategory sub)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar '{sub.Name}'?");
        if (!confirmado) return;

        try
        {
            await Http.DeleteAsync($"api/subcategories/{sub.Id}");
            await JS.InvokeVoidAsync("alert", "✅ Subcategoría eliminada");
            await CargarDatos();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
    }
}
