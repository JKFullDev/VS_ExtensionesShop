@page "/admin/categorias"
@layout ExtensionesShop.Client.Layouts.AdminLayout
@using ExtensionesShop.Shared.Models
@inject HttpClient Http
@inject IJSRuntime JS

<div class="page-header">
    <div class="section-inner">
        <div class="breadcrumb">
            <a href="/" class="breadcrumb-link">Inicio</a>
            <span class="breadcrumb-separator">→</span>
            <a href="/admin" class="breadcrumb-link">Admin</a>
            <span class="breadcrumb-separator">→</span>
            <span class="breadcrumb-current">Categorías</span>
        </div>

        <div class="header-content-flex" style="display: flex; flex-direction:column; gap:20px; justify-content: space-between; align-items: center;">
            <div>
                <h1 class="page-title">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect>
                    </svg>
                    Estructura de Categorías
                </h1>
                <p class="page-subtitle">Organiza los menús y subcategorías de la tienda</p>
            </div>

            <button class="btn-primary" @onclick="() => MostrarModal(null, false)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Nueva Categoría
            </button>
        </div>
    </div>
</div>

<div class="section-inner">
    
    <!-- BARRA DE BÚSQUEDA -->
    <div class="search-section">
        <input type="text" 
               placeholder="🔍 Buscar categoría o subcategoría..." 
               value="@filtroSearch"
               @oninput="@((ChangeEventArgs e) => { filtroSearch = e.Value?.ToString() ?? ""; _debounceTimer?.Dispose(); _debounceTimer = new System.Timers.Timer(300); _debounceTimer.Elapsed += (s, ea) => { _ = AplicarFiltro(); _debounceTimer.Stop(); }; _debounceTimer.Start(); })"
               class="search-input-cat" />
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner">✦</div>
            <p>Cargando categorías...</p>
        </div>
    }
    else if (categoriasFiltradas.Any())
    {
        <div class="categorias-list">
            @foreach (var categoria in categoriasFiltradas)
            {
                var isExpanded = categoriasExpandidas.Contains(categoria.Id);
                
                <div class="categoria-panel">
                    <div class="categoria-panel-header" @onclick="() => ToggleCategoria(categoria.Id)">
                        <div class="expand-icon" style="transform: @(isExpanded ? "rotate(90deg)" : "rotate(0deg)");">
                            ▶
                        </div>
                        <h3>@categoria.Name</h3>
                        <span class="subcategory-count">
                            @if (categoria.Subcategories?.Any() == true)
                            {
                                <span>(@categoria.Subcategories.Count)</span>
                            }
                            else
                            {
                                <span>(sin subcategorías)</span>
                            }
                        </span>
                        
                        <div class="panel-actions" @onclick:stopPropagation="true">
                            <button class="btn-icon-small" @onclick="() => MostrarModal(categoria, false)" title="Editar">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </button>
                            <button class="btn-icon-small btn-add-sub" @onclick="() => MostrarModal(categoria, true)" title="Agregar subcategoría">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                            </button>
                            <button class="btn-icon-small btn-delete" @onclick="() => EliminarCategoria(categoria)" title="Eliminar">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                    
                    @if (isExpanded && categoria.Subcategories?.Any() == true)
                    {
                        <div class="categoria-panel-content">
                            <ul class="subcategories-tree">
                                @foreach (var sub in categoria.Subcategories)
                                {
                                    <li class="subcategory-item">
                                        <div class="subcategory-item-content">
                                            <span class="sub-name">@sub.Name</span>
                                            <div class="sub-actions">
                                                <button class="btn-icon-tiny" @onclick="() => EditarSubcategoria(sub)" title="Editar">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                                    </svg>
                                                </button>
                                                <button class="btn-icon-tiny btn-delete" @onclick="() => EliminarSubcategoria(sub)" title="Eliminar">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <polyline points="3 6 5 6 21 6"></polyline>
                                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                    </svg>
                                                </button>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state-cat">
            <p>No hay categorías que coincidan con tu búsqueda.</p>
        </div>
    }
</div>

<!-- Modal -->
@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(esSubcategoria ? "Nueva Subcategoría" : itemEditando?.Id == 0 ? "Nueva Categoría" : "Editar Categoría")</h3>
                <button class="btn-close" @onclick="CerrarModal">✕</button>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label>Nombre *</label>
                    <input type="text" @bind="nombreInput" class="form-control" placeholder="Nombre..." />
                </div>

                @if (esSubcategoria)
                {
                    <div class="form-group">
                        <label>Categoría Padre</label>
                        <input type="text" value="@categoriaSeleccionada?.Name" class="form-control" disabled />
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-secondary" @onclick="CerrarModal">Cancelar</button>
                <button type="button" class="btn-primary" @onclick="GuardarItem" disabled="@guardando">
                    @if (guardando)
                    {
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span>Guardar</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<style>
    /* Page Header - Heredado del estilo global */
    .page-header {
        background: linear-gradient(to bottom, var(--rose-pale), var(--white));
        padding: 36px 0 40px;
        text-align: center;
        margin: -32px -32px 32px -32px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 600;
        color: var(--ink);
        margin: 0 0 8px 0;
        display: flex;
        align-items: center;
        gap: 12px;
        justify-content: center;
    }

    .page-subtitle {
        color: #64748B;
        font-size: 14px;
        margin: 0;
    }

    .breadcrumb {
        margin-bottom: 16px;
        font-size: 13px;
    }

    .breadcrumb-link {
        color: var(--rose);
        text-decoration: none;
        font-weight: 500;
    }

    .breadcrumb-separator {
        color: #CBD5E1;
        margin: 0 6px;
    }

    .breadcrumb-current {
        color: #64748B;
    }

    .loading-state {
        text-align: center;
        padding: 80px 20px;
    }

    .spinner {
        font-size: 48px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* BÚSQUEDA */
    .search-section {
        margin-bottom: 24px;
    }

    .search-input-cat {
        width: 100%;
        padding: 14px 18px;
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        font-size: 15px;
        font-family: inherit;
        transition: all .2s;
    }

    .search-input-cat:focus {
        outline: none;
        border-color: var(--rose);
        box-shadow: 0 0 0 3px rgba(214, 70, 112, 0.1);
    }

    /* LISTA DE CATEGORÍAS CON PANELES */
    .categorias-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .categoria-panel {
        background: white;
        border: 1px solid #E2E8F0;
        border-radius: 10px;
        overflow: hidden;
        transition: all .3s ease;
    }

    .categoria-panel:hover {
        border-color: var(--rose);
        box-shadow: 0 4px 12px rgba(214, 70, 112, 0.08);
    }

    .categoria-panel-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 18px;
        cursor: pointer;
        user-select: none;
        background: #F8FAFC;
        border-bottom: 1px solid #E2E8F0;
        transition: background .2s;
    }

    .categoria-panel-header:hover {
        background: #F1F5F9;
    }

    .expand-icon {
        flex-shrink: 0;
        font-size: 12px;
        color: var(--rose);
        transition: transform .2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 20px;
    }

    .categoria-panel-header h3 {
        flex: 1;
        margin: 0;
        font-size: 18px;
        font-weight: 600;
        color: var(--ink);
    }

    .subcategory-count {
        color: #94A3B8;
        font-size: 14px;
        font-weight: 500;
        padding: 4px 12px;
        background: #F1F5F9;
        border-radius: 12px;
        white-space: nowrap;
    }

    .panel-actions {
        display: flex;
        gap: 8px;
        margin-left: 8px;
    }

    .categoria-panel-content {
        padding: 16px;
        background: #FAFBFC;
        animation: slideDown .2s ease;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            max-height: 0;
        }
        to {
            opacity: 1;
            max-height: 1000px;
        }
    }

    /* ÁRBOL DE SUBCATEGORÍAS */
    .subcategories-tree {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .subcategory-item {
        margin-bottom: 0;
    }

    .subcategory-item-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px;
        margin-bottom: 6px;
        background: white;
        border: 1px solid #E2E8F0;
        border-radius: 6px;
        transition: all .2s;
    }

    .subcategory-item-content:hover {
        border-color: var(--rose);
        background: #FFF5F7;
    }

    .sub-name {
        flex: 1;
        color: var(--ink);
        font-weight: 500;
        font-size: 14px;
    }

    .sub-actions {
        display: flex;
        gap: 6px;
        margin-left: 8px;
    }

    /* BOTONES PEQUEÑOS */
    .btn-icon-small {
        padding: 6px;
        border: none;
        background: #F1F5F9;
        color: #475569;
        border-radius: 5px;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-icon-small:hover {
        background: var(--rose);
        color: white;
    }

    .btn-icon-small.btn-add-sub:hover {
        background: #10B981;
    }

    .btn-icon-small.btn-delete:hover {
        background: #DC2626;
    }

    .btn-icon-tiny {
        padding: 4px;
        border: none;
        background: transparent;
        color: #94A3B8;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-icon-tiny:hover {
        color: var(--rose);
    }

    .btn-icon-tiny.btn-delete:hover {
        color: #DC2626;
    }

    /* ESTADO VACÍO */
    .empty-state-cat {
        text-align: center;
        padding: 60px 20px;
        background: #F8FAFC;
        border-radius: 10px;
        border: 1px dashed #E2E8F0;
    }

    .empty-state-cat p {
        margin: 0;
        color: #94A3B8;
        font-size: 15px;
    }

    /* MODAL */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        max-width: 500px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px;
        border-bottom: 1px solid #E2E8F0;
    }

    .modal-header h3 {
        margin: 0;
        font-size: 20px;
        font-weight: 600;
        color: var(--ink);
    }

    .btn-close {
        border: none;
        background: transparent;
        color: #94A3B8;
        padding: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-close:hover {
        color: var(--ink);
    }

    .modal-body {
        padding: 24px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        font-size: 14px;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--rose);
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid #E2E8F0;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .btn-secondary {
        background: #E2E8F0;
        color: var(--ink);
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
        transition: all .2s;
    }

    .btn-secondary:hover {
        background: #CBD5E1;
    }

    .btn-primary {
        background: var(--rose);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
        transition: all .2s;
    }

    .btn-primary:hover:not(:disabled) {
        background: #DC2626;
    }

    .btn-primary:disabled {
        background: #F87171;
        cursor: not-allowed;
    }
</style>

@code {
    private List<Category> categorias = new();
    private List<Category> categoriasFiltradas = new();
    private HashSet<int> categoriasExpandidas = new();
    private string filtroSearch = "";
    private bool isLoading = true;
    private bool mostrarModal = false;
    private bool esSubcategoria = false;
    private bool guardando = false;
    private Category? categoriaSeleccionada;
    private Category itemEditando = new();
    private Subcategory? subEditando;
    private string nombreInput = "";
    private System.Timers.Timer _debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading = true;
            categorias = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
            await AplicarFiltro();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando categorías: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AplicarFiltro()
    {
        if (string.IsNullOrWhiteSpace(filtroSearch))
        {
            categoriasFiltradas = categorias.ToList();
        }
        else
        {
            var searchLower = filtroSearch.ToLower();
            categoriasFiltradas = categorias.Where(c =>
                c.Name.ToLower().Contains(searchLower) ||
                (c.Subcategories?.Any(s => s.Name.ToLower().Contains(searchLower)) == true)
            ).ToList();

            foreach (var cat in categoriasFiltradas)
            {
                if (cat.Subcategories?.Any(s => s.Name.ToLower().Contains(searchLower)) == true)
                {
                    categoriasExpandidas.Add(cat.Id);
                }
            }
        }
        
        StateHasChanged();
        await Task.CompletedTask;
    }

    private void ToggleCategoria(int categoriaId)
    {
        if (categoriasExpandidas.Contains(categoriaId))
        {
            categoriasExpandidas.Remove(categoriaId);
        }
        else
        {
            categoriasExpandidas.Add(categoriaId);
        }
        StateHasChanged();
    }

    private void MostrarModal(Category? categoria, bool esSubcat)
    {
        esSubcategoria = esSubcat;
        categoriaSeleccionada = categoria;
        nombreInput = "";

        if (!esSubcat)
        {
            itemEditando = categoria ?? new Category();
            nombreInput = itemEditando.Name;
        }

        mostrarModal = true;
    }

    private void EditarSubcategoria(Subcategory sub)
    {
        subEditando = sub;
        nombreInput = sub.Name;
        esSubcategoria = true;
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        nombreInput = "";
        itemEditando = new();
        subEditando = null;
        categoriaSeleccionada = null;
    }

    private async Task GuardarItem()
    {
        if (string.IsNullOrWhiteSpace(nombreInput))
        {
            await JS.InvokeVoidAsync("alert", "El nombre es obligatorio");
            return;
        }

        try
        {
            guardando = true;

            if (esSubcategoria)
            {
                if (subEditando?.Id > 0)
                {
                    subEditando.Name = nombreInput;
                    await Http.PutAsJsonAsync($"api/subcategories/{subEditando.Id}", subEditando);
                }
                else
                {
                    var newSub = new Subcategory { Name = nombreInput, CategoryId = categoriaSeleccionada?.Id ?? 0 };
                    await Http.PostAsJsonAsync("api/subcategories", newSub);
                }
            }
            else
            {
                if (itemEditando.Id > 0)
                {
                    itemEditando.Name = nombreInput;
                    await Http.PutAsJsonAsync($"api/categories/{itemEditando.Id}", itemEditando);
                }
                else
                {
                    var newCat = new Category { Name = nombreInput };
                    await Http.PostAsJsonAsync("api/categories", newCat);
                }
            }

            CerrarModal();
            await CargarDatos();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task EliminarCategoria(Category categoria)
    {
        bool confirma = await JS.InvokeAsync<bool>("confirm", "¿Eliminar categoría?");
        if (!confirma)
            return;

        try
        {
            await Http.DeleteAsync($"api/categories/{categoria.Id}");
            await CargarDatos();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task EliminarSubcategoria(Subcategory subcategoria)
    {
        bool confirma = await JS.InvokeAsync<bool>("confirm", "¿Eliminar subcategoría?");
        if (!confirma)
            return;

        try
        {
            await Http.DeleteAsync($"api/subcategories/{subcategoria.Id}");
            await CargarDatos();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}
