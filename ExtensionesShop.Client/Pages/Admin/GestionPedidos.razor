@page "/admin/pedidos"
@attribute [Authorize(Roles = "Admin")]
@layout ExtensionesShop.Client.Layouts.AdminLayout
@using ExtensionesShop.Shared.Models
@using ExtensionesShop.Client.Services
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager Navigation


<PageTitle>Gestión de Pedidos - Admin</PageTitle>

    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <a href="/admin" class="breadcrumb-link">Admin</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Pedidos</span>
            </div>
            <h1 class="page-title">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <path d="M16 10a4 4 0 0 1-8 0"></path>
                </svg>
                Gestión de Pedidos
            </h1>
            <p class="page-subtitle">Administra el estado y seguimiento de todas las ventas</p>
        </div>
    </div>

    <div class="section-inner">
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner">✦</div>
                <p>Cargando pedidos...</p>
            </div>
        }
        else if (!pedidos.Any())
        {
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                </svg>
                <p>No hay pedidos registrados</p>
            </div>
        }
        else
        {
                <!-- Filtros -->
                <div class="filtros-section">
                    <label>
                        Filtrar por estado:
                        <select @onchange="FiltrarPorEstado" class="filtro-select">
                            <option value="-1">Todos</option>
                            <option value="0">Pendientes</option>
                            <option value="1">Confirmados</option>
                            <option value="2">En Proceso</option>
                            <option value="3">Enviados</option>
                            <option value="4">Entregados</option>
                            <option value="5">Cancelados</option>
                        </select>
                    </label>
                </div>

                <!-- Tabla de pedidos -->
                <div class="pedidos-table-container">
                    <table class="pedidos-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Cliente</th>
                                <th>Email</th>
                                <th>Teléfono</th>
                                <th>Total</th>
                                <th>Fecha</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pedido in pedidosFiltrados)
                            {
                                <tr>
                                    <td><strong>#@pedido.Id</strong></td>
                                    <td>@pedido.CustomerName</td>
                                    <td>
                                        <a href="mailto:@pedido.CustomerEmail">@pedido.CustomerEmail</a>
                                    </td>
                                    <td>
                                        <a href="tel:@pedido.CustomerPhone">@pedido.CustomerPhone</a>
                                    </td>
                                    <td><strong>@pedido.Total.ToString("N2")€</strong></td>
                                    <td>@pedido.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="status-badge @GetStatusClass(pedido.Status)">
                                            @GetStatusText(pedido.Status)
                                        </span>
                                    </td>
                                    <td>
                                        <div class="acciones-cell">
                                            <select class="estado-select" 
                                                    value="@pedido.Status"
                                                    @onchange="@(e => CambiarEstado(pedido.Id, int.Parse(e.Value?.ToString() ?? "0")))">
                                                <option value="0">Pendiente</option>
                                                <option value="1">Confirmado</option>
                                                <option value="2">En Proceso</option>
                                                <option value="3">Enviado</option>
                                                <option value="4">Entregado</option>
                                                <option value="5">Cancelado</option>
                                            </select>
                                            <button class="btn-detalle" @onclick="() => VerDetalle(pedido.Id)">
                                                👁️ Ver
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    <!-- Modal de detalle mejorado -->
    @if (pedidoSeleccionado != null)
    {
        <div class="modal-overlay" @onclick="CerrarDetalle">
            <div class="modal-content-detail" @onclick:stopPropagation="true">
                <div class="modal-header-detail">
                    <div>
                        <h2>Pedido <span class="order-number">#@pedidoSeleccionado.Id</span></h2>
                        <p class="order-date">@pedidoSeleccionado.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</p>
                    </div>
                    <button class="btn-close-detail" @onclick="CerrarDetalle">✕</button>
                </div>

                <!-- Contenido en dos columnas -->
                <div class="modal-body-detail">
                    <!-- Columna izquierda: Información del cliente -->
                    <div class="detail-section-left">
                        <div class="customer-card">
                            <h3>📋 Información del Cliente</h3>
                            <div class="customer-info">
                                <div class="info-row">
                                    <label>Nombre:</label>
                                    <span>@pedidoSeleccionado.CustomerName</span>
                                </div>
                                <div class="info-row">
                                    <label>Email:</label>
                                    <a href="mailto:@pedidoSeleccionado.CustomerEmail">@pedidoSeleccionado.CustomerEmail</a>
                                </div>
                                <div class="info-row">
                                    <label>Teléfono:</label>
                                    <a href="tel:@pedidoSeleccionado.CustomerPhone">@pedidoSeleccionado.CustomerPhone</a>
                                </div>
                            </div>
                        </div>

                        <div class="shipping-card">
                            <h3>🚚 Dirección de Envío</h3>
                            <div class="shipping-info">
                                <p>@pedidoSeleccionado.ShippingAddress</p>
                                <p>@pedidoSeleccionado.PostalCode, @pedidoSeleccionado.City</p>
                                @if (!string.IsNullOrEmpty(pedidoSeleccionado.Province))
                                {
                                    <p>@pedidoSeleccionado.Province</p>
                                }
                            </div>
                        </div>

                        <div class="status-card">
                            <h3>Estado del Pedido</h3>
                            <span class="status-badge-large @GetStatusClass(pedidoSeleccionado.Status)">
                                @GetStatusText(pedidoSeleccionado.Status)
                            </span>
                        </div>

                        @if (!string.IsNullOrEmpty(pedidoSeleccionado.Notes))
                        {
                            <div class="notes-card">
                                <h3>📝 Notas</h3>
                                <p>@pedidoSeleccionado.Notes</p>
                            </div>
                        }
                    </div>

                    <!-- Separador visual -->
                    <div class="detail-divider"></div>

                    <!-- Columna derecha: Productos -->
                    <div class="detail-section-right">
                        <h3>📦 Productos Pedidos</h3>
                        <div class="products-table-container">
                            @if (pedidoSeleccionado.OrderItems != null && pedidoSeleccionado.OrderItems.Any())
                            {
                                <table class="products-detail-table">
                                    <thead>
                                        <tr>
                                            <th>Imagen</th>
                                            <th>Producto</th>
                                            <th>Variante</th>
                                            <th>Cantidad</th>
                                            <th>Precio</th>
                                            <th>Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in pedidoSeleccionado.OrderItems)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="product-image-cell">
@if (!string.IsNullOrEmpty(item.Product?.ImageUrl)) {
    <img src="@item.Product.ImageUrl" alt="@item.ProductName" class="product-thumbnail" />
} else if (item.Product?.Images?.Any() == true) {
    <img src="@item.Product.Images.First().ImageUrl" alt="@item.ProductName" class="product-thumbnail" />
} else {
    <div class="product-no-image">Sin imagen</div>
}
                                                    </div>
                                                </td>
                                                <td><strong>@item.ProductName</strong></td>
                                                <td>
                                                    <div class="variant-info">
                                                        @if (!string.IsNullOrEmpty(item.SelectedColor))
                                                        {
                                                            <span class="variant-badge color">@item.SelectedColor</span>
                                                        }
                                                        @if (item.SelectedCentimeters.HasValue)
                                                        {
                                                            <span class="variant-badge length">@item.SelectedCentimeters cm</span>
                                                        }
                                                        @if (string.IsNullOrEmpty(item.SelectedColor) && !item.SelectedCentimeters.HasValue)
                                                        {
                                                            <span class="variant-badge none">Sin variante</span>
                                                        }
                                                    </div>
                                                </td>
                                                <td>@item.Quantity</td>
                                                <td>@item.UnitPrice.ToString("N2")€</td>
                                                <td><strong>@(item.UnitPrice * item.Quantity).ToString("N2")€</strong></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>

                                <!-- Resumen de totales -->
                                <div class="totals-summary">
                                    <div class="total-row">
                                        <span>Subtotal:</span>
                                        <span>@pedidoSeleccionado.Subtotal.ToString("N2")€</span>
                                    </div>
                                    <div class="total-row">
                                        <span>Envío:</span>
                                        <span>@pedidoSeleccionado.ShippingCost.ToString("N2")€</span>
                                    </div>
                                    <div class="total-row grand-total">
                                        <span>Total:</span>
                                        <span>@pedidoSeleccionado.Total.ToString("N2")€</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <p class="empty-items">No hay productos en este pedido</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

<style>
    /* Page Header - Heredado del estilo global */
    .page-header {
        background: linear-gradient(to bottom, var(--rose-pale), var(--white));
        padding: 36px 0 40px;
        text-align: center;
        margin: -32px -32px 32px -32px;
    }

    .admin-pedidos-page {
        padding: 40px 0;
        min-height: 100vh;
    }

    .loading-state {
        text-align: center;
        padding: 60px;
    }

    .spinner {
        font-size: 48px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .filtros-section {
        margin-bottom: 24px;
        padding: 16px;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
    }

    .filtro-select {
        margin-left: 12px;
        padding: 8px 16px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
    }

    .pedidos-table-container {
        overflow-x: auto;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
    }

    .pedidos-table {
        width: 100%;
        border-collapse: collapse;
    }

    .pedidos-table th {
        background: var(--rose);
        color: white;
        padding: 16px;
        text-align: left;
        font-weight: 600;
        font-size: 14px;
    }

    .pedidos-table td {
        padding: 16px;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
    }

    .pedidos-table tr:hover {
        background: var(--off-white);
    }

    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .status-pending { background: #FFF3CD; color: #856404; }
    .status-confirmed { background: #D1ECF1; color: #0C5460; }
    .status-processing { background: #D1ECF1; color: #0C5460; }
    .status-shipped { background: #D4EDDA; color: #155724; }
    .status-delivered { background: #D4EDDA; color: #155724; }
    .status-cancelled { background: #F8D7DA; color: #721C24; }

    .acciones-cell {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .estado-select {
        padding: 6px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 13px;
        background: white;
        cursor: pointer;
    }

    .btn-detalle {
        padding: 6px 12px;
        background: var(--rose);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
    }

    .btn-detalle:hover {
        background: #C53A5A;
    }

    /* Modal Mejorado */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(2px);
    }

    .modal-content-detail {
        background: white;
        border-radius: 20px;
        max-width: 1000px;
        width: 95%;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        display: flex;
        flex-direction: column;
    }

    .modal-header-detail {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 32px;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(to bottom, var(--rose-pale), var(--white));
    }

    .modal-header-detail h2 {
        margin: 0;
        font-size: 24px;
        color: var(--ink);
    }

    .order-number {
        color: var(--rose);
        font-weight: 700;
    }

    .order-date {
        margin: 8px 0 0 0;
        font-size: 14px;
        color: var(--muted);
    }

    .btn-close-detail {
        background: none;
        border: none;
        font-size: 28px;
        cursor: pointer;
        color: var(--muted);
        padding: 0;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .btn-close-detail:hover {
        background: rgba(0, 0, 0, 0.05);
        color: var(--ink);
    }

    .modal-body-detail {
        display: grid;
        grid-template-columns: 1fr auto 1.2fr;
        gap: 32px;
        padding: 32px;
        overflow-y: auto;
    }

    /* Sección izquierda: Cliente */
    .detail-section-left {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .customer-card,
    .shipping-card,
    .status-card,
    .notes-card {
        background: var(--off-white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
    }

    .customer-card h3,
    .shipping-card h3,
    .status-card h3,
    .notes-card h3 {
        margin: 0 0 16px 0;
        font-size: 16px;
        font-weight: 600;
        color: var(--ink);
    }

    .customer-info {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
    }

    .info-row label {
        font-weight: 600;
        color: var(--muted);
        min-width: 80px;
    }

    .info-row span,
    .info-row a {
        color: var(--ink);
        word-break: break-word;
    }

    .info-row a {
        color: var(--rose);
        text-decoration: none;
    }

    .info-row a:hover {
        text-decoration: underline;
    }

    .shipping-info {
        font-size: 14px;
        line-height: 1.6;
        color: var(--ink);
    }

    .shipping-info p {
        margin: 0;
    }

    .status-badge-large {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .notes-card p {
        margin: 0;
        color: var(--ink);
        line-height: 1.6;
    }

    /* Separador visual */
    .detail-divider {
        width: 1px;
        background: linear-gradient(180deg, transparent 0%, var(--border) 50%, transparent 100%);
    }

    /* Sección derecha: Productos */
    .detail-section-right {
        flex: 1;
    }

    .detail-section-right h3 {
        margin: 0 0 20px 0;
        font-size: 16px;
        font-weight: 600;
        color: var(--ink);
    }

    .products-table-container {
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        background: white;
    }

    .products-detail-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    .products-detail-table thead {
        background: var(--rose-pale);
        border-bottom: 2px solid var(--border);
    }

    .products-detail-table th {
        padding: 14px;
        text-align: left;
        font-weight: 600;
        color: var(--ink);
    }

    .products-detail-table td {
        padding: 14px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
    }

    .products-detail-table tbody tr:last-child td {
        border-bottom: none;
    }

    .products-detail-table tbody tr:hover {
        background: var(--off-white);
    }

    .product-image-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 60px;
        height: 60px;
    }

    .product-thumbnail {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 8px;
    }

    .product-no-image {
        width: 60px;
        height: 60px;
        background: var(--off-white);
        border: 1px dashed var(--border);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        color: var(--muted);
        text-align: center;
        padding: 4px;
    }

    .variant-info {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .variant-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

    .variant-badge.color {
        background: rgba(212, 70, 112, 0.1);
        color: var(--rose);
        border: 1px solid rgba(212, 70, 112, 0.2);
    }

    .variant-badge.length {
        background: rgba(79, 172, 254, 0.1);
        color: #4FACE;
        border: 1px solid rgba(79, 172, 254, 0.2);
    }

    .variant-badge.none {
        background: var(--off-white);
        color: var(--muted);
        border: 1px solid var(--border);
    }

    /* Resumen de totales */
    .totals-summary {
        padding: 20px;
        background: var(--off-white);
        border-top: 1px solid var(--border);
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        font-size: 14px;
    }

    .total-row span:first-child {
        font-weight: 500;
        color: var(--muted);
    }

    .total-row span:last-child {
        font-weight: 600;
        color: var(--ink);
    }

    .total-row.grand-total {
        border-top: 2px solid var(--border);
        padding-top: 14px;
        margin-top: 6px;
        font-size: 16px;
    }

    .total-row.grand-total span:first-child {
        color: var(--ink);
        font-weight: 700;
    }

    .total-row.grand-total span:last-child {
        color: var(--rose);
        font-size: 18px;
    }

    .empty-items {
        padding: 40px 20px;
        text-align: center;
        color: var(--muted);
        font-style: italic;
    }
</style>

@code {
    private List<Order> pedidos = new();
    private List<Order> pedidosFiltrados = new();
    private bool isLoading = true;
    private Order? pedidoSeleccionado;
    private int filtroEstado = -1;

    protected override async Task OnInitializedAsync()
    {
        // TODO: Agregar verificación de admin
        // if (!AuthService.IsAdmin) { Navigation.NavigateTo("/"); return; }

        await CargarPedidos();
    }

    private async Task CargarPedidos()
    {
        try
        {
            isLoading = true;
            pedidos = await Http.GetFromJsonAsync<List<Order>>("api/orders") ?? new();
            pedidosFiltrados = pedidos;
            Console.WriteLine($"✅ Pedidos cargados: {pedidos.Count}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error cargando pedidos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FiltrarPorEstado(ChangeEventArgs e)
    {
        filtroEstado = int.Parse(e.Value?.ToString() ?? "-1");
        
        if (filtroEstado == -1)
        {
            pedidosFiltrados = pedidos;
        }
        else
        {
            pedidosFiltrados = pedidos.Where(p => p.Status == filtroEstado).ToList();
        }
    }

    private async Task CambiarEstado(int pedidoId, int nuevoEstado)
    {
        try
        {
            Console.WriteLine($"🔄 Cambiando estado del pedido {pedidoId} a {nuevoEstado}");
            
            var response = await Http.PutAsJsonAsync($"api/orders/{pedidoId}/status", new { Status = nuevoEstado });
            
            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine("✅ Estado actualizado correctamente");
                await CargarPedidos(); // Recargar para ver cambios
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Error al actualizar estado: {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error: {ex.Message}");
        }
    }

    private void VerDetalle(int pedidoId)
    {
        pedidoSeleccionado = pedidos.FirstOrDefault(p => p.Id == pedidoId);
    }

    private void CerrarDetalle()
    {
        pedidoSeleccionado = null;
    }

    private string GetStatusText(int status)
    {
        return status switch
        {
            0 => "Pendiente",
            1 => "Confirmado",
            2 => "En Proceso",
            3 => "Enviado",
            4 => "Entregado",
            5 => "Cancelado",
            _ => "Desconocido"
        };
    }

    private string GetStatusClass(int status)
    {
        return status switch
        {
            0 => "status-pending",
            1 => "status-confirmed",
            2 => "status-processing",
            3 => "status-shipped",
            4 => "status-delivered",
            5 => "status-cancelled",
            _ => "status-pending"
        };
    }
}
