@page "/admin/productos"
@attribute [Authorize(Roles = "Admin")]
@layout ExtensionesShop.Client.Layouts.AdminLayout
@using ExtensionesShop.Shared.Models
@using ExtensionesShop.Client.Components
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="page-header">
    <div class="section-inner">
        <div class="breadcrumb">
            <a href="/" class="breadcrumb-link">Inicio</a>
            <span class="breadcrumb-separator">→</span>
            <a href="/admin" class="breadcrumb-link">Admin</a>
            <span class="breadcrumb-separator">→</span>
            <span class="breadcrumb-current">Productos</span>
        </div>
        
        <div class="header-content-flex">
            <div>
                <h1 class="page-title">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                        <line x1="7" y1="7" x2="7.01" y2="7"></line>
                    </svg>
                    Catálogo de Productos
                </h1>
                @* <p class="page-subtitle">Estrategia: 1 Producto = 1 Color. Variantes por Longitud. (@productos.Count total)</p> *@
            </div>
            
            @if (vistaActual == "lista")
            {
                <button class="btn-primary" @onclick="() => MostrarFormulario(null)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Nuevo Producto
                </button>
            }
        </div>
    </div>
</div>

<div class="section-inner">
    @if (vistaActual == "lista")
    {
        <!-- BARRA DE BÚSQUEDA Y FILTROS -->
        <div class="search-bar-container">
            <!-- ✅ NUEVO: Checkbox para mostrar inactivos -->
            <div style="margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                <input type="checkbox" 
                       id="chkMostrarInactivos"
                       checked="@mostrarInactivos"
                       @onchange="@HandleMostrarInactivosChanged"
                       style="width: 18px; height: 18px; cursor: pointer;" />
                <label for="chkMostrarInactivos" style="cursor: pointer; user-select: none; font-weight: 500; color: #475569;">
                    Ver productos desactivados
                </label>
            </div>

           <div class="search-inputs">
               <input type="text" 
                      placeholder="🔍 Buscar por nombre, color o descripción..." 
                      value="@filtroSearch"
                      @oninput="@((ChangeEventArgs e) => { filtroSearch = e.Value?.ToString() ?? ""; })"
                      class="search-input" />

               <select value="@filtroCategoria" 
                       @onchange="@((ChangeEventArgs e) => { filtroCategoria = e.Value?.ToString() ?? ""; })"
                       class="filter-select">
                   <option value="">Todas las categorías</option>
                   @foreach (var cat in categorias)
                   {
                       <option value="@cat.Id">@cat.Name</option>
                   }
               </select>
           </div>
        </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner">✦</div>
                <p>Cargando productos...</p>
            </div>
        }
        else
        {
            <div class="table-card">
                <div class="table-wrapper">
                    <table class="data-table">
                        <thead class="table-header-fixed">
                            <tr>
                                <th class="col-thumb">Imagen</th>
                                <th class="col-id">ID</th>
                                <th class="col-name">Nombre / Color</th>
                                <th class="col-category">Categoría</th>
                                <th class="col-price">Precio</th>
                                <th class="col-stock">Stock</th>
                                <th class="col-variants">Tallas</th>
                                <th class="col-actions">Acciones</th>
                            </tr>
                        </thead>
                        @if (productosFiltrados.Any())
                        {
                            <tbody>
                                @foreach (var producto in productosFiltrados.Skip((paginaActual - 1) * productosPorPagina).Take(productosPorPagina))
                                {
                                    <!-- ✅ NUEVO: Agregar clase si producto está inactivo -->
                                    <tr class="@(producto.IsActive == false ? "product-inactive" : "")">
                                        <td class="col-thumb">
                                            <img src="@(producto.ImageUrl ?? "/images/placeholder.jpg")" alt="@producto.Name" class="producto-thumb" />
                                        </td>
                                        <td class="col-id"><strong>#@producto.Id</strong></td>
                                        <td class="col-name">
                                            <div class="product-info">
                                                <strong>@producto.Name</strong>
                                                @if (!string.IsNullOrEmpty(producto.Color))
                                                {
                                                    <small>@producto.Color</small>
                                                }
                                                @if (producto.IsActive == false)
                                                {
                                                    <span style="color: #DC2626; font-weight: 600; font-size: 11px; margin-left: 8px;">❌ DESACTIVADO</span>
                                                }
                                            </div>
                                        </td>
                                        <td class="col-category">@producto.Category?.Name</td>
                                        <td class="col-price"><strong>@producto.Price.ToString("N2")€</strong></td>
                                        <td class="col-stock">
                                            <span class="stock-badge @(producto.Stock < 10 ? "low-stock" : "")">
                                                @producto.Stock
                                            </span>
                                        </td>
                                        <td class="col-variants">
                                            <span class="variant-count">@(producto.Variants?.Count ?? 0)</span>
                                        </td>
                                        <td class="col-actions">
                                            <div class="action-buttons">
                                                <button class="btn-icon" @onclick="() => MostrarFormulario(producto)" title="Editar">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                                    </svg>
                                                </button>
                                                <button class="btn-icon btn-duplicate" @onclick="() => DuplicarProducto(producto)" title="Duplicar">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
                                                        <rect x="8" y="2" width="8" height="4"></rect>
                                                    </svg>
                                                </button>
                                                <!-- ✅ NUEVO: Mostrar botón de Reactivar si está inactivo, Eliminar si está activo -->
                                                @if (producto.IsActive == false)
                                                {
                                                    <button class="btn-icon btn-reactivate" @onclick="() => ReactivarProducto(producto)" @onclick:stopPropagation="true" title="Reactivar">
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <path d="M23 4v6h-6"/>
                                                            <path d="M1 20v-6h6"/>
                                                            <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
                                                        </svg>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn-icon btn-delete" @onclick="() => EliminarProducto(producto)" @onclick:stopPropagation="true" title="Eliminar">
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <polyline points="3 6 5 6 21 6"></polyline>
                                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                        </svg>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        }
                        else
                        {
                            <tbody>
                                <tr>
                                    <td colspan="8" style="padding: 40px; text-align: center; color: #94A3B8;">
                                        No hay productos que coincidan con tu búsqueda.
                                    </td>
                                </tr>
                            </tbody>
                        }
                    </table>

                    @if (productosFiltrados.Any())
                    {
                        <div class="pagination-controls">
                            <button class="btn-pagination" 
                                    @onclick="() => PaginaAnterior()" 
                                    disabled="@(paginaActual <= 1)">
                                ← Anterior
                            </button>

                            <div class="pagination-info">
                                Página @paginaActual de @((int)Math.Ceiling((double)productosFiltrados.Count() / productosPorPagina))
                                <span class="pagination-results">(@productosFiltrados.Count() productos encontrados)</span>
                            </div>

                            <button class="btn-pagination" 
                                    @onclick="() => PaginaSiguiente()" 
                                    disabled="@(paginaActual >= Math.Ceiling((double)productosFiltrados.Count() / productosPorPagina))">
                                Siguiente →
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    }
    
    else
    {
        <!-- VISTA FORMULARIO: UN PRODUCTO = UN COLOR -->
        <div class="form-header">
            <button class="btn-back" @onclick="VolverALista">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Volver
            </button>
            <h2>@(formularioRequest.Id.HasValue ? $"Editar: {formularioRequest.Name} - {formularioRequest.Color}" : "Nuevo Producto")</h2>
        </div>

<EditForm Model="formularioRequest" class="form-card">            <!-- SECCIÓN 1: INFORMACIÓN BASE (Nombre, Color, Categoría, etc.) -->
            <div class="form-section">
                <h3 class="section-title">📦 Información Base</h3>

                <div class="form-grid">
                    <div class="form-group">
                        <label>Nombre del Producto *</label>
                        <input type="text" @bind="formularioRequest.Name" class="form-control" placeholder="Ej: Extensiones Remy" />
                        <small>Este es el nombre de la extensión (ej: Remy, Humanas, Sintéticas)</small>
                    </div>

                    <div class="form-group">
                        <label>Color / Variante *</label>
                        <input type="text" @bind="formularioRequest.Color" class="form-control" placeholder="Ej: Castaño, Rubio, Negro" />
                        <small>Cada producto = 1 color. Para otros colores, duplica este producto.</small>
                    </div>

                    <div class="form-group">
                        <label>Categoría *</label>
                        <select @bind="formularioRequest.CategoryId" @bind:after="OnCategoryChanged" class="form-control">
                            <option value="0">Seleccionar...</option>
                            @foreach (var cat in categorias)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Subcategoría</label>
                        <select @bind="formularioRequest.SubcategoryId" @bind:event="onchange" class="form-control">
                            <option value="">Ninguna</option>
                            @if (formularioRequest.CategoryId > 0 && filteredSubcategories.Any())
                            {
                                @foreach (var sub in filteredSubcategories.OrderBy(s => s.Name))
                                {
                                    <option value="@sub.Id">@sub.Name</option>
                                }
                            }
                        </select>
                        @if (formularioRequest.CategoryId == 0)
                        {
                            <small style="color: #94A3B8;">Selecciona una categoría primero</small>
                        }
                        @if (formularioRequest.CategoryId > 0 && !filteredSubcategories.Any())
                        {
                            <small style="color: #94A3B8;">No hay subcategorías para esta categoría</small>
                        }
                    </div>

                    <div class="form-group full-width">
                        <label>Descripción</label>
                        <textarea @bind="formularioRequest.Description" class="form-control" rows="3" placeholder="Descripción del producto..."></textarea>
                    </div>

                    <div class="form-group full-width">
                        <label>Imagen Principal</label>
                        <div class="main-image-container">
                            <div class="main-image-uploader">
                                <ImageUpload Label="Imagen Principal" OnImageSelected="@HandleMainImageSelected" />
                            </div>
                            @if (!string.IsNullOrEmpty(formularioRequest.ImageUrl))
                            {
                                <div class="main-image-preview">
                                    <img src="@formularioRequest.ImageUrl" alt="Preview Imagen Principal" />
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Precio Base (Se mostrará en el catálogo) *</label>
                        <input type="number" step="0.01" @bind="formularioRequest.Price" class="form-control" placeholder="0.00" />
                        <small>Precio que se muestra en el catálogo. El precio de cada variante puede ser diferente.</small>
                    </div>

                    <div class="form-group">
                        <label>Stock Total</label>
                        @if (formularioRequest.Variants.Any())
                        {
                            <input type="number" 
                                   value="@(formularioRequest.Variants.Sum(v => v.Stock))" 
                                   class="form-control" 
                                   readonly 
                                   disabled />
                            <small>Calculado automáticamente desde las variantes de este producto</small>
                        }
                        else
                        {
                            <input type="number" 
                                   @bind="formularioRequest.Stock" 
                                   class="form-control" 
                                   placeholder="Ingresa el stock disponible" 
                                   min="0" />
                            <small>Ingresa el stock manual para este producto (sin variantes)</small>
                        }
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 2: VARIANTES POR MEDIDA/TALLA (OPCIONAL) -->
            <div class="form-section">
                <div class="section-header">
                    <h3 class="section-title">
                        @if (EsProductoCapilar(formularioRequest.CategoryId))
                        {
                            <span>📏 Variantes por Longitud (cm) - Opcional</span>
                        }
                        else
                        {
                            <span>📦 Variantes / Medidas - Opcional</span>
                        }
                    </h3>
                    <button type="button" class="btn-add-variant" @onclick="AgregarVariante">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Nueva Variante
                    </button>
                </div>

                @if (formularioRequest.Variants.Any())
                {
                    <div class="variants-table-wrapper">
                        <table class="variants-table">
                            <thead>
                                <tr>
                                    <th>
                                        @if (EsProductoCapilar(formularioRequest.CategoryId))
                                        {
                                            <span>Longitud (cm)</span>
                                        }
                                        else
                                        {
                                            <span>Medida / Tipo</span>
                                        }
                                    </th>
                                    <th>Precio *</th>
                                    <th>Stock</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < formularioRequest.Variants.Count; i++)
                                {
                                    int index = i; // Capturar por valor
                                    var variante = formularioRequest.Variants[i];
                                    <tr>
                                        <td>
                                            @if (EsProductoCapilar(formularioRequest.CategoryId))
                                            {
                                                <input type="number" step="0.1" @bind="variante.Centimeters" @bind:event="oninput" class="form-control" placeholder="Ej: 60" />
                                            }
                                            else
                                            {
                                                <input type="text" @bind="variante.Color" class="form-control" placeholder="Ej: Estándar, Grande, Pequeño" />
                                            }
                                        </td>
                                        <td class="price-cell">
                                            <input type="number" step="0.01" @bind="variante.Price" @bind:event="oninput" class="form-control" placeholder="0.00" />
                                            @if (variante.Price <= 0)
                                            {
                                                <small class="error-msg">⚠️ Precio requerido</small>
                                            }
                                        </td>
                                        <td>
                                            <input type="number" @bind="variante.Stock" @bind:event="oninput" class="form-control" placeholder="0" min="0" />
                                        </td>
                                        <td class="action-cell">
                                            <button type="button" class="btn-action btn-clone" @onclick="@(() => ClonarVariante(index))" title="Clonar variante">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
                                                    <rect x="8" y="2" width="8" height="4"></rect>
                                                </svg>
                                            </button>
                                            <button type="button" class="btn-action btn-remove" @onclick="@(() => EliminarVariante(index))" title="Eliminar variante">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6"></polyline>
                                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                </svg>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <p>Sin variantes. El producto se venderá con el Precio Base. Haz clic en "Nueva Variante" para agregar opciones.</p>
                    </div>
                }
            </div>

            <!-- SECCIÓN 3: IMÁGENES ADICIONALES -->
            <div class="form-section">
                <div class="section-header">
                    <h3 class="section-title">🖼️ Imágenes Adicionales</h3>
                </div>

                <!-- COMPONENTE DE UPLOAD UNIFICADO -->
                <div style="margin-bottom: 24px;">
                    <ImageUpload Label="Agregar Imagen Adicional" OnImageSelected="@HandleAdditionalImageSelected" />
                </div>

                @if (formularioRequest.Images.Any())
                {
                    <div class="images-grid">
                        @for (int i = 0; i < formularioRequest.Images.Count; i++)
                        {
                            int index = i; // Capturar por valor para evitar closure issues
                            var imagen = formularioRequest.Images[i];
                            <div class="image-item">
                                <button type="button" class="btn-close-image" @onclick="@(() => EliminarImagen(index))" title="Eliminar imagen">
                                    ×
                                </button>

                                <div class="image-preview-box">
                                    @if (!string.IsNullOrEmpty(imagen.ImageUrl))
                                    {
                                        <img src="@imagen.ImageUrl" alt="@imagen.AltText" />
                                    }
                                    else
                                    {
                                        <div class="image-placeholder">
                                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <rect x="3" y="3" width="18" height="18"></rect>
                                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                                <polyline points="21 15 16 10 5 21"></polyline>
                                            </svg>
                                        </div>
                                    }
                                </div>

                                <div class="image-form">
                                    <input type="text" @bind="imagen.AltText" class="form-control" placeholder="Texto alt (SEO) - Recomendado" />
                                    <small style="color: #94A3B8; margin-top: 4px;">URL: @(string.IsNullOrEmpty(imagen.ImageUrl) ? "Pendiente" : imagen.ImageUrl.Substring(0, Math.Min(30, imagen.ImageUrl.Length)) + "...")</small>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <p>No hay imágenes adicionales. Usa el selector de arriba para agregar fotos del producto.</p>
                    </div>
                }
            </div>

            <!-- BOTONES DE ACCIÓN -->
            <div class="form-actions">
                <button type="button" class="btn-secondary" @onclick="VolverALista">Cancelar</button>
                <button type="button" class="btn-primary" @onclick="GuardarProducto" disabled="@guardando">
                    @if (guardando)
                    {
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span>@(formularioRequest.Id.HasValue ? "Actualizar Producto" : "Crear Producto")</span>
                    }
                </button>
            </div>
</EditForm>    }
</div>

<style>
    .page-header {
        background: linear-gradient(135deg, var(--rose-pale) 0%, var(--white) 100%);
        padding: 56px 0 64px;
        text-align: center;
        margin: -32px -32px 32px -32px;
        border-bottom: 4px solid var(--rose);
        position: relative;
        overflow: hidden;
    }

    .page-header::before {
        content: '';
        position: absolute;
        top: -40%;
        right: -10%;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(233, 30, 99, 0.15) 0%, transparent 70%);
        border-radius: 50%;
    }

    .header-content-flex {
        display: flex;
        flex-direction: column;
        gap: 24px;
        justify-content: space-between;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .page-subtitle {
        font-size: 17px;
        color: var(--ink);
        font-weight: 700;
    }

    .loading-state {
        text-align: center;
        padding: 120px 20px;
    }

    .spinner {
        font-size: 56px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .table-card {
        background: white;
        border: 2px solid var(--rose);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th {
        background: linear-gradient(90deg, var(--rose-pale) 0%, var(--white) 100%);
        padding: 16px 18px;
        text-align: left;
        font-size: 12px;
        font-weight: 900;
        color: var(--ink);
        text-transform: uppercase;
        border-bottom: 2px solid var(--rose);
        letter-spacing: 0.08em;
    }

    .data-table td {
        padding: 18px;
        border-bottom: 1px solid #F5F5F5;
    }

    .data-table tr:hover {
        background: var(--rose-pale);
    }

    .product-info {
        display: flex;
        flex-direction: column;
        gap: 3px;
        align-items: flex-start;
    }

    .product-info strong {
        font-size: 14px;
        line-height: 1.2;
        font-weight: 900;
        color: var(--ink);
    }

    .product-info small {
        font-size: 12px;
        color: var(--muted);
        font-weight: 600;
    }

    .producto-thumb {
        width: 56px;
        height: 56px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid var(--rose);
        box-shadow: 0 4px 12px rgba(233, 30, 99, 0.2);
    }

    .stock-badge {
        padding: 6px 16px;
        border-radius: 16px;
        font-size: 12px;
        font-weight: 900;
        background: linear-gradient(90deg, #E3F2FD, #BBDEFB);
        color: #1565C0;
    }

    .stock-badge.low-stock {
        background: linear-gradient(90deg, #FFEBEE, #FFCDD2);
        color: #C62828;
    }

    .variant-count {
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 900;
        background: var(--rose-pale);
        color: var(--rose);
    }

    .action-buttons {
        display: flex;
        gap: 10px;
    }

    .btn-icon {
        padding: 10px;
        border: 2px solid transparent;
        background: #F5F5F5;
        border-radius: 8px;
        cursor: pointer;
        color: var(--ink);
        transition: all .3s var(--ease-spring);
        font-weight: 700;
    }

    .btn-icon:hover {
        background: linear-gradient(135deg, var(--rose) 0%, var(--rose-vibrant) 100%);
        color: white;
        border-color: var(--rose);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(233, 30, 99, 0.25);
    }

    .btn-icon.btn-duplicate:hover {
        background: linear-gradient(135deg, #4F46E5, #6366F1);
        border-color: #4F46E5;
    }

    .btn-icon.btn-delete:hover {
        background: linear-gradient(135deg, #DC2626, #EF4444);
        border-color: #DC2626;
    }

    .btn-icon.btn-reactivate:hover {
        background: linear-gradient(135deg, #059669, #10B981);
        border-color: #059669;
    }

    .product-inactive {
        opacity: 0.6;
        background-color: #F8F8F8;
    }

    .form-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
    }

    .btn-back {
        padding: 10px 18px;
        background: white;
        border: 2px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 700;
        color: var(--ink);
        transition: all .2s;
    }

    .btn-back:hover {
        background: var(--rose-pale);
        border-color: var(--rose);
        color: var(--rose);
    }

    .form-header h2 {
        font-size: 28px;
        font-weight: 800;
        color: var(--ink);
        margin: 0;
    }

    .form-card {
        background: white;
        border: 2px solid var(--rose);
        border-radius: 12px;
        padding: 36px;
        display: flex;
        flex-direction: column;
        gap: 44px;
        box-shadow: 0 12px 32px rgba(232, 0, 232, 0.1);
    }

    .form-section {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .section-title {
        font-size: 18px;
        font-weight: 800;
        color: var(--ink);
        margin: 0;
        letter-spacing: 0.01em;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .form-group.full-width {
        grid-column: 1 / -1;
    }

    .form-group label {
        font-size: 14px;
        font-weight: 800;
        color: var(--ink);
        letter-spacing: 0.02em;
    }

    .form-group small {
        font-size: 12px;
        color: var(--muted);
        margin-top: 4px;
        font-weight: 500;
    }

    .form-control {
        padding: 12px 16px;
        border: 2px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
        transition: all .2s;
        font-family: inherit;
        font-weight: 500;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--rose);
        box-shadow: 0 0 0 3px rgba(232, 0, 232, 0.1), 0 0 12px rgba(232, 0, 232, 0.2);
    }

    .image-preview {
        margin-top: 12px;
    }

    .image-preview img {
        max-width: 200px;
        height: auto;
        border-radius: 8px;
        border: 1px solid #E2E8F0;
    }

    /* LAYOUT COMPACTO PARA IMAGEN PRINCIPAL */
    .main-image-container {
        display: grid;
        grid-template-columns: 1fr 250px;
        gap: 24px;
        align-items: start;
    }

    .main-image-uploader {
        min-height: 200px;
    }

    .main-image-preview {
        width: 250px;
        height: 250px;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid #E2E8F0;
        background: #F8FAFC;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .main-image-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        margin: 0;
        border: none;
    }

    @@media (max-width: 1024px) {
        .main-image-container {
            grid-template-columns: 1fr;
        }

        .main-image-preview {
            width: 100%;
            max-width: 300px;
        }
    }

    /* VARIANTES TABLE */
    .btn-add-variant {
        padding: 10px 20px;
        background: linear-gradient(135deg, #4F46E5 0%, #6366F1 100%);
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 800;
        transition: all .2s;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.25);
    }

    .btn-add-variant:hover {
        background: linear-gradient(135deg, #4338CA 0%, #4F46E5 100%);
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(79, 70, 229, 0.35);
    }

    .variants-table-wrapper {
        overflow-x: auto;
    }

    .variants-table {
        width: 100%;
        border-collapse: collapse;
        border: 2px solid var(--rose);
        border-radius: 8px;
        overflow: hidden;
    }

    .variants-table th {
        background: linear-gradient(90deg, var(--rose-pale) 0%, var(--white) 100%);
        padding: 14px;
        text-align: left;
        font-size: 12px;
        font-weight: 800;
        color: var(--ink);
        text-transform: uppercase;
        border-bottom: 2px solid var(--rose);
        letter-spacing: 0.05em;
    }

    .variants-table td {
        padding: 14px;
        border-bottom: 1px solid #F0F0F0;
    }

    .variants-table tr:hover {
        background: var(--rose-pale);
    }

    .price-cell {
        position: relative;
    }

    .price-cell .error-msg {
        position: absolute;
        font-size: 10px;
        color: #DC2626;
        font-weight: 800;
        margin-top: 2px;
        white-space: nowrap;
    }

    .action-cell {
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    .btn-action {
        padding: 6px 10px;
        border: 2px solid transparent;
        border-radius: 6px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: all .2s;
        background: none;
        font-weight: 700;
    }

    .btn-action.btn-clone {
        background: #DBEAFE;
        color: #0369A1;
        border-color: #0369A1;
    }

    .btn-action.btn-clone:hover {
        background: #0369A1;
        color: white;
    }

    .btn-action.btn-remove {
        background: #FEE2E2;
        color: #DC2626;
        border-color: #DC2626;
    }

    .btn-action.btn-remove:hover {
        background: #DC2626;
        color: white;
    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        background: var(--rose-pale);
        border-radius: 8px;
        border: 2px dashed var(--rose);
        color: var(--ink);
        font-weight: 600;
    }

    /* IMÁGENES */
    .btn-add-image {
        padding: 8px 16px;
        background: #059669;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 500;
        transition: all .2s;
    }

    .btn-add-image:hover {
        background: #047857;
    }

    .images-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
    }

    .image-item {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 12px;
        background: var(--rose-pale);
        border-radius: 8px;
        border: 2px solid var(--rose);
        position: relative;
    }

    .btn-close-image {
        position: absolute;
        top: 4px;
        right: 4px;
        width: 32px;
        height: 32px;
        border: none;
        background: #DC2626;
        color: white;
        border-radius: 50%;
        cursor: pointer;
        font-size: 24px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all .2s;
        z-index: 10;
        box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
    }

    .btn-close-image:hover {
        background: #991B1B;
        transform: scale(1.15);
    }

    .image-preview-box {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 6px;
        border: 2px solid var(--rose);
        overflow: hidden;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .image-preview-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .image-placeholder {
        color: #CBD5E1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .image-form {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .image-form input {
        font-size: 12px !important;
        padding: 8px 10px !important;
    }

    .btn-remove {
        padding: 6px 12px;
        background: #FEE2E2;
        color: #DC2626;
        border: 2px solid #DC2626;
        border-radius: 6px;
        cursor: pointer;
        font-size: 12px;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: all .2s;
        font-weight: 700;
    }

    .btn-remove:hover {
        background: #DC2626;
        color: white;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        padding-top: 32px;
        border-top: 2px solid var(--rose);
    }

    .btn-primary,
    .btn-secondary {
        padding: 12px 28px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 800;
        transition: all .2s;
        border: none;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 14px;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--rose) 0%, var(--rose-vibrant) 100%);
        color: white;
        box-shadow: var(--shadow-rose);
    }

    .btn-primary:hover:not(:disabled) {
        background: linear-gradient(135deg, var(--rose-deep) 0%, var(--rose) 100%);
        transform: translateY(-3px);
        box-shadow: 0 20px 60px rgba(233, 30, 99, 0.4);
    }

    .btn-primary:disabled {
        background: #F48FB1;
        cursor: not-allowed;
        box-shadow: none;
    }

    .btn-secondary {
        background: #F0F0F0;
        color: var(--ink);
        border: 2px solid var(--border);
    }

    .btn-secondary:hover {
        background: var(--rose-pale);
        color: var(--rose);
        border-color: var(--rose);
    }

    /* BÚSQUEDA Y FILTROS */
    .search-bar-container {
        margin-bottom: 28px;
    }

    .search-inputs {
        display: grid;
        grid-template-columns: 1fr 200px;
        gap: 14px;
    }

    .search-input {
        padding: 12px 16px;
        border: 2px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
        transition: all .2s;
        font-family: inherit;
        font-weight: 500;
        width: 100%;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--rose);
        box-shadow: 0 0 0 3px rgba(232, 0, 232, 0.1), 0 0 12px rgba(232, 0, 232, 0.2);
    }

    .filter-select {
        padding: 12px 16px;
        border: 2px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
        background: white;
        cursor: pointer;
        transition: all .2s;
        font-family: inherit;
        font-weight: 600;
    }

    .filter-select:focus {
        outline: none;
        border-color: var(--rose);
        box-shadow: 0 0 0 3px rgba(232, 0, 232, 0.1), 0 0 12px rgba(232, 0, 232, 0.2);
    }

    /* PAGINACIÓN */
    .pagination-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 16px;
        border-top: 2px solid var(--rose);
        background: var(--rose-pale);
        border-radius: 0 0 8px 8px;
        gap: 12px;
    }

    .btn-pagination {
        padding: 10px 18px;
        border: 2px solid var(--rose);
        border-radius: 6px;
        background: white;
        color: var(--rose);
        cursor: pointer;
        font-weight: 800;
        transition: all .2s;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .btn-pagination:hover:not(:disabled) {
        border-color: var(--rose);
        background: var(--rose);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(232, 0, 232, 0.25);
    }

    .btn-pagination:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .pagination-info {
        color: var(--ink);
        font-weight: 800;
        font-size: 14px;
    }

    .pagination-results {
        display: block;
        color: var(--muted);
        font-size: 13px;
        margin-top: 2px;
        font-weight: 600;
    }

    @@media (max-width: 1440px) {
        .form-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .section-title {
            font-size: 20px;
        }

        .page-title {
            font-size: clamp(36px, 5vw, 52px);
        }
    }

    @@media (max-width: 1024px) {
        .form-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .form-card {
            padding: 28px;
            gap: 32px;
        }

        .page-header {
            padding: 40px 0 48px;
        }

        .page-title {
            font-size: clamp(32px, 5vw, 48px);
        }

        .search-inputs {
            grid-template-columns: 1fr;
        }

        .main-image-container {
            grid-template-columns: 1fr;
        }

        .main-image-preview {
            width: 100%;
