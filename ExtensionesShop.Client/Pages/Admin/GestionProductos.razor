@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public int? editId { get; set; }

    private string vistaActual = "lista";
    private List<Product> productos = new();
    private List<Product> productosFiltrados = new();
    private List<Category> categorias = new();
    private List<Subcategory> subcategorias = new();
    private List<Subcategory> filteredSubcategories = new();
    private CreateProductRequest formularioRequest = new();
    private bool isLoading = true;
    private bool guardando = false;
    private int? _lastCategoryId = null;

    // Paginación y Búsqueda
    private string filtroSearch = "";
    private string filtroCategoria = "";
    private string _lastFiltroSearch = "";
    private string _lastFiltroCategoria = "";
    private int paginaActual = 1;
    private int productosPorPagina = 12;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Primera carga
            await FiltrarProductos();
        }
        else
        {
            // Detectar cambios en filtros
            if (_lastFiltroSearch != filtroSearch || _lastFiltroCategoria != filtroCategoria)
            {
                _lastFiltroSearch = filtroSearch;
                _lastFiltroCategoria = filtroCategoria;
                await FiltrarProductos();
            }
            else if (_lastCategoryId != formularioRequest.CategoryId && vistaActual == "formulario")
            {
                // Categoría cambió en formulario
                if (formularioRequest.CategoryId != _lastCategoryId)
                {
                    // Actualizar lista filtrada de subcategorías
                    ActualizarSubcategoriasFiltradas();

                    // Resetear subcategoría
                    formularioRequest.SubcategoryId = null;
                    _lastCategoryId = formularioRequest.CategoryId;

                    Console.WriteLine($"📂 Categoría cambió a {formularioRequest.CategoryId} → Subcategorías filtradas");
                    StateHasChanged();
                }
            }
        }
    }

    private void ActualizarSubcategoriasFiltradas()
    {
        if (formularioRequest.CategoryId > 0)
        {
            var selectedCategory = categorias.FirstOrDefault(c => c.Id == formularioRequest.CategoryId);
            filteredSubcategories = selectedCategory?.Subcategories ?? new List<Subcategory>();
        }
        else
        {
            filteredSubcategories = new();
        }
    }

    private void OnCategoryChanged()
    {
        if (formularioRequest.CategoryId > 0)
        {
            var selectedCategory = categorias.FirstOrDefault(c => c.Id == formularioRequest.CategoryId);
            filteredSubcategories = selectedCategory?.Subcategories ?? new List<Subcategory>();
        }
        else
        {
            filteredSubcategories = new List<Subcategory>();
        }

        formularioRequest.SubcategoryId = null;
        StateHasChanged();
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading = true;
            productos = await Http.GetFromJsonAsync<List<Product>>("api/products") ?? new();
            categorias = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
            subcategorias = await Http.GetFromJsonAsync<List<Subcategory>>("api/subcategories") ?? new();
            Console.WriteLine($"✅ Cargadas {subcategorias.Count} subcategorías");

            // Si existe editId en la URL, buscar y abrir el producto
            if (editId.HasValue && productos.Any())
            {
                var productoAEditar = productos.FirstOrDefault(p => p.Id == editId.Value);
                if (productoAEditar != null)
                {
                    MostrarFormulario(productoAEditar);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error cargando datos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            await FiltrarProductos();
            StateHasChanged();
        }
    }

    private async Task FiltrarProductos()
    {
        paginaActual = 1; // Reset a primera página cuando se filtra

        var query = productos.AsEnumerable();

        // Filtro de búsqueda por nombre, color o descripción
        if (!string.IsNullOrWhiteSpace(filtroSearch))
        {
            var searchLower = filtroSearch.ToLower();
            query = query.Where(p => 
                p.Name.ToLower().Contains(searchLower) ||
                (p.Color != null && p.Color.ToLower().Contains(searchLower)) ||
                (p.Description != null && p.Description.ToLower().Contains(searchLower))
            );
        }

        // Filtro por categoría
        if (!string.IsNullOrEmpty(filtroCategoria) && int.TryParse(filtroCategoria, out var categoryId))
        {
            query = query.Where(p => p.CategoryId == categoryId);
        }

        productosFiltrados = query.OrderByDescending(p => p.Id).ToList();
        StateHasChanged();
        await Task.CompletedTask;
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
        {
            paginaActual--;
            StateHasChanged();
        }
    }

    private void PaginaSiguiente()
    {
        var totalPaginas = (int)Math.Ceiling((double)productosFiltrados.Count() / productosPorPagina);
        if (paginaActual < totalPaginas)
        {
            paginaActual++;
            StateHasChanged();
        }
    }

    private void MostrarFormulario(Product? producto)
    {
        if (producto != null)
        {
            formularioRequest = new CreateProductRequest
            {
                Id = producto.Id,
                Name = producto.Name,
                Description = producto.Description,
                Price = producto.Price,
                Stock = producto.Stock,
                CategoryId = producto.CategoryId,
                SubcategoryId = producto.SubcategoryId,
                Color = producto.Color,
                Centimeters = producto.Centimeters,
                ImageUrl = producto.ImageUrl,
                Variants = producto.Variants?.Select(v => new ProductVariantDto
                {
                    Id = v.Id,
                    Color = v.Color,
                    Centimeters = v.Centimeters,
                    Stock = v.Stock,
                    Price = v.Price,
                    IsActive = v.IsActive
                }).ToList() ?? new(),
                Images = producto.Images?.Select(i => new ProductImageDto
                {
                    Id = i.Id,
                    ProductVariantId = i.ProductVariantId,
                    ImageUrl = i.ImageUrl,
                    AltText = i.AltText,
                    DisplayOrder = i.DisplayOrder,
                    IsActive = i.IsActive
                }).ToList() ?? new()
            };
        }
        else
        {
            formularioRequest = new CreateProductRequest();
        }

        _lastCategoryId = formularioRequest.CategoryId;
        // Actualizar subcategorías filtradas al abrir el formulario
        ActualizarSubcategoriasFiltradas();
        vistaActual = "formulario";
    }

    private void VolverALista()
    {
        vistaActual = "lista";
        formularioRequest = new();
        filteredSubcategories = new();
        _lastCategoryId = null;
    }

    private void AgregarVariante()
    {
        formularioRequest.Variants.Add(new ProductVariantDto
        {
            Id = 0,
            Price = formularioRequest.Price,
            IsActive = true
        });

        // ✅ NUEVO: Sincronizar automáticamente el precio base con la variante más barata
        ActualizarPrecioBase();

        StateHasChanged();
    }

    /// <summary>
    /// Actualiza el precio base del producto con el precio de la variante más barata.
    /// Esto asegura que el catálogo siempre muestre el precio correcto.
    /// </summary>
    private void ActualizarPrecioBase()
    {
        if (formularioRequest.Variants.Any())
        {
            var precioMasBarato = formularioRequest.Variants.Min(v => v.Price);
            if (precioMasBarato > 0)
            {
                formularioRequest.Price = precioMasBarato;
                Console.WriteLine($"💰 Precio base actualizado a ${precioMasBarato} (variante más barata)");
            }
        }
    }

    private void EliminarVariante(int index)
    {
        if (index >= 0 && index < formularioRequest.Variants.Count)
        {
            var varianteEliminada = formularioRequest.Variants[index];
            formularioRequest.Variants.RemoveAt(index);
            Console.WriteLine($"✅ Variante eliminada (Precio: ${varianteEliminada.Price})");

            // ✅ NUEVO: Resincronizar precio base después de eliminar
            ActualizarPrecioBase();

            StateHasChanged();
        }
    }

    private void ClonarVariante(int index)
    {
        if (index >= 0 && index < formularioRequest.Variants.Count)
        {
            var original = formularioRequest.Variants[index];
            var clon = new ProductVariantDto
            {
                Id = 0,
                Color = original.Color,
                Centimeters = original.Centimeters,
                Stock = original.Stock,
                Price = original.Price,
                IsActive = original.IsActive
            };

            formularioRequest.Variants.Insert(index + 1, clon);
            Console.WriteLine($"✅ Variante clonada correctamente");

            // ✅ NUEVO: Resincronizar precio base después de clonar
            ActualizarPrecioBase();

            StateHasChanged();
        }
    }

    private void EliminarImagen(int index)
    {
        if (index >= 0 && index < formularioRequest.Images.Count)
        {
            formularioRequest.Images.RemoveAt(index);

            // Recalcular DisplayOrder
            for (int i = 0; i < formularioRequest.Images.Count; i++)
            {
                formularioRequest.Images[i].DisplayOrder = i;
            }

            Console.WriteLine($"✅ Imagen eliminada");
            StateHasChanged();
        }
    }

    private async Task HandleMainImageSelected(string imageUrl)
    {
        formularioRequest.ImageUrl = imageUrl;
        Console.WriteLine($"✅ Imagen principal actualizada");
        StateHasChanged();
        await JS.InvokeVoidAsync("alert", "✓ Imagen principal actualizada");
    }

    private async Task HandleAdditionalImageSelected(string imageUrl)
    {
        var newImage = new ProductImageDto
        {
            ImageUrl = imageUrl,
            DisplayOrder = formularioRequest.Images.Count,
            IsActive = true,
            AltText = ""
        };

        formularioRequest.Images.Add(newImage);
        Console.WriteLine($"✅ Imagen adicional agregada a galería");
        StateHasChanged();
        await JS.InvokeVoidAsync("alert", "✓ Imagen adicional agregada a la galería");
    }

    private async Task DuplicarProducto(Product producto)
    {
        try
        {
            var confirmado = await JS.InvokeAsync<bool>("confirm", 
                $"¿Duplicar '{producto.Name}' (color: {producto.Color})?\n\nPodría cambiar el color después.");

            if (!confirmado) return;

            // Crear una copia del producto
            MostrarFormulario(producto);

            // Limpiar el ID para que sea un nuevo producto
            formularioRequest.Id = null;

            // Cambiar el nombre para indicar que es un duplicado
            formularioRequest.Color = ""; // El usuario debe ingresar el nuevo color
            formularioRequest.Name = producto.Name; // Mantener el mismo nombre

            vistaActual = "formulario";
            StateHasChanged();

            // Scroll al formulario
            await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }

    private async Task GuardarProducto()
    {
        try
        {
            // Validación 1: Campos base requeridos
            if (string.IsNullOrEmpty(formularioRequest.Name) || 
                formularioRequest.Price <= 0 || 
                formularioRequest.CategoryId == 0 ||
                string.IsNullOrEmpty(formularioRequest.Color))
            {
                await JS.InvokeVoidAsync("alert", "❌ Por favor completa: Nombre, Color, Precio y Categoría");
                return;
            }

            // Validación 2: Si hay variantes, validar que ninguna tenga precio 0
            if (formularioRequest.Variants.Any())
            {
                var variantesSinPrecio = formularioRequest.Variants.Where(v => v.Price <= 0).ToList();
                if (variantesSinPrecio.Any())
                {
                    var indices = string.Join(", ", formularioRequest.Variants
                        .Select((v, idx) => (v, idx))
                        .Where(x => x.v.Price <= 0)
                        .Select(x => $"Variante {x.idx + 1}"));

                    await JS.InvokeVoidAsync("alert", 
                        $"❌ Las siguientes variantes tienen precio 0 o vacío:\n{indices}\n\nTodas las variantes deben tener un precio > 0");
                    return;
                }
            }

            guardando = true;

            Console.WriteLine("═══════════════════════════════════════════════");
            Console.WriteLine("📤 ENVIANDO PRODUCTO");
            Console.WriteLine("═══════════════════════════════════════════════");
            Console.WriteLine($"Nombre: {formularioRequest.Name}");
            Console.WriteLine($"Color: {formularioRequest.Color}");
            Console.WriteLine($"Precio: {formularioRequest.Price}");
            Console.WriteLine($"Categoría: {formularioRequest.CategoryId}");
            Console.WriteLine($"Subcategoría: {formularioRequest.SubcategoryId}");
            Console.WriteLine($"Imagen Principal: {formularioRequest.ImageUrl}");
            Console.WriteLine($"Variantes: {formularioRequest.Variants.Count}");

            foreach (var v in formularioRequest.Variants)
            {
                Console.WriteLine($"  - Variante: Precio=${v.Price}, Stock={v.Stock}, Centimeters={v.Centimeters}");
            }

            Console.WriteLine($"Imágenes Adicionales: {formularioRequest.Images.Count}");
            foreach (var img in formularioRequest.Images)
            {
                Console.WriteLine($"  - Imagen: {img.ImageUrl.Substring(0, Math.Min(50, img.ImageUrl.Length))}...");
            }
            Console.WriteLine("═══════════════════════════════════════════════");

            var response = await Http.PostAsJsonAsync("api/products/with-variants", formularioRequest);

            Console.WriteLine($"📥 RESPUESTA: {response.StatusCode}");

            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", 
                    $"✅ Producto {(formularioRequest.Id.HasValue ? "actualizado" : "creado")} correctamente");
                await CargarDatos();
                VolverALista();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await JS.InvokeVoidAsync("alert", 
                    "❌ ERROR 401: No estás autorizado.\n\nDebes estar logueado como Admin.");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ ERROR: {errorContent}");
                await JS.InvokeVoidAsync("alert", $"❌ Error: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Exception: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task EliminarProducto(Product producto)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", 
            $"⚠️ ¿Estás seguro de eliminar '{producto.Name} ({producto.Color})'?\n\nEsta acción NO se puede deshacer.");

        if (!confirmado) return;

        try
        {
            var response = await Http.DeleteAsync($"api/products/{producto.Id}");
            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "✅ Producto eliminado");
                await CargarDatos();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error eliminando: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
    }

    private string GetColorHex(string colorName)
    {
        // Mapa de colores comunes
        var colorMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            { "Castaño", "#8B4513" },
            { "Rubio", "#FFD700" },
            { "Negro", "#000000" },
            { "Rojo", "#FF0000" },
            { "Marrón", "#A52A2A" },
            { "Dorado", "#FFD700" },
            { "Platino", "#E5E4E2" },
            { "Oscuro", "#333333" },
            { "Claro", "#F5DEB3" }
        };

        return colorMap.TryGetValue(colorName, out var hex) ? hex : "#CCCCCC";
    }

    /// <summary>
    /// Determina si el producto actual es de tipo capilar (pelo)
    /// basado en su categoría
    /// </summary>
    private bool EsProductoCapilar(int? categoryId)
    {
        if (!categoryId.HasValue || categoryId.Value == 0)
            return true; // Por defecto, asumimos que es capilar

        // Buscar la categoría
        var categoria = categorias.FirstOrDefault(c => c.Id == categoryId.Value);
        if (categoria == null)
            return true; // Por defecto capilar

        // Lógica: considera capilar si la categoría contiene palabras clave
        var nombreCategoria = categoria.Name?.ToLower() ?? "";
        return nombreCategoria.Contains("pelo") || 
               nombreCategoria.Contains("cabello") || 
               nombreCategoria.Contains("extensión") ||
               nombreCategoria.Contains("remy") ||
               nombreCategoria.Contains("sintético");
    }

    /// <summary>
    /// Obtiene un label amigable para mostrar el valor de Centimeters
    /// Si es 0 o null, muestra "Estándar"
    /// </summary>
    private string GetMedidaLabel(decimal? centimeters)
    {
        if (!centimeters.HasValue || centimeters.Value == 0)
            return "Estándar";

        return $"{centimeters:F1} cm";
    }

    /// <summary>
    /// Valida si una variante tiene todos los campos requeridos
    /// </summary>
    private bool EsVarianteValida(ProductVariantDto variante)
    {
        return variante.Price > 0;
    }

    /// <summary>
    /// Obtiene el total de variantes con precio válido
    /// </summary>
    private int ContarVariantesValidas()
    {
        return formularioRequest.Variants.Count(v => EsVarianteValida(v));
    }
