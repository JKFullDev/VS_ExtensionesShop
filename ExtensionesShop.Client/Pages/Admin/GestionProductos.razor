@page "/admin/productos"
@layout ExtensionesShop.Client.Layouts.AdminLayout
@using ExtensionesShop.Shared.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<AdminRoute>
    <div class="productos-admin-page">
        @if (vistaActual == "lista")
        {
            <!-- VISTA LISTA -->
            <div class="page-actions">
                <h2>Gestión de Productos (@productos.Count)</h2>
                <button class="btn-primary" @onclick="() => MostrarFormulario(null)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Nuevo Producto
                </button>
            </div>

            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner">✦</div>
                    <p>Cargando productos...</p>
                </div>
            }
            else
            {
                <div class="table-card">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Imagen</th>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Categoría</th>
                                <th>Precio</th>
                                <th>Stock</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var producto in productos)
                            {
                                <tr>
                                    <td>
                                        <img src="@(producto.ImageUrl ?? "/images/placeholder.jpg")" alt="@producto.Name" class="producto-thumb" />
                                    </td>
                                    <td><strong>#@producto.Id</strong></td>
                                    <td>@producto.Name</td>
                                    <td>@producto.Category?.Name</td>
                                    <td><strong>$@producto.Price.ToString("N2")</strong></td>
                                    <td>
                                        <span class="stock-badge @(producto.Stock < 10 ? "low-stock" : "")">
                                            @producto.Stock
                                        </span>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn-icon" @onclick="() => MostrarFormulario(producto)" title="Editar">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                                </svg>
                                            </button>
                                            <button class="btn-icon btn-delete" @onclick="() => EliminarProducto(producto)" title="Eliminar">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6"></polyline>
                                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            <!-- VISTA FORMULARIO -->
            <div class="form-header">
                <button class="btn-back" @onclick="VolverALista">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    Volver
                </button>
                <h2>@(productoEditando?.Id == 0 ? "Nuevo Producto" : $"Editar: {productoEditando?.Name}")</h2>
            </div>

            <div class="form-card">
                <div class="form-grid">
                    <!-- Nombre -->
                    <div class="form-group full-width">
                        <label>Nombre del Producto *</label>
                        <input type="text" @bind="productoEditando.Name" class="form-control" placeholder="Ej: Extensiones Remy 60cm" />
                    </div>

                    <!-- Descripción -->
                    <div class="form-group full-width">
                        <label>Descripción</label>
                        <textarea @bind="productoEditando.Description" class="form-control" rows="4" placeholder="Descripción del producto..."></textarea>
                    </div>

                    <!-- Precio -->
                    <div class="form-group">
                        <label>Precio *</label>
                        <input type="number" step="0.01" @bind="productoEditando.Price" class="form-control" placeholder="0.00" />
                    </div>

                    <!-- Stock -->
                    <div class="form-group">
                        <label>Stock *</label>
                        <input type="number" @bind="productoEditando.Stock" class="form-control" placeholder="0" />
                    </div>

                    <!-- Categoría -->
                    <div class="form-group">
                        <label>Categoría *</label>
                        <select @bind="productoEditando.CategoryId" class="form-control">
                            <option value="0">Seleccionar...</option>
                            @foreach (var cat in categorias)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Subcategoría -->
                    <div class="form-group">
                        <label>Subcategoría</label>
                        <select @bind="productoEditando.SubcategoryId" class="form-control">
                            <option value="">Ninguna</option>
                            @foreach (var sub in subcategorias.Where(s => s.CategoryId == productoEditando.CategoryId))
                            {
                                <option value="@sub.Id">@sub.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Color -->
                    <div class="form-group">
                        <label>Color</label>
                        <input type="text" @bind="productoEditando.Color" class="form-control" placeholder="Ej: Castaño" />
                    </div>

                    <!-- Centímetros -->
                    <div class="form-group">
                        <label>Longitud (cm)</label>
                        <input type="number" step="0.1" @bind="productoEditando.Centimeters" class="form-control" placeholder="Ej: 60" />
                    </div>

                    <!-- Imagen URL -->
                    <div class="form-group full-width">
                        <label>URL de Imagen</label>
                        <input type="text" @bind="productoEditando.ImageUrl" class="form-control" placeholder="https://..." />
                        @if (!string.IsNullOrEmpty(productoEditando.ImageUrl))
                        {
                            <div class="image-preview">
                                <img src="@productoEditando.ImageUrl" alt="Preview" />
                            </div>
                        }
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn-secondary" @onclick="VolverALista">Cancelar</button>
                    <button type="button" class="btn-primary" @onclick="GuardarProducto" disabled="@guardando">
                        @if (guardando)
                        {
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <span>Guardar Producto</span>
                        }
                    </button>
                </div>
            </div>
        }
    </div>
</AdminRoute>

<style>
    .productos-admin-page {
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .page-actions h2 {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
    }

    .loading-state {
        text-align: center;
        padding: 80px 20px;
    }

    .spinner {
        font-size: 48px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .table-card {
        background: white;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        overflow: hidden;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th {
        background: #F8FAFC;
        padding: 12px 16px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        color: #64748B;
        text-transform: uppercase;
        border-bottom: 1px solid #E2E8F0;
    }

    .data-table td {
        padding: 16px;
        border-bottom: 1px solid #F1F5F9;
    }

    .data-table tr:hover {
        background: #F8FAFC;
    }

    .producto-thumb {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 8px;
    }

    .stock-badge {
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        background: #D4EDDA;
        color: #155724;
    }

    .stock-badge.low-stock {
        background: #FFF3CD;
        color: #856404;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .btn-icon {
        padding: 8px;
        border: none;
        background: #F1F5F9;
        border-radius: 6px;
        cursor: pointer;
        color: var(--ink);
        transition: all .2s;
    }

    .btn-icon:hover {
        background: var(--rose);
        color: white;
    }

    .btn-delete:hover {
        background: #DC2626;
    }

    /* FORMULARIO */
    .form-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
    }

    .btn-back {
        padding: 8px 16px;
        background: white;
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 500;
        color: var(--ink);
        transition: all .2s;
    }

    .btn-back:hover {
        background: #F8FAFC;
    }

    .form-header h2 {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
    }

    .form-card {
        background: white;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        padding: 32px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        margin-bottom: 32px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-group.full-width {
        grid-column: 1 / -1;
    }

    .form-group label {
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
    }

    .form-control {
        padding: 10px 14px;
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        font-size: 14px;
        transition: border-color .2s;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--rose);
    }

    .image-preview {
        margin-top: 12px;
    }

    .image-preview img {
        max-width: 200px;
        height: auto;
        border-radius: 8px;
        border: 1px solid #E2E8F0;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        padding-top: 24px;
        border-top: 1px solid #E2E8F0;
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private string vistaActual = "lista";
    private List<Product> productos = new();
    private List<Category> categorias = new();
    private List<Subcategory> subcategorias = new();
    private Product productoEditando = new();
    private bool isLoading = true;
    private bool guardando = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading = true;
            productos = await Http.GetFromJsonAsync<List<Product>>("api/products") ?? new();
            categorias = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
            subcategorias = await Http.GetFromJsonAsync<List<Subcategory>>("api/subcategories") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error cargando datos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void MostrarFormulario(Product? producto)
    {
        productoEditando = producto != null ? new Product
        {
            Id = producto.Id,
            Name = producto.Name,
            Description = producto.Description,
            Price = producto.Price,
            Stock = producto.Stock,
            CategoryId = producto.CategoryId,
            SubcategoryId = producto.SubcategoryId,
            Color = producto.Color,
            Centimeters = producto.Centimeters,
            ImageUrl = producto.ImageUrl
        } : new Product();

        vistaActual = "formulario";
    }

    private void VolverALista()
    {
        vistaActual = "lista";
        productoEditando = new();
    }

    private async Task GuardarProducto()
    {
        try
        {
            if (string.IsNullOrEmpty(productoEditando.Name) || productoEditando.Price <= 0 || productoEditando.CategoryId == 0)
            {
                await JS.InvokeVoidAsync("alert", "❌ Por favor completa los campos obligatorios");
                return;
            }

            guardando = true;

            if (productoEditando.Id == 0)
            {
                var response = await Http.PostAsJsonAsync("api/products", productoEditando);
                if (response.IsSuccessStatusCode)
                {
                    await JS.InvokeVoidAsync("alert", "✅ Producto creado correctamente");
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/products/{productoEditando.Id}", productoEditando);
                if (response.IsSuccessStatusCode)
                {
                    await JS.InvokeVoidAsync("alert", "✅ Producto actualizado correctamente");
                }
            }

            await CargarDatos();
            VolverALista();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error guardando producto: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task EliminarProducto(Product producto)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Estás seguro de eliminar '{producto.Name}'?");
        if (!confirmado) return;

        try
        {
            var response = await Http.DeleteAsync($"api/products/{producto.Id}");
            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "✅ Producto eliminado");
                await CargarDatos();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error eliminando producto: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Error: {ex.Message}");
        }
    }
}
