@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public int? editId { get; set; }

    private string vistaActual = "lista";
    private List<Product> productos = new();
    private List<Product> productosFiltrados = new();
    private List<Category> categorias = new();
    private List<Subcategory> subcategorias = new();
    private List<Subcategory> filteredSubcategories = new();
    private CreateProductRequest formularioRequest = new();
    private bool isLoading = true;
    private bool guardando = false;
    private int? _lastCategoryId = null;

    // Paginación y Búsqueda
    private string filtroSearch = "";
    private string filtroCategoria = "";
    private string _lastFiltroSearch = "";
    private string _lastFiltroCategoria = "";
    private bool mostrarInactivos = false;  // ✅ NUEVO: Mostrar productos desactivados
    private bool _lastMostrarInactivos = false;  // ✅ NUEVO: Rastrear cambios en checkbox
    private int paginaActual = 1;
    private int productosPorPagina = 12;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Primera carga
            await FiltrarProductos();
        }
        else
        {
            // Detectar cambios en filtros (búsqueda, categoría, o checkbox de inactivos)
            if (_lastFiltroSearch != filtroSearch || _lastFiltroCategoria != filtroCategoria || _lastMostrarInactivos != mostrarInactivos)
            {
                _lastFiltroSearch = filtroSearch;
                _lastFiltroCategoria = filtroCategoria;
                _lastMostrarInactivos = mostrarInactivos;  // ✅ NUEVO: Rastrear cambio en checkbox
                await FiltrarProductos();
            }
            else if (_lastCategoryId != formularioRequest.CategoryId && vistaActual == "formulario")
            {
                // Categoría cambió en formulario
                if (formularioRequest.CategoryId != _lastCategoryId)
                {
                    // Actualizar lista filtrada de subcategorías
                    ActualizarSubcategoriasFiltradas();

                    // Resetear subcategoría
                    formularioRequest.SubcategoryId = null;
                    _lastCategoryId = formularioRequest.CategoryId;

                    Console.WriteLine($"📂 Categoría cambió a {formularioRequest.CategoryId} → Subcategorías filtradas");
                    StateHasChanged();
                }
            }
        }
    }

    private void ActualizarSubcategoriasFiltradas()
    {
        if (formularioRequest.CategoryId > 0)
        {
            var selectedCategory = categorias.FirstOrDefault(c => c.Id == formularioRequest.CategoryId);
            filteredSubcategories = selectedCategory?.Subcategories ?? new List<Subcategory>();
        }
        else
        {
            filteredSubcategories = new();
        }
    }

    private void OnCategoryChanged()
    {
        if (formularioRequest.CategoryId > 0)
        {
            var selectedCategory = categorias.FirstOrDefault(c => c.Id == formularioRequest.CategoryId);
            filteredSubcategories = selectedCategory?.Subcategories ?? new List<Subcategory>();
        }
        else
        {
            filteredSubcategories = new List<Subcategory>();
        }

        formularioRequest.SubcategoryId = null;
        StateHasChanged();
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading = true;
            // ✅ Usar endpoint admin/all para obtener TODOS los productos (activos e inactivos)
            productos = await Http.GetFromJsonAsync<List<Product>>("api/products/admin/all") ?? new();
            categorias = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
            subcategorias = await Http.GetFromJsonAsync<List<Subcategory>>("api/subcategories") ?? new();
            Console.WriteLine($"✅ Cargados {productos.Count} productos (incluyendo inactivos)");
            Console.WriteLine($"✅ Cargadas {subcategorias.Count} subcategorías");

            // Si existe editId en la URL, buscar y abrir el producto
            if (editId.HasValue && productos.Any())
            {
                var productoAEditar = productos.FirstOrDefault(p => p.Id == editId.Value);
                if (productoAEditar != null)
                {
                    MostrarFormulario(productoAEditar);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error cargando datos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            await FiltrarProductos();
            StateHasChanged();
        }
    }

    private async Task FiltrarProductos()
    {
        paginaActual = 1; // Reset a primera página cuando se filtra

        var query = productos.AsEnumerable();

        // ✅ NUEVO: Filtro de productos activos/inactivos
        if (!mostrarInactivos)
        {
            // Si el checkbox NO está marcado, mostrar solo activos
            query = query.Where(p => p.IsActive == true);
        }
        // Si está marcado, mostrar todos (activos e inactivos)

        // Filtro de búsqueda por nombre, color o descripción
        if (!string.IsNullOrWhiteSpace(filtroSearch))
        {
            var searchLower = filtroSearch.ToLower();
            query = query.Where(p => 
                p.Name.ToLower().Contains(searchLower) ||
                (p.Color != null && p.Color.ToLower().Contains(searchLower)) ||
                (p.Description != null && p.Description.ToLower().Contains(searchLower))
            );
        }

        // Filtro por categoría
        if (!string.IsNullOrEmpty(filtroCategoria) && int.TryParse(filtroCategoria, out var categoryId))
        {
            query = query.Where(p => p.CategoryId == categoryId);
        }

        productosFiltrados = query.OrderByDescending(p => p.Id).ToList();
        StateHasChanged();
        await Task.CompletedTask;
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
        {
            paginaActual--;
            StateHasChanged();
        }
    }

    private void PaginaSiguiente()
    {
        var totalPaginas = (int)Math.Ceiling((double)productosFiltrados.Count() / productosPorPagina);
        if (paginaActual < totalPaginas)
        {
            paginaActual++;
            StateHasChanged();
        }
    }

    private void MostrarFormulario(Product? producto)
    {
        if (producto != null)
        {
            formularioRequest = new CreateProductRequest
            {
                Id = producto.Id,
                Name = producto.Name,
                Description = producto.Description,
                Price = producto.Price,
                Stock = producto.Stock,
                CategoryId = producto.CategoryId,
                SubcategoryId = producto.SubcategoryId,
                Color = producto.Color,
                Centimeters = producto.Centimeters,
                ImageUrl = producto.ImageUrl,
                // ✅ FILTRO: Solo incluir variantes ACTIVAS en el formulario
                Variants = producto.Variants?
                    .Where(v => v.IsActive) // ✅ Excluir variantes inactivas (soft-deleted)
                    .Select(v => new ProductVariantDto
                    {
                        Id = v.Id,
                        Color = v.Color,
                        Centimeters = v.Centimeters,
                        Stock = v.Stock,
                        Price = v.Price,
                        IsActive = v.IsActive
                    }).ToList() ?? new(),
                Images = producto.Images?.Select(i => new ProductImageDto
                {
                    Id = i.Id,
                    ProductVariantId = i.ProductVariantId,
                    ImageUrl = i.ImageUrl,
                    AltText = i.AltText,
                    DisplayOrder = i.DisplayOrder,
                    IsActive = i.IsActive
                }).ToList() ?? new()
            };
        }
        else
        {
            // ✅ Al crear un nuevo producto, inicializar con IsActive = true automáticamente
            formularioRequest = new CreateProductRequest();
        }

        _lastCategoryId = formularioRequest.CategoryId;
        // Actualizar subcategorías filtradas al abrir el formulario
        ActualizarSubcategoriasFiltradas();
        vistaActual = "formulario";
    }

    private void VolverALista()
    {
        vistaActual = "lista";
        formularioRequest = new();
        filteredSubcategories = new();
        _lastCategoryId = null;
    }

    /// <summary>
    /// Maneja el cambio del checkbox "Ver productos desactivados"
    /// </summary>
    private async Task HandleMostrarInactivosChanged(ChangeEventArgs e)
    {
        mostrarInactivos = (bool)e.Value;
        await FiltrarProductos();
    }

    private void AgregarVariante()
    {
        formularioRequest.Variants.Add(new ProductVariantDto
        {
            Id = 0,
            Price = formularioRequest.Price,
            IsActive = true
        });

        // ✅ NUEVO: Sincronizar automáticamente el precio base con la variante más barata
        ActualizarPrecioBase();

        StateHasChanged();
    }

    /// <summary>
    /// Actualiza el precio base del producto con el precio de la variante más barata.
    /// Esto asegura que el catálogo siempre muestre el precio correcto.
    /// </summary>
    private void ActualizarPrecioBase()
    {
        if (formularioRequest.Variants.Any())
        {
            var precioMasBarato = formularioRequest.Variants.Min(v => v.Price);
            if (precioMasBarato > 0)
            {
                formularioRequest.Price = precioMasBarato;
                Console.WriteLine($"💰 Precio base actualizado a ${precioMasBarato} (variante más barata)");
            }
        }
    }

    private void EliminarVariante(int index)
    {
        if (index >= 0 && index < formularioRequest.Variants.Count)
        {
            var varianteEliminada = formularioRequest.Variants[index];
            formularioRequest.Variants.RemoveAt(index);
            Console.WriteLine($"✅ Variante eliminada (Precio: ${varianteEliminada.Price})");

            // ✅ NUEVO: Resincronizar precio base después de eliminar
            ActualizarPrecioBase();

            StateHasChanged();
        }
    }

    private void ClonarVariante(int index)
    {
        if (index >= 0 && index < formularioRequest.Variants.Count)
        {
            var original = formularioRequest.Variants[index];
            var clon = new ProductVariantDto
            {
                Id = 0,
                Color = original.Color,
                Centimeters = original.Centimeters,
                Stock = original.Stock,
                Price = original.Price,
                IsActive = original.IsActive
            };

            formularioRequest.Variants.Insert(index + 1, clon);
            Console.WriteLine($"✅ Variante clonada correctamente");

            // ✅ NUEVO: Resincronizar precio base después de clonar
            ActualizarPrecioBase();

            StateHasChanged();
        }
    }

    private void EliminarImagen(int index)
    {
        if (index >= 0 && index < formularioRequest.Images.Count)
        {
            formularioRequest.Images.RemoveAt(index);

            // Recalcular DisplayOrder
            for (int i = 0; i < formularioRequest.Images.Count; i++)
            {
                formularioRequest.Images[i].DisplayOrder = i;
            }

            Console.WriteLine($"✅ Imagen eliminada");
