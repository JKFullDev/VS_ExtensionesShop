@page "/admin/productos"
@using ExtensionesShop.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS

<div class="admin-page">
    <div class="admin-header">
        <div class="section-inner">
            <h1 class="admin-title">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                </svg>
                Gestión de Productos
            </h1>
            <button class="btn-primary" @onclick="AbrirModalCrear">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Nuevo Producto
            </button>
        </div>
    </div>

    <div class="admin-content">
        <div class="section-inner">
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner">✦</div>
                    <p>Cargando productos...</p>
                </div>
            }
            else if (!productos.Any())
            {
                <div class="empty-state">
                    <p>No hay productos registrados</p>
                    <button class="btn-primary" @onclick="AbrirModalCrear">Crear el primero</button>
                </div>
            }
            else
            {
                <!-- Tabla de productos -->
                <div class="admin-table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Imagen</th>
                                <th>Nombre</th>
                                <th>Categoría</th>
                                <th>Precio</th>
                                <th>Stock</th>
                                <th>Estado</th>
                                <th class="actions-col">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var producto in productos)
                            {
                                <tr>
                                    <td class="id-col">#@producto.Id</td>
                                    <td>
                                        <div class="table-image">
                                            <img src="@producto.ImageUrl" alt="@producto.Name" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="product-name-cell">
                                            <span class="name">@producto.Name</span>
                                        </div>
                                    </td>
                                    <td>@producto.Category?.Name</td>
                                    <td>
                                        <div class="price-cell">
                                            <span class="current-price">$@producto.Price.ToString("N2")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="stock-badge @(producto.Stock > 10 ? "stock-good" : producto.Stock > 0 ? "stock-low" : "stock-out")">
                                            @producto.Stock
                                        </span>
                                    </td>
                                    <td>
                                        @if (producto.Stock > 0)
                                        {
                                            <span class="status-active">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="status-inactive">Sin stock</span>
                                        }
                                    </td>
                                    <td class="actions-col">
                                        <div class="action-buttons">
                                            <button class="btn-icon btn-edit"
                                                    @onclick="() => AbrirModalEditar(producto)"
                                                    title="Editar">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                </svg>
                                            </button>
                                            <button class="btn-icon btn-delete"
                                                    @onclick="() => EliminarProducto(producto)"
                                                    title="Eliminar">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal de Crear/Editar -->
@if (mostrarModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>@(productoEditando?.Id > 0 ? "Editar Producto" : "Nuevo Producto")</h2>
                <button class="modal-close" @onclick="CerrarModal">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>

            <EditForm Model="productoEditando" OnValidSubmit="GuardarProducto">
                <DataAnnotationsValidator />

                <div class="modal-body">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Nombre *</label>
                            <InputText @bind-Value="productoEditando!.Name" class="form-control" placeholder="Ej: Clip-In Premium Castaño" />
                            <ValidationMessage For="@(() => productoEditando.Name)" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Descripción</label>
                        <InputTextArea @bind-Value="productoEditando!.Description" class="form-control" rows="3" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Precio *</label>
                            <InputNumber @bind-Value="productoEditando!.Price" class="form-control" />
                            <ValidationMessage For="@(() => productoEditando.Price)" />
                        </div>

                        <div class="form-group">
                            <label>Stock *</label>
                            <InputNumber @bind-Value="productoEditando!.Stock" class="form-control" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>URL de Imagen</label>
                        <InputText @bind-Value="productoEditando!.ImageUrl" class="form-control" placeholder="https://..." />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Categoría *</label>
                            <InputSelect @bind-Value="productoEditando!.CategoryId" class="form-control">
                                <option value="0">Seleccionar...</option>
                                @foreach (var cat in categorias)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label>Subcategoría</label>
                            <InputSelect @bind-Value="productoEditando!.SubcategoryId" class="form-control">
                                <option value="">Sin subcategoría</option>
                                @foreach (var cat in categorias.Where(c => c.Id == productoEditando.CategoryId))
                                {
                                    @foreach (var sub in cat.Subcategories)
                                    {
                                        <option value="@sub.Id">@sub.Name</option>
                                    }
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Color</label>
                            <InputText @bind-Value="productoEditando!.Color" class="form-control" placeholder="Ej: Castaño #4" />
                        </div>

                        <div class="form-group">
                            <label>Largo (cm)</label>
                            <InputNumber @bind-Value="productoEditando!.Centimeters" class="form-control" placeholder="Ej: 50" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-ghost" @onclick="CerrarModal">Cancelar</button>
                    <button type="submit" class="btn-primary" disabled="@guardando">
                        @if (guardando)
                        {
                            <span class="spinner-sm">✦</span>
                            <text>Guardando...</text>
                        }
                        else
                        {
                            <text>@(productoEditando?.Id > 0 ? "Actualizar" : "Crear") Producto</text>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    /* ── Admin Header ──────────────────────────────────────── */
    .admin-header {
        background: var(--white);
        border-bottom: 1px solid var(--border);
        padding: 32px 0;
        margin-top: var(--header-h);
    }

        .admin-header .section-inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

    .admin-title {
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: var(--font-display);
        font-size: 28px;
        font-weight: 400;
        color: var(--ink);
    }

        .admin-title svg {
            color: var(--rose);
        }

    /* ── Admin Content ─────────────────────────────────────── */
    .admin-content {
        padding: 48px 0;
    }

    /* ── Table ─────────────────────────────────────────────── */
    .admin-table-wrapper {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table thead {
            background: var(--off-white);
            border-bottom: 1px solid var(--border);
        }

        .admin-table th {
            padding: 16px 20px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .15em;
            text-transform: uppercase;
            color: var(--muted);
        }

        .admin-table td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
            color: var(--ink);
        }

        .admin-table tbody tr:last-child td {
            border-bottom: none;
        }

        .admin-table tbody tr:hover {
            background: var(--rose-pale);
        }

    .id-col {
        font-family: monospace;
        color: var(--muted);
        font-size: 13px;
    }

    .table-image {
        width: 60px;
        height: 72px;
        border-radius: 8px;
        overflow: hidden;
        background: var(--off-white);
    }

        .table-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .product-name-cell {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .product-name-cell .name {
            font-weight: 500;
        }

    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 100px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .05em;
    }

    .badge-new {
        background: var(--ink);
        color: white;
    }

    .badge-featured {
        background: #FEF3C7;
        color: #92400E;
    }

    .price-cell {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .original-price {
        font-size: 12px;
        color: var(--muted);
        text-decoration: line-through;
    }

    .current-price {
        font-weight: 600;
    }

    .stock-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 600;
    }

    .stock-good {
        background: #D1FAE5;
        color: #065F46;
    }

    .stock-low {
        background: #FEF3C7;
        color: #92400E;
    }

    .stock-out {
        background: #FEE2E2;
        color: #991B1B;
    }

    .status-active {
        color: #059669;
        font-weight: 500;
    }

    .status-inactive {
        color: var(--muted);
    }

    .actions-col {
        width: 120px;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s, color .2s;
    }

    .btn-edit {
        color: #0284C7;
        background: #E0F2FE;
    }

        .btn-edit:hover {
            background: #0284C7;
            color: white;
        }

    .btn-delete {
        color: #DC2626;
        background: #FEE2E2;
    }

        .btn-delete:hover {
            background: #DC2626;
            color: white;
        }

    /* ── Modal ─────────────────────────────────────────────── */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(26, 18, 21, .6);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 20px;
    }

    .modal-content {
        background: var(--white);
        border-radius: 20px;
        width: 100%;
        max-width: 800px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 24px 64px rgba(0, 0, 0, .2);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 28px 32px;
        border-bottom: 1px solid var(--border);
    }

        .modal-header h2 {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 400;
            color: var(--ink);
        }

    .modal-close {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: background .2s, color .2s;
    }

        .modal-close:hover {
            background: var(--rose-pale);
            color: var(--rose);
        }

    .modal-body {
        padding: 32px;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .form-group label {
            font-size: 13px;
            font-weight: 600;
            color: var(--ink);
        }

    .form-control {
        padding: 12px 16px;
        border: 1px solid var(--border);
        border-radius: 10px;
        font-size: 14px;
        color: var(--ink);
        background: var(--white);
        transition: border-color .2s, box-shadow .2s;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--rose);
            box-shadow: 0 0 0 3px rgba(232, 96, 122, .1);
        }

    .form-checkboxes {
        display: flex;
        gap: 24px;
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: var(--ink);
        cursor: pointer;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        padding: 20px 32px;
        border-top: 1px solid var(--border);
    }

    .spinner-sm {
        display: inline-block;
        animation: spin 1.5s linear infinite;
    }

    /* ── Loading/Empty States ──────────────────────────────── */
    .loading-state, .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        padding: 80px 20px;
        color: var(--muted);
    }

    .spinner {
        font-size: 48px;
        animation: spin 2s linear infinite;
        color: var(--rose);
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

@code {
    private List<Product> productos = new();
    private List<Category> categorias = new();
    private bool isLoading = true;
    private bool mostrarModal = false;
    private bool guardando = false;
    private Product? productoEditando;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        isLoading = true;
        try
        {
            productos = await Http.GetFromJsonAsync<List<Product>>("api/products?pageSize=1000") ?? new();
            categorias = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AbrirModalCrear()
    {
        productoEditando = new Product { CategoryId = 0 };
        mostrarModal = true;
    }

    private void AbrirModalEditar(Product producto)
    {
        productoEditando = new Product
        {
            Id = producto.Id,
            Name = producto.Name,
            Description = producto.Description,
            Price = producto.Price,
            ImageUrl = producto.ImageUrl,
            CategoryId = producto.CategoryId,
            SubcategoryId = producto.SubcategoryId,
            Stock = producto.Stock,
            Color = producto.Color,
            Centimeters = producto.Centimeters
        };
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        productoEditando = null;
    }

    private async Task GuardarProducto()
    {
        if (productoEditando == null) return;

        guardando = true;
        try
        {
            HttpResponseMessage response;

            if (productoEditando.Id > 0)
            {
                // Editar
                response = await Http.PutAsJsonAsync($"api/products/{productoEditando.Id}", productoEditando);
            }
            else
            {
                // Crear
                response = await Http.PostAsJsonAsync("api/products", productoEditando);
            }

            if (response.IsSuccessStatusCode)
            {
                await CargarDatos();
                CerrarModal();
                await JS.InvokeVoidAsync("alert", "Producto guardado correctamente");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Error: {error}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task EliminarProducto(Product producto)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar '{producto.Name}'?");
        if (!confirmado) return;

        try
        {
            var response = await Http.DeleteAsync($"api/products/{producto.Id}");
            if (response.IsSuccessStatusCode)
            {
                await CargarDatos();
                await JS.InvokeVoidAsync("alert", "Producto eliminado");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }
}