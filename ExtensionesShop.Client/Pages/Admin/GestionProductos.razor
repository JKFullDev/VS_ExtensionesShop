            height: 280px;
        }

        .images-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .variants-table {
            font-size: 12px;
        }

        .variants-table th,
        .variants-table td {
            padding: 10px;
        }

        .form-group label {
            font-size: 13px;
