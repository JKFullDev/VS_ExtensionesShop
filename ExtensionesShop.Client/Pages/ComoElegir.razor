@* @page "/como-elegir"

<PageTitle>Guía: Cómo Elegir Tu Extensión - Extensiones Shop</PageTitle>

<div class="guia-page">
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Guía de Compra</span>
            </div>
            <h1 class="page-title">¿Cómo Elegir la Extensión Perfecta?</h1>
            <p class="page-subtitle">Encuentra el tipo, largo y color ideal para tu cabello en 3 pasos</p>
        </div>
    </div>

    <div class="guia-content">
        <div class="section-inner">
            
            <!-- Paso 1: Tipo de Extensión -->
            <section class="guia-step">
                <div class="step-number">01</div>
                <h2 class="step-title">Elige el Tipo de Extensión</h2>
                <div class="types-grid">

                    <div class="type-card">
                        <div class="type-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
                            </svg>
                        </div>
                        <h3>Clips</h3>
                        <p class="type-ideal">Ideal para: Cambio ocasional</p>
                        <ul class="type-features">
                            <li>✓ Fácil de poner y quitar</li>
                            <li>✓ Sin compromiso</li>
                            <li>✓ Puedes hacerlo tú misma</li>
                            <li>✓ Reutilizables</li>
                        </ul>
                        <span class="type-price">Desde 89€</span>
                    </div>

                    <div class="type-card type-featured">
                        <div class="badge-popular">Más Popular</div>
                        <div class="type-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                <line x1="9" y1="9" x2="15" y2="15"/>
                                <line x1="15" y1="9" x2="9" y2="15"/>
                            </svg>
                        </div>
                        <h3>Adhesivas</h3>
                        <p class="type-ideal">Ideal para: Uso diario</p>
                        <ul class="type-features">
                            <li>✓ Muy naturales</li>
                            <li>✓ Ultraligeras</li>
                            <li>✓ Aplicación profesional</li>
                            <li>✓ Duración: 8-12 meses</li>
                        </ul>
                        <span class="type-price">Desde 149€</span>
                    </div>

                    <div class="type-card">
                        <div class="type-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M12 6v6l4 2"/>
                            </svg>
                        </div>
                        <h3>Queratina</h3>
                        <p class="type-ideal">Ideal para: Resultado permanente</p>
                        <ul class="type-features">
                            <li>✓ Máxima duración</li>
                            <li>✓ Resultado invisible</li>
                            <li>✓ Aplicación profesional</li>
                            <li>✓ Duración: 3-6 meses</li>
                        </ul>
                        <span class="type-price">Desde 199€</span>
                    </div>

                    <div class="type-card">
                        <div class="type-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="3"/>
                                <circle cx="12" cy="12" r="8"/>
                            </svg>
                        </div>
                        <h3>Micro Anillas</h3>
                        <p class="type-ideal">Ideal para: Sin químicos</p>
                        <ul class="type-features">
                            <li>✓ Sin calor ni adhesivos</li>
                            <li>✓ Muy discretas</li>
                            <li>✓ Ajustables</li>
                            <li>✓ Duración: 4-6 meses</li>
                        </ul>
                        <span class="type-price">Desde 129€</span>
                    </div>

                    <div class="type-card">
                        <div class="type-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                            </svg>
                        </div>
                        <h3>Cortina</h3>
                        <p class="type-ideal">Ideal para: Volumen instantáneo</p>
                        <ul class="type-features">
                            <li>✓ Máximo volumen</li>
                            <li>✓ Colocación sencilla</li>
                            <li>✓ Efecto natural</li>
                            <li>✓ Versátil</li>
                        </ul>
                        <span class="type-price">Desde 99€</span>
                    </div>

                </div>
            </section>

            <!-- Paso 2: Largo y Peso -->
            <section class="guia-step">
                <div class="step-number">02</div>
                <h2 class="step-title">Determina el Largo y Peso</h2>
                
                <div class="length-guide">
                    <div class="length-visual">
                        <div class="length-option" data-length="35cm">
                            <div class="length-line" style="height: 25%;"></div>
                            <span>35cm - Hasta hombros</span>
                        </div>
                        <div class="length-option" data-length="50cm">
                            <div class="length-line" style="height: 50%;"></div>
                            <span>50cm - Media espalda</span>
                        </div>
                        <div class="length-option" data-length="60cm">
                            <div class="length-line" style="height: 75%;"></div>
                            <span>60cm - Espalda baja</span>
                        </div>
                        <div class="length-option" data-length="70cm">
                            <div class="length-line" style="height: 100%;"></div>
                            <span>70cm - Cintura</span>
                        </div>
                    </div>

                    <div class="weight-info">
                        <h4>Peso Recomendado</h4>
                        <div class="weight-cards">
                            <div class="weight-card">
                                <strong>80-100g</strong>
                                <span>Cabello fino</span>
                            </div>
                            <div class="weight-card">
                                <strong>120-140g</strong>
                                <span>Cabello medio</span>
                            </div>
                            <div class="weight-card">
                                <strong>160-200g</strong>
                                <span>Cabello grueso</span>
                            </div>
                        </div>
                        <p class="tip">💡 <strong>Tip:</strong> Si tienes dudas, elige el peso intermedio. Siempre puedes añadir más volumen.</p>
                    </div>
                </div>
            </section>

            <!-- Paso 3: Color -->
            <section class="guia-step">
                <div class="step-number">03</div>
                <h2 class="step-title">Encuentra Tu Color Perfecto</h2>
                
                <div class="color-guide">
                    <div class="color-tips">
                        <div class="tip-box">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M12 16v-4"/>
                                <path d="M12 8h.01"/>
                            </svg>
                            <div>
                                <strong>Consejos para elegir el color:</strong>
                                <ul>
                                    <li>Elige el color de tus medios/puntas, no de la raíz</li>
                                    <li>En caso de duda, opta por el tono más claro</li>
                                    <li>Puedes mezclar 2 tonos para un efecto más natural</li>
                                </ul>
                            </div>
                        </div>

                        <div class="color-palette">
                            <h4>Paleta de Colores Disponibles</h4>
                            <div class="colors-grid">
                                <div class="color-swatch" style="background: #1a1a1a;" title="#1 Negro Jet">
                                    <span>#1</span>
                                </div>
                                <div class="color-swatch" style="background: #3d2817;" title="#2 Castaño Oscuro">
                                    <span>#2</span>
                                </div>
                                <div class="color-swatch" style="background: #6b4423;" title="#4 Castaño Chocolate">
                                    <span>#4</span>
                                </div>
                                <div class="color-swatch" style="background: #8b5a3c;" title="#6 Castaño Claro">
                                    <span>#6</span>
                                </div>
                                <div class="color-swatch" style="background: #b8860b;" title="#10 Rubio Miel">
                                    <span>#10</span>
                                </div>
                                <div class="color-swatch" style="background: #daa520;" title="#14 Rubio Dorado">
                                    <span>#14</span>
                                </div>
                                <div class="color-swatch" style="background: #f5deb3;" title="#60 Rubio Platino">
                                    <span>#60</span>
                                </div>
                                <div class="color-swatch" style="background: linear-gradient(to right, #3d2817, #daa520);" title="Balayage">
                                    <span>Mix</span>
                                </div>
                            </div>
                            <a href="/productos" class="btn-primary" style="margin-top: 24px;">Ver Todos los Colores</a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- CTA Final -->
            <section class="guia-cta">
                <h2>¿Aún tienes dudas?</h2>
                <p>Nuestro equipo de especialistas está aquí para ayudarte</p>
                <div class="cta-actions">
                    <a href="/contacto" class="btn-primary">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        </svg>
                        Contactar Asesor
                    </a>
                    <a href="/productos" class="btn-ghost">Ver Catálogo Completo</a>
                </div>
            </section>

        </div>
    </div>
</div>

<style>
    .guia-content {
        padding: 40px 0 var(--section-gap);
    }

    .guia-step {
        margin-bottom: 96px;
        position: relative;
    }

    .step-number {
        display: inline-block;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--rose), #d45876);
        color: white;
        font-size: 24px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 24px;
    }

    .step-title {
        font-family: var(--font-display);
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 400;
        color: var(--ink);
        margin-bottom: 48px;
    }

    /* Types Grid */
    .types-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 32px;
    }

    .type-card {
        position: relative;
        background: var(--white);
        border: 2px solid var(--border);
        border-radius: 20px;
        padding: 40px 32px;
        text-align: center;
        transition: transform .3s, box-shadow .3s, border-color .3s;
    }

    .type-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,.08);
        border-color: var(--rose);
    }

    .type-featured {
        border-color: var(--rose);
        background: linear-gradient(to bottom, var(--rose-pale), var(--white));
    }

    .badge-popular {
        position: absolute;
        top: -12px;
        right: 24px;
        background: var(--rose);
        color: white;
        padding: 6px 16px;
        border-radius: 100px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
    }

    .type-icon {
        margin: 0 auto 24px;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--rose-pale);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .type-icon svg {
        color: var(--rose);
    }

    .type-card h3 {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 500;
        margin-bottom: 8px;
    }

    .type-ideal {
        font-size: 13px;
        color: var(--rose);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .1em;
        margin-bottom: 24px;
    }

    .type-features {
        list-style: none;
        text-align: left;
        margin-bottom: 24px;
    }

    .type-features li {
        padding: 8px 0;
        font-size: 14px;
        color: var(--ink-light);
    }

    .type-price {
        display: block;
        font-size: 22px;
        font-weight: 700;
        color: var(--ink);
        margin-top: 16px;
    }

    /* Length Guide */
    .length-guide {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .length-visual {
        display: flex;
        align-items: flex-end;
        justify-content: space-around;
        height: 400px;
        background: var(--off-white);
        border-radius: 16px;
        padding: 40px 20px;
    }

    .length-option {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

    .length-line {
        width: 4px;
        background: var(--rose);
        border-radius: 4px;
        transition: background .3s;
    }

    .length-option span {
        font-size: 12px;
        font-weight: 600;
        color: var(--ink-light);
        writing-mode: vertical-rl;
        text-orientation: mixed;
    }

    .weight-info h4 {
        font-family: var(--font-display);
        font-size: 20px;
        margin-bottom: 24px;
    }

    .weight-cards {
        display: grid;
        gap: 16px;
        margin-bottom: 24px;
    }

    .weight-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .weight-card strong {
        font-size: 18px;
        color: var(--rose);
    }

    .tip {
        background: #FEF3C7;
        border-left: 4px solid #F59E0B;
        padding: 16px;
        border-radius: 8px;
        font-size: 14px;
        color: #78350F;
    }

    /* Color Guide */
    .color-guide {
        max-width: 800px;
    }

    .tip-box {
        display: flex;
        gap: 20px;
        background: var(--rose-pale);
        padding: 32px;
        border-radius: 16px;
        margin-bottom: 40px;
    }

    .tip-box svg {
        color: var(--rose);
        flex-shrink: 0;
    }

    .tip-box ul {
        margin-top: 12px;
    }

    .tip-box li {
        padding: 4px 0;
        font-size: 14px;
    }

    .colors-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
        gap: 16px;
        margin-top: 24px;
    }

    .color-swatch {
        aspect-ratio: 1;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 14px;
        box-shadow: 0 4px 12px rgba(0,0,0,.1);
        cursor: pointer;
        transition: transform .2s;
    }

    .color-swatch:hover {
        transform: scale(1.1);
    }

    /* CTA Final */
    .guia-cta {
        text-align: center;
        padding: 80px 40px;
        background: linear-gradient(135deg, var(--rose-pale), var(--white));
        border-radius: 24px;
        margin-top: 64px;
    }

    .guia-cta h2 {
        font-family: var(--font-display);
        font-size: clamp(32px, 5vw, 48px);
        font-weight: 400;
        margin-bottom: 16px;
    }

    .guia-cta p {
        font-size: 18px;
        color: var(--ink-light);
        margin-bottom: 40px;
    }

    .cta-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
    }

    @@media (max-width: 768px) {
        .length-guide {
            grid-template-columns: 1fr;
        }
        
        .types-grid {
            grid-template-columns: 1fr;
        }
    }
</style> *@
