@page "/recuperar-password"
@using System.ComponentModel.DataAnnotations
@using ExtensionesShop.Client.Services
@inject AuthService AuthService

<PageTitle>Recuperar Contraseña - Extensiones Shop</PageTitle>

<div class="recuperar-page">
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <a href="/cuenta" class="breadcrumb-link">Cuenta</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Recuperar Contraseña</span>
            </div>
            <h1 class="page-title">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                Recuperar Contraseña
            </h1>
            <p class="page-subtitle">Te enviaremos instrucciones a tu email</p>
        </div>
    </div>

    <div class="recuperar-content">
        <div class="section-inner">
            <div class="recuperar-card">
                @if (emailEnviado)
                {
                    <div class="success-message">
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                        <h2>Email Enviado</h2>
                        <p>Si el email existe en nuestro sistema, recibirás instrucciones para recuperar tu contraseña.</p>
                        <p>Revisa tu bandeja de entrada y la carpeta de spam.</p>
                        <a href="/cuenta" class="btn-primary">Volver a Iniciar Sesión</a>
                    </div>
                }
                else
                {
                    <EditForm Model="@recuperarForm" OnValidSubmit="EnviarRecuperacion">
                        <DataAnnotationsValidator />

                        <div class="form-intro">
                            <p>Introduce tu dirección de email y te enviaremos instrucciones para restablecer tu contraseña.</p>
                        </div>

                        <div class="form-group">
                            <label for="email">Email</label>
                            <InputText id="email" type="email" @bind-Value="recuperarForm.Email" class="form-control" placeholder="tu@email.com" />
                            <ValidationMessage For="@(() => recuperarForm.Email)" />
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-error">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="12" y1="8" x2="12" y2="12"/>
                                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                                </svg>
                                @errorMessage
                            </div>
                        }

                        <button type="submit" class="btn-primary btn-submit" disabled="@procesando">
                            @if (procesando)
                            {
                                <span class="spinner-sm">✦</span>
                                <text>Enviando...</text>
                            }
                            else
                            {
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                    <polyline points="22,6 12,13 2,6"/>
                                </svg>
                                <text>Enviar Instrucciones</text>
                            }
                        </button>

                        <div class="back-link">
                            <a href="/cuenta" class="link-secondary">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="m15 18-6-6 6-6"/>
                                </svg>
                                Volver a Iniciar Sesión
                            </a>
                        </div>
                    </EditForm>
                }
            </div>

            <div class="help-box">
                <h3>¿Necesitas ayuda?</h3>
                <p>Si tienes problemas para recuperar tu contraseña, contacta con nuestro equipo de soporte:</p>
                <ul class="contact-list">
                    <li>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                        <a href="mailto:hola@extensionesshop.com">hola@extensionesshop.com</a>
                    </li>
                    <li>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                        </svg>
                        <a href="tel:+34600000000">+34 600 000 000</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .recuperar-content {
        padding: 40px 0 var(--section-gap);
    }

    .recuperar-content .section-inner {
        max-width: 900px;
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 48px;
        align-items: start;
    }

    .recuperar-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 48px;
    }

    .form-intro {
        margin-bottom: 32px;
        padding: 20px;
        background: var(--rose-pale);
        border-radius: 12px;
    }

    .form-intro p {
        font-size: 14px;
        color: var(--ink-light);
        margin: 0;
        line-height: 1.6;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid var(--border);
        border-radius: 10px;
        font-size: 14px;
        transition: border-color .2s, box-shadow .2s;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--rose);
        box-shadow: 0 0 0 3px rgba(232, 96, 122, .1);
    }

    .alert {
        padding: 16px;
        border-radius: 12px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 14px;
    }

    .alert-error {
        background: #FEE2E2;
        color: #DC2626;
        border: 1px solid #FECACA;
    }

    .alert svg {
        flex-shrink: 0;
    }

    .btn-submit {
        width: 100%;
        justify-content: center;
        margin-bottom: 24px;
    }

    .back-link {
        text-align: center;
    }

    .link-secondary {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: var(--ink-light);
        text-decoration: none;
        transition: color .2s;
    }

    .link-secondary:hover {
        color: var(--rose);
    }

    .success-message {
        text-align: center;
        padding: 40px 20px;
    }

    .success-message svg {
        color: var(--rose);
        margin: 0 auto 24px;
    }

    .success-message h2 {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 400;
        color: var(--ink);
        margin-bottom: 16px;
    }

    .success-message p {
        color: var(--ink-light);
        margin-bottom: 12px;
        line-height: 1.6;
    }

    .success-message .btn-primary {
        margin-top: 24px;
    }

    .help-box {
        background: var(--off-white);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 32px;
    }

    .help-box h3 {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 400;
        color: var(--ink);
        margin-bottom: 16px;
    }

    .help-box p {
        font-size: 14px;
        color: var(--ink-light);
        margin-bottom: 20px;
        line-height: 1.6;
    }

    .contact-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .contact-list li {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 14px;
    }

    .contact-list svg {
        color: var(--rose);
        flex-shrink: 0;
    }

    .contact-list a {
        color: var(--ink);
        text-decoration: none;
        transition: color .2s;
    }

    .contact-list a:hover {
        color: var(--rose);
    }

    .spinner-sm {
        display: inline-block;
        animation: spin 1s linear infinite;
    }
</style>

@code {
    private RecuperarFormModel recuperarForm = new();
    private bool procesando = false;
    private bool emailEnviado = false;
    private string errorMessage = string.Empty;

    private async Task EnviarRecuperacion()
    {
        procesando = true;
        errorMessage = string.Empty;

        try
        {
            var result = await AuthService.ForgotPasswordAsync(recuperarForm.Email);

            if (result.Success)
            {
                emailEnviado = true;
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Error al procesar la solicitud. Por favor, inténtalo de nuevo.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error al procesar la solicitud. Por favor, inténtalo de nuevo.";
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            procesando = false;
        }
    }

    public class RecuperarFormModel
    {
        [Required(ErrorMessage = "El email es obligatorio")]
        [EmailAddress(ErrorMessage = "El email no es válido")]
        public string Email { get; set; } = string.Empty;
    }
}
