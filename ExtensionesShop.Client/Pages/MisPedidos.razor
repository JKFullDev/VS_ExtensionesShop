@page "/mis-pedidos"
@using ExtensionesShop.Shared.Models
@using ExtensionesShop.Client.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Mis Pedidos - Extensiones Shop</PageTitle>

<div class="mis-pedidos-page">
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <a href="/cuenta" class="breadcrumb-link">Mi Cuenta</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Mis Pedidos</span>
            </div>
            <h1 class="page-title">📦 Mis Pedidos</h1>
            <p class="page-subtitle">Consulta el estado de tus pedidos</p>
        </div>
    </div>

    <div class="pedidos-content">
        <div class="section-inner">
            @if (!AuthService.IsAuthenticated)
            {
                <div class="alert-info">
                    <p>Debes iniciar sesión para ver tus pedidos</p>
                    <a href="/cuenta" class="btn-primary">Iniciar Sesión</a>
                </div>
            }
            else if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner">✦</div>
                    <p>Cargando pedidos...</p>
                </div>
            }
            else if (!pedidos.Any())
            {
                <div class="empty-state">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <path d="M16 10a4 4 0 0 1-8 0" />
                    </svg>
                    <h3>Aún no tienes pedidos</h3>
                    <p>Cuando realices un pedido, aparecerá aquí</p>
                    <a href="/productos" class="btn-primary">Ver Productos</a>
                </div>
            }
            else
            {
                <div class="pedidos-list">
                    @foreach (var pedido in pedidos)
                    {
                        <div class="accordion-item" key="@pedido.Id">
                            <!-- Cabecera del Acordeón -->
                            <button class="accordion-header" @onclick="() => ToggleAccordion(pedido.Id)">
                                <div class="header-left">
                                    <div class="header-info">
                                        <h3>Pedido #@pedido.Id</h3>
                                        <span class="fecha">@pedido.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                </div>

                                <div class="header-right">
                                    <span class="pedido-status @GetStatusClass(pedido.Status)">
                                        @GetStatusText(pedido.Status)
                                    </span>
                                    <span class="total">€@pedido.Total.ToString("N2")</span>
                                    <svg class="chevron @(expandedOrders.Contains(pedido.Id) ? "open" : "")" 
                                         width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="6 9 12 15 18 9"></polyline>
                                    </svg>
                                </div>
                            </button>

                            <!-- Contenido Colapsable -->
                            @if (expandedOrders.Contains(pedido.Id))
                            {
                                <div class="accordion-content">
                                    <!-- Dirección de Envío -->
                                    <div class="content-section">
                                        <h4>📍 Dirección de Envío</h4>
                                        <p>@pedido.ShippingAddress</p>
                                        <p>@pedido.City, @pedido.PostalCode</p>
                                    </div>

                                    <!-- Productos Comprados -->
                                    <div class="content-section">
                                        <h4>📦 Productos</h4>
                                        <div class="items-list">
                                            @if (pedido.OrderItems != null && pedido.OrderItems.Any())
                                            {
                                                @foreach (var item in pedido.OrderItems)
                                                {
                                                    <div class="order-item">
                                                        <div class="item-detail">
                                                            <p class="item-name">@item.ProductName</p>
                                                            <p class="item-specs">
                                                                @if (!string.IsNullOrEmpty(item.SelectedColor))
                                                                {
                                                                    <span>@item.SelectedColor</span>
                                                                }
                                                                @if (item.SelectedCentimeters.HasValue)
                                                                {
                                                                    <span>@item.SelectedCentimeters cm</span>
                                                                }
                                                            </p>
                                                        </div>
                                                        <div class="item-quantity">x@(item.Quantity)</div>
                                                        <div class="item-price">€@item.UnitPrice.ToString("N2")</div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>

                                    <!-- Desglose de Precios -->
                                    <div class="content-section price-breakdown">
                                        <div class="breakdown-row">
                                            <span>Subtotal:</span>
                                            <span>€@pedido.Subtotal.ToString("N2")</span>
                                        </div>
                                        <div class="breakdown-row">
                                            <span>Envío:</span>
                                            <span>€@pedido.ShippingCost.ToString("N2")</span>
                                        </div>
                                        <div class="breakdown-row total">
                                            <span>Total:</span>
                                            <span>€@pedido.Total.ToString("N2")</span>
                                        </div>
                                    </div>

                                    <!-- Notas si existen -->
                                    @if (!string.IsNullOrEmpty(pedido.Notes))
                                    {
                                        <div class="content-section">
                                            <h4>📝 Notas</h4>
                                            <p>@pedido.Notes</p>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .mis-pedidos-page {
        min-height: 100vh;
        padding-bottom: 60px;
    }

    .loading-state {
        text-align: center;
        padding: 60px 20px;
    }

    .spinner {
        font-size: 48px;
        color: var(--rose);
        animation: spin 2s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-state svg {
        color: var(--muted);
        margin-bottom: 20px;
    }

    .empty-state h3 {
        font-size: 24px;
        color: var(--ink);
        margin-bottom: 10px;
    }

    .empty-state p {
        color: var(--muted);
        margin-bottom: 30px;
    }

    .alert-info {
        background: #FFF3CD;
        border: 1px solid #FFC107;
        border-radius: 12px;
        padding: 24px;
        text-align: center;
    }

    .pedidos-grid {
        display: grid;
        gap: 24px;
    }

    /* Acordeón */
    .pedidos-list {
        display: grid;
        gap: 16px;
    }

    .accordion-item {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        transition: box-shadow 0.3s;
    }

    .accordion-item:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    }

    .accordion-header {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 24px;
        background: none;
        border: none;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .accordion-header:hover {
        background-color: var(--off-white);
    }

    .header-left {
        display: flex;
        align-items: center;
        flex: 1;
    }

    .header-info h3 {
        font-size: 16px;
        font-weight: 700;
        color: var(--ink);
        margin: 0 0 4px 0;
    }

    .header-info .fecha {
        font-size: 13px;
        color: var(--muted);
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .pedido-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .header-right .total {
        font-weight: 700;
        font-size: 16px;
        color: var(--rose);
        min-width: 100px;
        text-align: right;
    }

    .chevron {
        transition: transform 0.3s ease;
        flex-shrink: 0;
        color: var(--muted);
    }

    .chevron.open {
        transform: rotate(180deg);
    }

    /* Contenido del Acordeón */
    .accordion-content {
        padding: 24px;
        border-top: 1px solid var(--border);
        background: var(--off-white);
        animation: slideDown 0.3s ease;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .content-section {
        margin-bottom: 24px;
    }

    .content-section:last-child {
        margin-bottom: 0;
    }

    .content-section h4 {
        font-size: 14px;
        font-weight: 700;
        color: var(--ink);
        margin: 0 0 12px 0;
    }

    .content-section p {
        margin: 4px 0;
        font-size: 14px;
        color: var(--ink-light);
    }

    .items-list {
        display: grid;
        gap: 12px;
    }

    .order-item {
        display: grid;
        grid-template-columns: 1fr 60px 100px;
        gap: 12px;
        align-items: center;
        padding: 12px;
        background: white;
        border-radius: 8px;
        border: 1px solid var(--border);
    }

    .item-detail {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .item-name {
        font-weight: 600;
        font-size: 14px;
        color: var(--ink);
        margin: 0;
    }

    .item-specs {
        font-size: 12px;
        color: var(--muted);
        display: flex;
        gap: 6px;
        margin: 0;
    }

    .item-specs span {
        display: inline-block;
    }

    .item-quantity {
        text-align: center;
        font-weight: 600;
        color: var(--ink-light);
        font-size: 13px;
    }

    .item-price {
        text-align: right;
        font-weight: 700;
        font-size: 14px;
        color: var(--ink);
    }

    .price-breakdown {
        background: white;
        border-radius: 8px;
        border: 1px solid var(--border);
        padding: 12px;
    }

    .breakdown-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        font-size: 14px;
        color: var(--ink-light);
        border-bottom: 1px solid var(--off-white);
    }

    .breakdown-row:last-child {
        border-bottom: none;
    }

    .breakdown-row.total {
        font-weight: 700;
        color: var(--ink);
        font-size: 16px;
        padding: 12px 0 0 0;
        border-top: 2px solid var(--border);
    }

    .breakdown-row span:last-child {
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .accordion-header {
            flex-direction: column;
            gap: 12px;
        }

        .header-right {
            width: 100%;
            justify-content: space-between;
        }

        .order-item {
            grid-template-columns: 1fr;
        }

        .item-price {
            text-align: left;
        }
    }
</style>

@code {
    private List<Order> pedidos = new();
    private bool isLoading = true;
    private HashSet<int> expandedOrders = new(); // ✅ Rastrear acordeones abiertos

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/cuenta");
            return;
        }

        await CargarPedidos();
    }

    private async Task CargarPedidos()
    {
        try
        {
            isLoading = true;
            var userId = AuthService.CurrentUser?.Id;

            if (userId.HasValue)
            {
                pedidos = await Http.GetFromJsonAsync<List<Order>>($"api/orders?userId={userId}") ?? new();
                Console.WriteLine($"✅ Pedidos cargados: {pedidos.Count}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error cargando pedidos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetStatusText(int status)
    {
        return status switch
        {
            0 => "Pendiente",
            1 => "Confirmado",
            2 => "En Proceso",
            3 => "Enviado",
            4 => "Entregado",
            5 => "Cancelado",
            _ => "Desconocido"
        };
    }

    private string GetStatusClass(int status)
    {
        return status switch
        {
            0 => "status-pending",
            1 => "status-confirmed",
            2 => "status-processing",
            3 => "status-shipped",
            4 => "status-delivered",
            5 => "status-cancelled",
            _ => "status-pending"
        };
    }

    // ✅ Método para alternar acordeón
    private void ToggleAccordion(int orderId)
    {
        if (expandedOrders.Contains(orderId))
        {
            expandedOrders.Remove(orderId);
        }
        else
        {
            expandedOrders.Add(orderId);
        }
    }
}
