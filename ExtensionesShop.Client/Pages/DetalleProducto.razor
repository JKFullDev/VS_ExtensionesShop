@page "/producto/{id:int}"
@using ExtensionesShop.Shared.Models
@using ExtensionesShop.Client.Services
@inject ProductService ProductService
@inject CartStateService CartState
@inject FavoritosService FavoritosService
@inject NavigationManager Navigation
@inject AuthService AuthService

<PageTitle>@(producto?.Name ?? "Cargando...") - Extensiones Shop</PageTitle>

<div class="detalle-producto-page">
    @if (cargando)
    {
        <div class="loading-state">
            <div class="spinner">✦</div>
            <p>Cargando producto...</p>
        </div>
    }
    else if (producto == null)
    {
        <div class="error-state">
            <div class="section-inner">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <h2>Producto no encontrado</h2>
                <p>Lo sentimos, el producto que buscas no existe o ha sido eliminado.</p>
                <a href="/productos" class="btn-primary">Volver al Catálogo</a>
            </div>
        </div>
    }
    else
    {
        <!-- Breadcrumb -->
        <div class="breadcrumb-section">
            <div class="section-inner">
                <div class="breadcrumb">
                    <a href="/" class="breadcrumb-link">Inicio</a>
                    <span class="breadcrumb-separator">→</span>
                    <a href="/productos" class="breadcrumb-link">Productos</a>
                    <span class="breadcrumb-separator">→</span>
                    @if (producto.Category != null)
                    {
                        <a href="/productos?categoria=@producto.Category.Name" class="breadcrumb-link">@producto.Category.Name</a>
                        <span class="breadcrumb-separator">→</span>
                    }
                    <span class="breadcrumb-current">@producto.Name</span>
                </div>
            </div>
        </div>

        <!-- Contenido del Producto -->
        <div class="producto-content">
            <div class="section-inner">
                <div class="producto-layout">
                    <!-- Galería de Imágenes -->
                    <div class="producto-gallery">
                        <div class="main-image">
                            <img src="@currentImageUrl" alt="@producto.Name" />
                        </div>

                        <!-- Galería de Miniaturas -->
                        @if (producto.Images != null && producto.Images.Any())
                        {
                            <div class="gallery-thumbnails">
                                <button class="thumbnail-btn @(currentImageUrl == producto.ImageUrl ? "active" : "")"
                                        @onclick="() => CambiarImagenActual(producto.ImageUrl ?? string.Empty)"
                                        title="Imagen principal">
                                    <img src="@producto.ImageUrl" alt="Principal" loading="lazy" />
                                </button>

                                @foreach (var imagen in producto.Images.Where(i => i.IsActive).OrderBy(i => i.DisplayOrder))
                                {
                                    <button class="thumbnail-btn @(currentImageUrl == imagen.ImageUrl ? "active" : "")"
                                            @onclick="() => CambiarImagenActual(imagen.ImageUrl)"
                                            title="@(imagen.AltText ?? "Imagen adicional")">
                                        <img src="@imagen.ImageUrl" alt="@imagen.AltText" loading="lazy" />
                                    </button>
                                }
                            </div>
                        }

                        @if (producto.Stock > 0)
                        {
                            <div class="stock-badge available">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                Disponible
                            </div>
                        }
                        else
                        {
                            <div class="stock-badge out-of-stock">
                                Agotado
                            </div>
                        }
                    </div>

                    <!-- Información del Producto -->
                    <div class="producto-details">
                        @if (producto.Category != null)
                        {
                            <span class="categoria-badge">@producto.Category.Name</span>
                        }
                        
                        <h1 class="producto-nombre">@producto.Name</h1>

                        <!-- Precio -->
                        <div class="precio-section">
                            <span class="precio-actual">@GetPrecio().ToString("C")</span>
                        </div>

                        <!-- Atributos -->
                        @if (producto.Centimeters.HasValue || !string.IsNullOrEmpty(producto.Color))
                        {
                            <div class="atributos-section">
                                <h3>Características</h3>
                                <div class="atributos-list">
                                    @* @if (producto.Centimeters.HasValue || (selectedVariant != null && selectedVariant.Centimeters.HasValue))
                                    {
                                        <div class="atributo-item">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <line x1="21" y1="10" x2="3" y2="10"></line>
                                                <line x1="21" y1="6" x2="3" y2="6"></line>
                                                <line x1="21" y1="14" x2="3" y2="14"></line>
                                                <line x1="21" y1="18" x2="3" y2="18"></line>
                                            </svg>
                                            <div>
                                                <strong>Longitud</strong>
                                                <span>@((selectedVariant?.Centimeters ?? producto.Centimeters) ?? 0) cm</span>
                                            </div>
                                        </div>
                                    } *@
                                    
                                    @if (!string.IsNullOrEmpty(producto.Color))
                                    {
                                        <div class="atributo-item">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="12" r="10"></circle>
                                            </svg>
                                            <div>
                                                <strong>Variante</strong>
                                                <span>@producto.Color</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Descripción -->
                        <div class="descripcion-section">
                            <h3>Descripción</h3>
                            <p>@producto.Description</p>
                        </div>

                        <!-- Stock -->
                        @if (producto.Stock > 0 && producto.Stock < 10)
                        {
                            <div class="stock-alert">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="12" y1="8" x2="12" y2="12"/>
                                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                                </svg>
                                ¡Solo quedan @producto.Stock unidades disponibles!
                            </div>
                        }

                        <!-- Selector de Variantes -->
                        @if (producto.Variants != null && producto.Variants.Any())
                        {
                            <div class="variante-selector">
                                <label>Selecciona tu variante *</label>
                                <select class="form-control" @onchange="OnVarianteChanged">
                                    <option value="0">-- Elige Color / Longitud --</option>
                                    @foreach (var variante in producto.Variants.OrderBy(v => v.DisplayOrder))
                                    {
                                        <option value="@variante.Id">
                                            @if (!string.IsNullOrEmpty(variante.Color))
                                            {
                                                @variante.Color
                                            }
                                            @if (variante.Centimeters.HasValue)
                                            {
                                                <text> - @variante.Centimeters cm</text>
                                            }
                                            (Stock: @variante.Stock)
                                        </option>
                                    }
                                </select>
                            </div>
                        }

                        <!-- Cantidad y Botones -->
                        <div class="cantidad-section">
                            <label>Cantidad</label>
                            <div class="cantidad-controls">
                                <button class="btn-cantidad" @onclick="DecrementarCantidad" disabled="@(cantidad <= 1)">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="5" y1="12" x2="19" y2="12"/>
                                    </svg>
                                </button>
                                <input type="number" class="cantidad-input" @bind="cantidad" min="1" max="@GetMaxStock()" />
                                <button class="btn-cantidad" @onclick="IncrementarCantidad" disabled="@(cantidad >= GetMaxStock())">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="12" y1="5" x2="12" y2="19"/>
                                        <line x1="5" y1="12" x2="19" y2="12"/>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <!-- Botones de Acción -->
                        <div class="acciones-section">
                            @if (agregadoAlCarrito)
                            {
                                <div class="success-message">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                    </svg>
                                    ¡Producto añadido al carrito!
                                </div>

                                <div class="acciones-botones-success">
                                    <button class="btn-primary btn-lg" @onclick="VerCarrito">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                            <line x1="3" y1="6" x2="21" y2="6" />
                                            <path d="M16 10a4 4 0 0 1-8 0" />
                                        </svg>
                                        <text>Ver mi Carrito</text>
                                    </button>
                                    <button class="btn-secondary btn-lg" @onclick="SeguidCompra">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                        </svg>
                                        <text>Seguir Comprando</text>
                                    </button>
                                </div>
                            }
                            else
                            {
                                @if (producto.Variants?.Any() == true && selectedVariant == null)
                                {
                                    <div style="color: #F59E0B; font-size: 13px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"/>
                                            <line x1="12" y1="8" x2="12" y2="12"/>
                                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                                        </svg>
                                        Por favor, selecciona una opción
                                    </div>
                                }

                                <button class="btn-primary btn-lg" 
                                        disabled="@(producto.Stock == 0 || (producto.Variants?.Any() == true && selectedVariant == null))" 
                                        @onclick="AgregarAlCarrito"
                                        title="@GetButtonTooltip()">
                                    @if (producto.Stock > 0)
                                    {
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                            <line x1="3" y1="6" x2="21" y2="6" />
                                            <path d="M16 10a4 4 0 0 1-8 0" />
                                        </svg>
                                        <text>Añadir al Carrito</text>
                                    }
                                    else
                                    {
                                        <text>No Disponible</text>
                                    }
                                </button>

                                <button class="btn-secondary btn-lg" @onclick="ToggleFavorito">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="@(esFavorito ? "currentColor" : "none")" stroke="currentColor" stroke-width="2">
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                    </svg>
                                    @(esFavorito ? "Quitar de Favoritos" : "Añadir a Favoritos")
                                </button>

                                <!-- Botón de Edición exclusivo para Admin -->
                                @if (AuthService.IsAdmin)
                                {
                                    <a href="/admin/productos?editId=@Id" target="_top" class="btn-admin" style="border-color: #F59E0B; color: #D97706; text-decoration: none; margin-top: 10px;">
                                        ⚙️ Editar este producto
                                    </a>
                                }
                            }
                        </div>

                        <!-- Info Adicional -->
                        <div class="info-adicional">
                            <div class="info-item">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                    <circle cx="12" cy="10" r="3"/>
                                </svg>
                                <span>Envío gratuito en pedidos +50€</span>
                            </div>
                            <div class="info-item">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"/>
                                    <polyline points="12 6 12 12 16 14"/>
                                </svg>
                                <span>Entrega en 24-48 horas</span>
                            </div>
                            <div class="info-item">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                </svg>
                                <span>Garantía de calidad 100% Remy</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Productos Relacionados -->
        @if (productosRelacionados.Any())
        {
            <div class="productos-relacionados-section">
                <div class="section-inner">
                    <h2 class="section-title">Productos Relacionados</h2>
                    <div class="productos-grid">
                        @foreach (var p in productosRelacionados.Take(4))
                        {
                            <div class="producto-card">
                                <a href="/producto/@p.Id" class="producto-link">
                                    <div class="producto-image">
                                        <img src="@p.ImageUrl" alt="@p.Name" loading="lazy" />
                                    </div>
                                    <div class="producto-info">
                                        <h3>@p.Name</h3>
                                        <p class="precio">@p.Price.ToString("C")</p>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .detalle-producto-page {
        min-height: 70vh;
    }

    .loading-state, .error-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        text-align: center;
    }

    .error-state svg {
        color: var(--muted);
        margin-bottom: 24px;
    }

    .error-state h2 {
        font-size: 24px;
        margin-bottom: 12px;
    }

    .error-state p {
        color: var(--muted);
        margin-bottom: 24px;
    }

    .spinner {
        font-size: 48px;
        animation: spin 2s linear infinite;
        margin-bottom: 20px;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    /* Breadcrumb */
    .breadcrumb-section {
        padding: 24px 0;
        background: var(--bg-secondary);
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        font-size: 13px;
    }

    .breadcrumb-link {
        color: var(--ink-light);
        text-decoration: none;
        transition: color .2s;
    }

    .breadcrumb-link:hover {
        color: var(--rose);
    }

    .breadcrumb-separator {
        color: var(--muted);
    }

    .breadcrumb-current {
        color: var(--ink);
        font-weight: 500;
    }

    /* Producto Layout */
    .producto-content {
        padding: 60px 0;
    }

    .producto-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: start;
    }

    /* Galería */
    .producto-gallery {
        position: relative;
        position: sticky;
        top: 100px;
    }

    .main-image {
        background: var(--bg-secondary);
        border-radius: 20px;
        overflow: hidden;
        aspect-ratio: 1;
    }

    .main-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Galería de Miniaturas */
    .gallery-thumbnails {
        display: flex;
        gap: 12px;
        margin-top: 16px;
        flex-wrap: wrap;
    }

    .thumbnail-btn {
        width: 80px;
        height: 80px;
        border: 2px solid var(--border);
        border-radius: 12px;
        padding: 0;
        background: white;
        cursor: pointer;
        overflow: hidden;
        transition: all 0.2s;
        flex-shrink: 0;
    }

    .thumbnail-btn img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .thumbnail-btn:hover {
        border-color: var(--rose);
        transform: scale(1.05);
    }

    .thumbnail-btn.active {
        border-color: var(--rose);
        box-shadow: 0 0 0 3px rgba(232, 96, 122, 0.2);
    }

    .stock-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .stock-badge.available {
        background: #D1FAE5;
        color: #065F46;
    }

    .stock-badge.out-of-stock {
        background: #FEE2E2;
        color: #991B1B;
    }

    /* Selector de Variantes */
    .variante-selector {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .variante-selector label {
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
    }

    .variante-selector select {
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
        background: white;
        color: var(--ink);
        cursor: pointer;
        transition: border-color 0.2s;
    }

    .variante-selector select:focus {
        outline: none;
        border-color: var(--rose);
        box-shadow: 0 0 0 3px rgba(232, 96, 122, 0.1);
    }

    /* Detalles */
    .producto-details {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .categoria-badge {
        display: inline-block;
        padding: 6px 14px;
        background: var(--bg-secondary);
        color: var(--rose);
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        width: fit-content;
    }

    .producto-nombre {
        font-family: var(--font-display);
        font-size: 36px;
        font-weight: 400;
        margin: 0;
        color: var(--ink);
    }

    .precio-section {
        padding: 20px 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
    }

    .precio-actual {
        font-size: 32px;
        font-weight: 600;
        color: var(--rose);
    }

    /* Atributos */
    .atributos-section h3,
    .descripcion-section h3 {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 16px;
    }

    .atributos-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .atributo-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        background: var(--bg-secondary);
        border-radius: 12px;
    }

    .atributo-item svg {
        color: var(--rose);
        flex-shrink: 0;
    }

    .atributo-item div {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .atributo-item strong {
        font-size: 13px;
        font-weight: 600;
        color: var(--ink);
    }

    .atributo-item span {
        font-size: 14px;
        color: var(--ink-light);
    }

    /* Descripción */
    .descripcion-section p {
        color: var(--ink-light);
        line-height: 1.7;
    }

    /* Stock Alert */
    .stock-alert {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: #FEF3C7;
        border: 1px solid #FDE047;
        border-radius: 12px;
        color: #92400E;
        font-size: 14px;
        font-weight: 500;
    }

    .stock-alert svg {
        flex-shrink: 0;
    }

    /* Cantidad */
    .cantidad-section label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .cantidad-controls {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .btn-cantidad {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--border);
        background: white;
        border-radius: 8px;
        cursor: pointer;
        transition: all .2s;
    }

    .btn-cantidad:hover:not(:disabled) {
        border-color: var(--rose);
        color: var(--rose);
    }

    .btn-cantidad:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .cantidad-input {
        width: 80px;
        height: 40px;
        text-align: center;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
    }

    .cantidad-input:focus {
        outline: none;
        border-color: var(--rose);
    }

    /* Acciones */
    .acciones-section {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .acciones-botones-success {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .success-message {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 16px;
        background: #D1FAE5;
        border: 1px solid #A7F3D0;
        border-radius: 12px;
        color: #065F46;
        font-weight: 500;
        animation: slideIn 0.3s ease;
    }

    .success-message svg {
        flex-shrink: 0;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .btn-lg {
        flex: 1;
        padding: 16px 24px;
        font-size: 16px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-primary {
        background: var(--rose);
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
    }

    .btn-primary:hover:not(:disabled) {
        background: var(--rose-deep);
        transform: translateY(-2px);
    }

    .btn-primary:disabled {
        background: var(--border-dark);
        color: var(--muted);
        cursor: not-allowed;
        opacity: 0.6;
    }

    .btn-secondary {
        background: var(--off-white);
