@code {
    [Parameter]
    public int Id { get; set; }

    private Product? producto;
    private List<Product> productosRelacionados = new();
    private bool cargando = true;
    private int cantidad = 1;
    private bool esFavorito = false;
    private bool agregadoAlCarrito = false;
    private string currentImageUrl = string.Empty;
    private ProductVariant? selectedVariant;

    protected override async Task OnParametersSetAsync()
    {
        cargando = true;
        agregadoAlCarrito = false;

        try
        {
            // Cargar producto
            var productos = await ProductService.GetProductsAsync();
            producto = productos.FirstOrDefault(p => p.Id == Id);

            if (producto != null)
            {
                // Inicializar imagen actual
                currentImageUrl = producto.ImageUrl ?? string.Empty;

                // Verificar si está en favoritos
                esFavorito = FavoritosService.IsFavorito(Id);

                // Cargar productos relacionados de la misma categoría
                if (producto.CategoryId > 0)
                {
                    productosRelacionados = productos
                        .Where(p => p.CategoryId == producto.CategoryId && p.Id != producto.Id)
                        .Take(4)
                        .ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando producto: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private void IncrementarCantidad()
    {
        if (producto != null && cantidad < producto.Stock)
        {
            cantidad++;
        }
    }

    private void DecrementarCantidad()
    {
        if (cantidad > 1)
        {
            cantidad--;
        }
    }

    private async Task AgregarAlCarrito()
    {
        if (producto == null) return;

        Console.WriteLine($"🛒 Intentando añadir al carrito:");
        Console.WriteLine($"   Producto ID: {producto.Id}");
        Console.WriteLine($"   Variante seleccionada: {selectedVariant?.Id} (Color: {selectedVariant?.Color}, Centimeters: {selectedVariant?.Centimeters})");
        Console.WriteLine($"   Cantidad: {cantidad}");

        try
        {
            // Pasar el variantId si está seleccionado
            await CartState.AgregarProducto(producto, cantidad, selectedVariant?.Id);

            // Cambiar estado visual SOLO si fue exitoso
            agregadoAlCarrito = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error al añadir al carrito: {ex.Message}");
            // El error será manejado por CartStateService (notificación al usuario)
        }
    }

    private void SeguidCompra()
    {
        agregadoAlCarrito = false;
        cantidad = 1;
        StateHasChanged();
    }

    private void VerCarrito()
    {
        Navigation.NavigateTo("/carrito");
    }

    private async Task ToggleFavorito()
    {
        if (producto == null) return;

        esFavorito = await FavoritosService.ToggleFavoritoAsync(producto);
        StateHasChanged();
    }

    private void CambiarVariante(int variantId)
    {
        if (variantId == 0)
        {
            selectedVariant = null;
        }
        else if (producto?.Variants != null)
        {
            Console.WriteLine($"🔍 Buscando variante con ID: {variantId}");
            Console.WriteLine($"📊 Variantes disponibles:");
            foreach (var v in producto.Variants)
            {
                Console.WriteLine($"   - ID: {v.Id}, Color: {v.Color}, Centimeters: {v.Centimeters}, Stock: {v.Stock}");
            }

            selectedVariant = producto.Variants.FirstOrDefault(v => v.Id == variantId);

            Console.WriteLine($"✅ Variante seleccionada: ID={selectedVariant?.Id}, Color={selectedVariant?.Color}, Centimeters={selectedVariant?.Centimeters}");

            // Resetear cantidad si excede el stock de la nueva variante
            if (selectedVariant != null && cantidad > selectedVariant.Stock)
            {
                cantidad = 1;
            }
        }
        StateHasChanged();
    }

    private void OnVarianteChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var variantId))
        {
            CambiarVariante(variantId);
        }
    }

    private int GetMaxStock()
    {
        if (selectedVariant != null)
            return selectedVariant.Stock;

        return producto?.Stock ?? 0;
    }

    private decimal GetPrecio()
    {
        if (selectedVariant != null)
            return selectedVariant.Price;

        // Si no hay variante seleccionada, mostrar el precio mínimo (o price base)
        return producto?.PrecioMinimo ?? 0;
    }

    private string GetButtonTooltip()
    {
        if (producto?.Stock == 0)
            return "Producto agotado";

        if (producto?.Variants?.Any() == true && selectedVariant == null)
            return "Selecciona una variante primero";

        return "Añadir al carrito";
    }

    private void CambiarImagenActual(string nuevaUrl)
    {
        currentImageUrl = nuevaUrl;
        StateHasChanged();
    }
}
