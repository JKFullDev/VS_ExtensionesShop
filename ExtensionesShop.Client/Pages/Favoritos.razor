@page "/favoritos"

<PageTitle>Mis Favoritos - Extensiones Shop</PageTitle>

<div class="favoritos-page">
    <div class="page-header">
        <div class="section-inner">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-link">Inicio</a>
                <span class="breadcrumb-separator">→</span>
                <span class="breadcrumb-current">Favoritos</span>
            </div>
            <h1 class="page-title">
                Mis Favoritos
            </h1>
            <p class="page-subtitle">Guarda tus extensiones favoritas para encontrarlas fácilmente</p>
        </div>
    </div>

    <div class="favoritos-content">
        <div class="section-inner">
            <div class="empty-state">
                <div class="empty-icon">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                </div>
                <h2>Aún no tienes favoritos</h2>
                <p>Explora nuestro catálogo y guarda los productos que más te gusten</p>
                <a href="/productos" class="btn-primary">
                    Descubrir Productos
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m9 18 6-6-6-6"/>
                    </svg>
                </a>

                <div class="features-list">
                    <div class="feature-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Guarda tus productos favoritos</span>
                    </div>
                    <div class="feature-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Compara diferentes opciones</span>
                    </div>
                    <div class="feature-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Recibe alertas de descuentos</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .favoritos-content {
        padding: 40px 0 var(--section-gap);
        min-height: 60vh;
    }

    .empty-state {
        text-align: center;
        padding: 0px 20px;
    }

    .empty-icon {
        margin: 0 auto 32px;
        color: var(--rose);
        justify-self: center;
        opacity: .3;
    }

    .empty-state h2 {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 400;
        color: var(--ink);
        margin-bottom: 16px;
    }

    .empty-state p {
        font-size: 16px;
        color: var(--muted);
        margin-bottom: 32px;
    }

    .features-list {
        display: inline-flex;
        flex-direction: column;
        gap: 16px;
        margin-top: 48px;
        text-align: left;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--ink-light);
    }

    .feature-item svg {
        color: var(--rose);
        flex-shrink: 0;
    }
</style>
